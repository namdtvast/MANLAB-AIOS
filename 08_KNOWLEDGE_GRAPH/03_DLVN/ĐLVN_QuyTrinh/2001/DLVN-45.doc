\par }{\b 6.1 Ki\'d3m tra b\'aan ngo\'b5i
\par }{
\par Ki\'d3m tra b\'bbng m\'bet \'ae\'d3 x\'b8c \'ae\'denh s\'f9 ph\'ef h\'eep c\'f1a m\'b8y \'aeo v\'edi c\'b8c y\'aau c\'c7u quy \'ae\'denh trong t\'b5i li\'d6u k\'fc thu\'cbt, v\'d2 h\'d7nh d\'b8ng, k\'ddch th\'ad\'edc, ch\'d8 th\'de, ngu\'e5n nu\'abi, k
\'fd nh\'b7n hi\'d6u, c\'ac c\'cau ni\'aam phong c\'f1a m\'b8y, t\'b5i li\'d6u v\'b5 ph\'f4 t\'efng k\'ccm theo.
\par }\pard \ql \li0\ri0\widctlpar\faauto\adjustright\rin0\lin0\itap0 {
\par }{\b 6.2 Ki\'d3m tra k\'fc thu\'cbt
\par }{
\par Ki\'d3m tra tr\'b9ng th\'b8i ho\'b9t \'ae\'e9ng b\'d7nh th\'ad\'eang c\'f1a m\'b8y \'aeo theo h\'ad\'edng d\'c9n v\'cbn h\'b5nh c\'f1a t\'f5ng lo\'b9i m\'b8y.
\par 
\par }{\b 6.3 Ki\'d3m tra \'aeo l\'ad\'eang
\par }{
\par 6.3.1 Ki\'d3m tra \'aei\'d3m }{\cf1 \'930\'94
\par 
\par 6.3.1.1 Th\'f9c hi\'d6n ki\'d3m tra \'aei\'d3m \'930\'94 c\'f1a m\'b8y sau khi m\'b8y \'ae\'b7 \'ae\'ad\'eec s\'cay theo h\'ad\'edng d\'c9n s\'f6 d\'f4ng. Th\'f9c hi\'d6n ki\'d3m tra \'aei\'d3m \'930\'94 c\'f1a m\'b8y b\'bbng c\'b8ch \'aeo kh\'dd Nit\'ac
 tinh khi\'d5t k\'fc thu\'cbt. Ghi k\'d5t qu\'b6 \'aeo \'ae\'ad\'eec v\'b5o bi\'aan b\'b6n \'eb ph\'f4 l\'f4c 1.
\par 
\par 6.3.1.2  Sau 15 ph\'f3t th\'f9c hi\'d6n l\'b9i vi\'d6c ki\'d3m tra \'aei\'d3m \'930\'94 l\'c7n th\'f8 hai. Ghi k\'d5t qu\'b6 \'aeo \'ae\'ad\'eec v\'b5o bi\'aan b\'b6n \'eb ph\'f4 l\'f4c 1. 
\par 
\par Ch\'aanh l\'d6ch gi\'f7a gi\'b8 tr\'de \'ae\'e4c \'ae\'ad\'eec theo m\'f4c 6.3.1.1 so v\'edi m\'f4c 6.3.1.2 kh\'abng \'ae\'ad\'eec l\'edn h\'acn }{\pard\plain \ql \li0\ri0\widctlpar\faauto\adjustright\rin0\lin0\itap0 
