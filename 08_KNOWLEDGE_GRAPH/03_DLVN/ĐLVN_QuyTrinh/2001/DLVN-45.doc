\par 
\par }\pard \qj \li0\ri0\widctlpar\faauto\adjustright\rin0\lin0\itap0 {6.3.3.1 Ch\'e4n kh\'dd chu\'c8n nh\'ad m\'f4c 6.3.2.1 ho\'c6c 6.3.2.2.
\par 
\par 6.3.3.2 Th\'f9c hi\'d6n 3 ph\'d0p \'aeo li\'aan ti\'d5p do m\'e9t ng\'ad\'eai ti\'d5n h\'b5nh \'ae\'e8i v\'edi kh\'dd chu\'c8n \'ae\'b7 ch\'e4n. Ghi k\'d5t qu\'b6 \'aeo v\'b5o bi\'aan b\'b6n \'eb ph\'f4 l\'f4c 1. 
\par 
\par }{\cf1 Ch\'aanh l\'d6ch gi\'f7a c\'b8c gi\'b8 tr\'de \'aeo \'ae\'ad\'eec max v\'b5 min ph\'b6i  }{\cf1 {\field{\*\fldinst SYMBOL 163 \\f "Symbol" \\s 13}{\fldrslt\f3\fs26}}}{\cf1   sai s\'e8 cho ph\'d0p c\'f1a m\'b8y.  }{\i\ul\cf1 
\par }{
\par 6.3.4 Ki\'d3m tra thay \'ae\'e6i \'aei\'d6n \'b8p ngu\'e5n nu\'abi
\par 
\par Ch\'d8 ki\'d3m tra thay \'ae\'e6i \'aei\'d6n \'b8p ngu\'e5n nu\'abi \'ae\'e8i v\'edi m\'b8y \'aeo s\'f6 d\'f4ng \'aei\'d6n l\'ad\'edi.
\par 
\par 6.3.4.1 Ch\'e4n kh\'dd chu\'c8n ph\'ef h\'eep \'ae\'e8i v\'edi m\'b8y \'aeo theo m\'f4c 6.3.2.1 ho\'c6c 6.3.2.2. Vi\'d6c ki\'d3m tra \'b6nh h\'ad\'ebng do thay \'ae\'e6i \'aei\'d6n \'b8p ngu\'e5n nu\'abi \'ae\'ad\'eec ti\'d5n h\'b5nh t\'b9i m\'e9t \'aei
\'d3m \'eb thang \'aeo b\'cat k\'fa c\'f1a m\'b8y.
\par }\pard \ql \li0\ri0\widctlpar\faauto\adjustright\rin0\lin0\itap0 {
\par }\pard \qj \li0\ri0\widctlpar\faauto\adjustright\rin0\lin0\itap0 {\cf1 6.3.4.2 \'a7o gi\'b8 tr\'de h\'b5m l\'ad\'eeng c\'f1a kh\'dd chu\'c8n \'ae\'b7 ch\'e4n t\'b9i gi\'b8 tr\'de danh \'ae\'denh c\'f1a \'aei\'d6n \'b8p ngu\'e5n nu\'abi. Ghi k\'d5t qu\'b6 
\'aeo \'ae\'ad\'eec v\'b5o bi\'aan b\'b6n \'eb ph\'f4 l\'f4c 1.
\par }{
\par 6.3.4.3 T\'a8ng gi\'b8 tr\'de \'aei\'d6n \'b8p ngu\'e5n nu\'abi cho m\'b8y t\'edi \'aei\'d6n \'b8p l\'edn nh\'cat cho ph\'d0p ghi trong h\'ad\'edng d\'c9n s\'f6 d\'f4ng m\'b8y. \'a7o gi\'b8 tr\'de h\'b5m l\'ad\'eeng c\'f1a kh\'dd chu\'c8n \'ae\'b7 ch\'e4
n. Ghi k\'d5t qu\'b6 \'aeo \'ae\'ad\'eec v\'b5o bi\'aan b\'b6n \'eb ph\'f4 l\'f4c 1.
\par 
\par 6.3.4.4 Gi\'b6m gi\'b8 tr\'de \'aei\'d6n \'b8p ngu\'e5n nu\'abi cho m\'b8y t\'edi \'aei\'d6n \'b8p nh\'e1 nh\'cat cho ph\'d0p ghi trong h\'ad\'edng d\'c9n s\'f6 d\'f4ng m\'b8y \'aeo. \'a7o gi\'b8 tr\'de h\'b5m l\'ad\'eeng c\'f1a kh\'dd chu\'c8n \'ae\'b7
 ch\'e4n. Ghi k\'d5t qu\'b6 \'aeo \'ae\'ad\'eec v\'b5o bi\'aan b\'b6n \'eb ph\'f4 l\'f4c 1.
\par 
\par 6.3.4.5 Ch\'aanh l\'d6ch gi\'f7a k\'d5t qu\'b6 \'aeo theo m\'f4c 6.3.4.2 v\'edi m\'f4c 6.3.4.3  v\'b5 m\'f4c 6.3.4.4 kh\'abng \'ae\'ad\'eec l\'edn h\'acn sai s\'e8 cho ph\'d0p \'ae\'e8i v\'edi t\'f5ng lo\'b9i m\'b8y.
\par }\pard \ql \li0\ri0\widctlpar\faauto\adjustright\rin0\lin0\itap0 {
\par }{\b 
\par 
\par }{\b\f30\fs28 \'aelvn 45 : 2001}{\b\fs28 
\par }{\b 
\par 
\par }{6.3.5 Ki\'d3m tra sai s\'e8 
\par 
\par }\pard \qj \li0\ri0\widctlpar\faauto\adjustright\rin0\lin0\itap0 {Ph\'ad\'acng ph\'b8p ki\'d3m tra sai s\'e8 c\'f1a m\'b8y l\'b5 so s\'b8nh k\'d5t qu\'b6 \'aeo tr\'f9c ti\'d5p h\'b5m l\'ad\'eeng c\'f1a h\'e7n h\'eep kh\'dd chu\'c8n b\'bbng m\'b8y c\'c7
n ki\'d3m \'ae\'denh v\'edi gi\'b8 tr\'de h\'b5m l\'ad\'eeng c\'f1a h\'e7n h\'eep kh\'dd chu\'c8n \'ae\'e3 t\'b9i nhi\'d6t \'ae\'e9 25 }{\super o}{C v\'b5 \'b8p  su\'cat kh\'dd quy\'d3n 101,3 }{\cf1 kPa.
\par }{
\par 6.3.5.1 \'a7\'e8i v\'edi m\'b8y \'aeo h\'b5m l\'ad\'eeng kh\'dd c\'e3 m\'e9t ho\'c6c nhi\'d2u ph\'b9m vi \'aeo kh\'b8c nhau, ph\'b6i ti\'d5n h\'b5nh ki\'d3m tra sai s\'e8  t\'cat c\'b6 c\'b8c ph\'b9m vi \'aeo. 
\par 
\par 6.3.5..2 Ch\'e4n kh\'dd chu\'c8n theo m\'f4c 6.3.2.1 v\'b5 6.3.2.2. 
\par 
\par 
\par 6.3.5.3 Ti\'d5n h\'b5nh \'aeo theo tr\'d7nh t\'f9 sau:
\par 
\par - \'a7o kh\'dd \'93kh\'abng\'94 \'ae\'b7 ch\'e4n. Ghi k\'d5t qu\'b6 \'aeo \'ae\'ad\'eec v\'b5o bi\'aan b\'b6n \'eb ph\'f4 l\'f4c 1.
\par 
\par - \'a7o gi\'b8 tr\'de h\'b5m l\'ad\'eeng c\'f1a kh\'dd chu\'c8n \'ae\'b7 ch\'e4n theo m\'f4c 4.1. Ghi k\'d5t qu\'b6 \'aeo \'ae\'ad\'eec v\'b5o bi\'aan b\'b6n \'eb ph\'f4 l\'f4c 1.
\par 
\par 6.3.5.4 Th\'f9c hi\'d6n \'aeo l\'b9i l\'c7n th\'f8 hai gi\'b8 tr\'de h\'b5m l\'ad\'eeng c\'f1a kh\'dd chu\'c8n \'ae\'b7 ch\'e4n. Ghi k\'d5t qu\'b6 \'aeo \'ae\'ad\'eec v\'b5o bi\'aan b\'b6n \'eb ph\'f4 l\'f4c 1.
\par 
\par 6.3.5.5 T\'ddnh sai s\'e8  
