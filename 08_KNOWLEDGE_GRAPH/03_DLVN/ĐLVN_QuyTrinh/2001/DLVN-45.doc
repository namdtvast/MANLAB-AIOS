\par }\pard\plain \s3\qr \li0\ri0\keepn\widctlpar\faauto\outlinelevel2\adjustright\rin0\lin0\itap0 \i\f32\fs26\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\fs28 Ph\'f4 l\'f4c 3}{\f29\fs28 
\par }\pard\plain \qc \li0\ri0\widctlpar\faauto\adjustright\rin0\lin0\itap0 \f27\fs26\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\b\f29 
\par 
\par t\'b9o kh\'dd chu\'c8n
\par c\'b8c th\'b5nh ph\'c7n c\'f1a kh\'dd chu\'c8n
\par }\pard \ql \li0\ri0\widctlpar\faauto\adjustright\rin0\lin0\itap0 {\f29 
\par }{\b 1 Y\'aau c\'c7u chung. 
\par }{
\par }\pard \qj \li0\ri0\widctlpar\faauto\adjustright\rin0\lin0\itap0 {1.1 Kh\'dd chu\'c8n ph\'b6i \'ae\'ad\'eec ch\'f8a trong b\'d7nh tr\'f4 ch\'deu \'b8p l\'f9c.
\par 
\par a) M\'e7i b\'d7nh kh\'dd ph\'b6i ghi r\'e2 c\'b8c th\'abng tin sau \'ae\'a9y (g\'e5m: m\'b8c, nh\'b7n ghi v\'b5  gi\'cay ch\'f8ng nh\'cbn):
\par - Nh\'b5 cung c\'cap b\'d7nh kh\'dd v\'b5 s\'e8 c\'f1a l\'ab ch\'d5 t\'b9o;
\par - Th\'b5nh ph\'c7n c\'f1a h\'eep ch\'cat kh\'dd chu\'c8n;
\par - Gi\'edi h\'b9n nhi\'d6t \'ae\'e9 s\'f6 d\'f4ng v\'b5 b\'b6o qu\'b6n;
\par - Ng\'b5y ph\'a9n t\'ddch v\'b5 ng\'b5y h\'d5t h\'b9n;
\par - C\'ac quan th\'f6 nghi\'d6m;
\par - Nh\'b7n "H\'e7n h\'eep ch\'cat kh\'dd chu\'c8n ".
\par 
\par b) H\'e7n h\'eep kh\'dd ph\'b6i ph\'ef h\'eep v\'edi ISO 6145 v\'b5 7395 (*) v\'b5 v\'edi c\'b8c y\'aau c\'c7u c\'f1a m\'f4c 1.2 v\'b5 m\'f4c 2 c\'f1a ph\'f4 l\'f4c n\'b5y.
\par 
\par 1.2 Kh\'dd chu\'c8n d\'efng \'ae\'d3 ch\'f8ng nh\'cbn m\'c9u chu\'c8n v\'b5 ki\'d3m \'ae\'denh ph\'b6i \'ae\'ad\'eec c\'ac quan c\'e3 th\'c8m quy\'d2n ch\'f8ng nh\'cbn ph\'ef h\'eep v\'edi c\'b8c y\'aau c\'c7u c\'f1a m\'f4c 2 theo m\'c9u chu\'c8n qu\'e8
c gia ho\'c6c qu\'e8c t\'d5.
\par 
\par Kh\'dd chu\'c8n s\'f6 d\'f4ng \'ae\'d3 ki\'d3m \'ae\'denh ph\'b6i \'ae\'ad\'eec nh\'b5 cung c\'cap kh\'dd c\'efng gi\'cay ch\'f8ng nh\'cbn.
\par 
\par 1.4 V\'cbt li\'d6u l\'b5m b\'d7nh ch\'f8a h\'e7n h\'eep kh\'dd chu\'c8n ph\'b6i tr\'ac v\'edi c\'b8c th\'b5nh ph\'c7n kh\'dd \'ae\'ad\'eec ch\'f8a trong b\'d7nh.
\par 
\par 1.5 C\'b8c quy t\'bec an to\'b5n th\'ddch h\'eep ph\'b6i tu\'a9n th\'f1 trong qu\'b8 tr\'d7nh x\'f6 l\'fd kh\'dd chu\'c8n.
\par 
\par }{\b 2  H\'b5m l\'ad\'eeng v\'b5 \'ae\'e9 ch\'ddnh x\'b8c c\'f1a c\'b8c th\'b5nh ph\'c7n kh\'dd chu\'c8n. 
\par }{
\par 2.1  \'a7\'acn v\'de th\'d3 hi\'d6n h\'b5m l\'ad\'eeng th\'b5nh ph\'c7n kh\'dd chu\'c8n \'ae\'ad\'eec t\'ddnh theo mol ho\'c6c th\'b5nh ph\'c7n th\'d3 t\'ddch. Nh\'f7ng th\'b5nh ph\'c7n th\'d3 t\'ddch c\'f1a c\'b8c th\'b5nh ph\'c7n kh\'dd ph\'b6i \'ae\'ad
\'eec bi\'d3u th\'de b\'bbng % th\'d3 t\'ddch \'ae\'e8i v\'edi CO v\'b5 CO}{\sub 2  }{... v\'b5 b\'bbng ppm th\'d3 t\'ddch \'ae\'e8i v\'edi HC.... Vi\'d6c ghi kh\'bec nh\'f7ng \'ae\'acn v\'de n\'b5y ph\'b6i r\'e2 r\'b5ng, th\'dd d\'f4 "%V CO", "%V CO}{
\sub 2}{", v\'b5 "ppmV HC".
\par 
\par }{\i\ul Ghi ch\'f3 1}{\i : ch\'f7 vi\'d5t t\'bet "ppm" ngh\'dca l\'b5 "ph\'c7n tri\'d6u".
\par 
\par }{\i\ul Ghi ch\'f3 2}{\i : c\'b8c h\'e7n h\'eep kh\'dd chu\'c8n c\'e3 th\'d3 \'ae\'ad\'eec ch\'d5 t\'b9o v\'edi th\'b5nh ph\'c7n mol cho c\'b8c kh\'dd chu\'c8n ch\'ddnh x\'b8c h\'acn. }{\i\f29 \'eb}{\i  \'ae\'a9y h\'e7n h\'eep kh\'dd chu\'c8n \'ae\'ad\'ee
c coi nh\'ad tu\'a9n theo \'ae\'denh lu\'cbt kh\'dd l\'fd t\'ad\'ebng, th\'b5nh ph\'c7n t\'ddnh theo mol coi nh\'ad b\'bbng v\'edi th\'b5nh ph\'c7n t\'ddnh theo th\'d3 t\'ddch.
\par }{
\par 2.2 H\'b5m l\'ad\'eeng c\'f1a m\'e7i kh\'dd th\'b5nh ph\'c7n trong h\'e7n h\'eep kh\'dd chu\'c8n kh\'abng \'ae\'ad\'eec kho\'b6ng 15% th\'b5nh ph\'c7n th\'d3 t\'ddch.
\par 2.3 \'a7\'e9 ch\'ddnh x\'b8c h\'b5m l\'ad\'eeng th\'b5nh ph\'c7n c\'f1a h\'e7n h\'eep kh\'dd chu\'c8n ph\'b6i }{{\field{\*\fldinst SYMBOL 163 \\f "Symbol" \\s 13}{\fldrslt\f3\fs26}}}{ 1 % V \'ae\'e8i v\'edi m\'e7i h\'b5nh ph\'c7n, tr\'f5 tr\'ad\'eang h
\'eep \'ae\'e8i v\'edi th\'b5nh ph\'c7n HC khi d\'ad\'edi 1 000 ppmV, \'ae\'e9 ch\'ddnh x\'b8c ph\'b6i }{{\field{\*\fldinst SYMBOL 163 \\f "Symbol" \\s 13}{\fldrslt\f3\fs26}}}{ 2 %. Nh\'f7ng gi\'b8 tr\'de v\'d2 \'ae\'e9 ch\'ddnh x\'b8c n\'b5y c\'e3 li\'aa
n quan t\'edi nh\'f7ng kh\'dd chu\'c8n \'ae\'b7 \'ae\'ad\'eec n\'aau trong m\'f4c 1.2.
\par 
\par Th\'b5nh ph\'c7n th\'d3 t\'ddch c\'f1a m\'e7i kh\'dd h\'eep th\'b5nh \'aei k\'ccm nh\'adng kh\'abng l\'b5 \'ae\'e8i t\'f9\'acng \'aeo ph\'b6i \'ae\'b6m b\'b6o  }{{\field{\*\fldinst SYMBOL 163 \\f "Symbol" \\s 13}{\fldrslt\f3\fs26}}}{ 5 %.
\par 
\par }{\b 3  \'a7i\'d2u ch\'d5 kh\'dd chu\'c8n trong nh\'f7ng tr\'ad\'eang h\'eep \'ae\'c6c bi\'d6t.
\par }{
\par 3.1 H\'eep ch\'cat kh\'dd chu\'c8n d\'efng \'ae\'d3 hi\'d6u chu\'c8n, ki\'d3m \'ae\'denh c\'b8c m\'b8y \'aeo th\'b5nh ph\'c7n HC th\'ad\'eang s\'f6 d\'f4ng propan, v\'d7 v\'cby ph\'b6i \'ae\'ada h\'d6 s\'e8 t\'ad\'acng \'ae\'ad\'acng propan/hexan v\'b5o t
\'ddnh to\'b8n.
\par 
\par 3.2 Kh\'abng \'ae\'ad\'eec \'ae\'f9ng trong b\'d7nh kh\'dd n\'d0n \'b8p su\'cat cao c\'b8c th\'b5nh ph\'c7n th\'d3 t\'ddch c\'f1a O}{\sub 2}{, H}{\sub 2}{, NO \'ae\'ad\'eec ho\'b5 l\'c9n v\'edi nh\'f7ng kh\'dd kh\'b8c theo y\'aau c\'c7u c\'f1a qu\'b8 tr
\'d7nh \'aeo n\'aau trong ph\'f4 l\'f4c n\'b5y c\'e3 th\'b5nh ph\'c7n th\'d3 t\'ddch c\'f1a h\'aci n\'ad\'edc v\'d7 hi\'d6u \'f8ng kh\'abng \'e6n \'ae\'denh v\'b5 \'a8n m\'dfn. Nh\'f7ng h\'e7n h\'eep c\'f1a O}{\sub 2}{, ch\'d8 \'ae\'ad\'eec ho\'b5 l\'c9
n v\'edi N}{\sub 2}{.
\par 
\par 3.3 \'a7\'e8i v\'edi ph\'ad\'acng ti\'d6n \'aeo HC, kh\'abng kh\'dd \'ae\'ada v\'b5o qua b\'e9 l\'e4c b\'bbng than hay h\'d6 th\'e8ng l\'e4c t\'ad\'acng }{\cf1 \'ae\'ad\'acng \'ae\'d3 \'ae\'c6t \'aei\'d3m \'930\'94.
\par }{
\par 
\par (*) ISO 6145: "Ph\'a9n t\'ddch kh\'dd - \'a7i\'d2u ch\'d5 h\'e7n h\'eep kh\'dd hi\'d6u chu\'c8n - Ph\'ad\'acng ph\'b8p th\'d3 t\'ddch \'ae\'e9ng".
\par       ISO 7395: " Ph\'a9n t\'ddch kh\'dd - \'a7i\'d2u ch\'d5 h\'e7n h\'eep kh\'dd hi\'d6u chu\'c8n - Ph\'ad\'acng ph\'b8p kh\'e8i l\'ad\'eeng \'ae\'e9ng".
\par 
\par }\pard \ql \li0\ri0\widctlpar\faauto\adjustright\rin0\lin0\itap0 {
\par 
\par 
\par 
