\par }{\b 5.1 Ki\'d3m tra b\'aan ngo\'b5i
\par }{
\par }\pard \s15\qj\nowidctlpar\widctlpar\adjustright {Ki\'d3m tra b\'bbng m\'bet \'ae\'d3 x\'b8c \'ae\'denh s\'f9 ph\'ef h\'eep c\'f1a ph\'ad\'acng ti\'d6n \'aeo nhi\'d6t \'ae\'e9 kh\'abng kh\'dd \'ae\'e8i v\'edi c\'b8c y\'aau c\'c7u quy \'ae\'denh trong t
\'b5i li\'d6u k\'fc thu\'cbt, v\'d2 h\'d7nh d\'b8ng, k\'ddch th\'ad\'edc, ch\'d8 th\'de, ngu\'e5n nu\'abi, k\'fd nh\'b7n hi\'d6u, c\'ac c\'cau ni\'aam phong c\'f1a m\'b8y, t\'b5i li\'d6u v\'b5 ph\'f4 t\'efng k\'ccm theo.
\par 
\par }{\b 5.2 Ki\'d3m tra k\'fc thu\'cbt
\par 
\par }{Ki\'d3m tra tr\'b9ng th\'b8i ho\'b9t \'ae\'e9ng b\'d7nh th\'ad\'eang c\'f1a ph\'ad\'acng ti\'d6n \'aeo nhi\'d6t \'ae\'e9 kh\'abng kh\'dd theo h\'ad\'edng d\'c9n v\'cbn h\'b5nh.
