\par 5.3.4 Ki\'d3m tra sai s\'e8 
\par 
\par 5.3.4.1 \'a7\'e8i v\'edi m\'b8y \'aeo pH c\'e3 ph\'b9m vi \'aeo t\'f5 (0 }{{\field{\*\fldinst SYMBOL 184 \\f "Symbol" \\s 13}{\fldrslt\f3\fs26}}}{14) pH.
\par 
\par Ch\'e4n dung d\'dech \'ae\'d6m chu\'c8n theo m\'f4c 4.2.1.
\par 
\par 5.3.4.2 R\'f6a v\'b5 l\'b5m kh\'ab \'aei\'d6n c\'f9c theo m\'f4c 4.2.4.
\par 
