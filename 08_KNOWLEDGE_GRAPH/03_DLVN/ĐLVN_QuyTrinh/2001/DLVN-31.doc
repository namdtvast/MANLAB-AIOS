\par }{5.3.3 Ki\'d3m tra thay \'ae\'e6i \'aei\'d6n \'b8p ngu\'e5n nu\'abi
\par 
\par }\pard \s15\qj \li0\ri0\widctlpar\faauto\adjustright\rin0\lin0\itap0 {Ch\'d8 ki\'d3m tra \'b6nh h\'ad\'ebng do thay \'ae\'e6i \'aei\'d6n \'b8p ngu\'e5n nu\'abi \'ae\'e8i v\'edi m\'b8y \'aeo pH s\'f6 d\'f4ng \'aei\'d6n l\'ad\'edi.
\par }\pard \s15\ql \li0\ri0\widctlpar\faauto\adjustright\rin0\lin0\itap0 {
\par }\pard \s15\qj \li0\ri0\widctlpar\faauto\adjustright\rin0\lin0\itap0 {5.3.3.1 Ch\'e4n m\'e9t lo\'b9i dung d\'dech \'ae\'d6m chu\'c8n th\'ddch h\'eep.}{\cf6 
\par }{
\par 5.3.3.2 \'a7o gi\'b8 tr\'de pH c\'f1a dung d\'dech \'ae\'d6m chu\'c8n \'ae\'b7 ch\'e4n b\'bbng m\'b8y \'aeo pH c\'c7n ki\'d3m \'ae\'denh t\'b9i nhi\'d6t \'ae\'e9 20 }{\super o}{C  (ho\'c6c 25 }{\super o}{C) c\'efng gi\'b8 tr\'de danh \'ae\'denh c\'f1a 
\'aei\'d6n \'b8p ngu\'e5n nu\'abi. Ghi k\'d5t qu\'b6 \'aeo pH v\'b5o bi\'aan b\'b6n \'eb ph\'f4 l\'f4c 1.
\par 
\par 5.3.3.3 }{\expnd-1\expndtw-6 T\'a8ng \'aei\'d6n \'b8p ngu\'e5n nu\'abi cho m\'b8y \'aeo pH t\'edi \'aei\'d6n \'b8p cao nh\'cat cho ph\'d0p ghi trong h\'ad\'edng d\'c9n v\'cbn h\'b5nh c\'f1a m\'b8y. \'a7o gi\'b8 tr\'de pH c\'f1a dung d\'dech \'ae\'d6m chu
\'c8n \'ae\'b7 ch\'e4n t\'b9i \'aei\'d6n \'b8p ngu\'e5n nu\'abi \'ae\'e3 v\'edi nhi\'d6t \'ae\'e9 20 }{\expnd-1\expndtw-6\super o}{\expnd-1\expndtw-6 C (ho\'c6c 25 }{\expnd-1\expndtw-6\super o}{\expnd-1\expndtw-6 C). Ghi k\'d5t qu\'b6 \'aeo pH v\'b5o bi
\'aan b\'b6n \'eb ph\'f4 l\'f4c 1.
\par }\pard \s15\ql \li0\ri0\widctlpar\faauto\adjustright\rin0\lin0\itap0 {
\par }\pard \s15\qj \li0\ri0\widctlpar\faauto\adjustright\rin0\lin0\itap0 {
\par }\pard \s15\qr \li0\ri0\widctlpar\faauto\adjustright\rin0\lin0\itap0 {\b\f30\fs28 \'aelvn 31 :  2001
\par }\pard \s15\qj \li0\ri0\widctlpar\faauto\adjustright\rin0\lin0\itap0 {
\par 
\par 5.3.3.4 Gi\'b6m \'aei\'d6n \'b8p ngu\'e5n nu\'abi cho m\'b8y \'aeo pH t\'edi \'aei\'d6n \'b8p th\'cap nh\'cat cho ph\'d0p ghi trong h\'ad\'edng d\'c9n v\'cbn h\'b5nh c\'f1a m\'b8y. \'a7o gi\'b8 tr\'de pH c\'f1a dung d\'dech \'ae\'d6m chu\'c8n t\'b9i \'aei
\'d6n \'b8p ngu\'e5n nu\'abi \'ae\'e3 v\'edi  nhi\'d6t \'ae\'e9 20 }{\super o}{C (ho\'c6c 25 }{\super o}{C). Ghi k\'d5t qu\'b6 \'aeo pH v\'b5o bi\'aan b\'b6n \'eb ph\'f4 l\'f4c 1.
\par 
\par 5.3.3.5 Ch\'aanh l\'d6ch gi\'f7a k\'d5t qu\'b6 \'aeo theo m\'f4c 5.3.3.2 v\'edi m\'f4c 5.3.3.3 v\'b5 theo m\'f4c 5.3.3.2 v\'edi m\'f4c 5.3.3.4 kh\'abng \'ae\'ad\'eec l\'edn h\'acn sai s\'e8 cho ph\'d0p l\'b5 }{{\field{\*\fldinst SYMBOL 177 \\f "Symbol"
 \\s 13}{\fldrslt\f3\fs26}}}{ 0,02 pH \'ae\'e8i v\'edi m\'b8y \'aeo pH c\'e3 gi\'b8 tr\'de \'ae\'e9 chia 0,01 pH ho\'c6c kh\'abng \'ae\'ad\'eec l\'edn h\'acn sai s\'e8 cho ph\'d0p l\'b5 }{{\field{\*\fldinst SYMBOL 177 \\f "Symbol" \\s 13}{\fldrslt
\f3\fs26}}}{ 0,1 pH \'ae\'e8i v\'edi m\'b8y \'aeo pH c\'e3 gi\'b8 tr\'de \'ae\'e9 chia  0,1 pH.
