\par 4.2.2 Dung d\'dech \'ae\'d6m chu\'c8n ph\'b6i \'ae\'ad\'eec \'ae\'c6t trong ph\'dfng ki\'d3m \'ae\'denh 24 gi\'ea tr\'ad\'edc khi ti\'d5n h\'b5nh ki\'d3m \'ae\'denh. \'a7i\'d6n c\'f9c c\'f1a m\'b8y \'aeo pH c\'c7n ki\'d3m \'ae\'denh ph\'b6i \'ae\'ad\'ee
c ng\'a9m tr\'ad\'edc trong n\'ad\'edc c\'cat ho\'c6c trong dung d\'dech theo h\'ad\'edng d\'c9n s\'f6 d\'f4ng \'aei\'d6n c\'f9c 24 gi\'ea t\'b9i ph\'dfng ki\'d3m \'ae\'denh.
\par 
\par }{4.2.3 Tr\'ad\'edc m\'e7i l\'c7n \'aeo gi\'b8 tr\'de pH c\'f1a lo\'b9i dung d\'dech \'ae\'d6m chu\'c8n kh\'b8c c\'c7n ph\'b6i th\'f9c hi\'d6n c\'b8c thao t\'b8c sau:
\par 
\par - R\'f6a \'aei\'d6n c\'f9c c\'f1a m\'b8y \'aeo pH;
\par 
\par - L\'b5m kh\'ab \'aei\'d6n c\'f9c c\'f1a m\'b8y \'aeo pH  b\'bbng gi\'cay l\'e4c.
\par }\pard \s15\ql \li0\ri0\widctlpar\faauto\adjustright\rin0\lin0\itap0 {\fs28 
\par }{\b\fs28 5 Ti\'d5n h\'b5nh ki\'d3m \'ae\'denh
\par }{\fs28 
\par }{\b 5.1 Ki\'d3m tra b\'aan ngo\'b5i
\par }{
\par }\pard \s15\qj \li0\ri0\widctlpar\faauto\adjustright\rin0\lin0\itap0 {Ki\'d3m tra b\'bbng m\'bet \'ae\'d3 x\'b8c \'ae\'denh s\'f9 ph\'ef h\'eep c\'f1a m\'b8y \'aeo pH \'ae\'e8i v\'edi c\'b8c y\'aau c\'c7u quy \'ae\'denh trong t\'b5i li\'d6u k\'fc thu\'cb
t, v\'d2 h\'d7nh d\'b8ng, k\'ddch th\'ad\'edc, ch\'d8 th\'de, ngu\'e5n nu\'abi, k\'fd nh\'b7n hi\'d6u, c\'ac c\'cau ni\'aam phong c\'f1a m\'b8y, t\'b5i li\'d6u v\'b5 ph\'f4 t\'efng k\'ccm theo.
\par 
\par }{\b 5.2 Ki\'d3m tra k\'fc thu\'cbt
\par }{
\par Ki\'d3m tra  tr\'b9ng th\'b8i ho\'b9t \'ae\'e9ng b\'d7nh th\'ad\'eang c\'f1a m\'b8y \'aeo pH theo h\'ad\'edng d\'c9n v\'cbn h\'b5nh.
