\par 5.3.2.1 \'a7\'b6o dung d\'dech ki\'d3m \'ae\'denh th\'cbt k\'fc b\'bbng que khu\'cay thu\'fb tinh chuy\'d3n \'ae\'e9ng l\'aan xu\'e8ng       (5 }{\cf1 {\field{\*\fldinst SYMBOL 184 \\f "Symbol" \\s 13}{\fldrslt\f3\fs26}}}{\cf1 7) l\'c7n, tr\'b8nh kh\'ab
ng \'ae\'d3 cho kh\'abng kh\'dd l\'e4t v\'b5o ch\'cat l\'e1ng. Sau khi b\'e4t kh\'dd tan h\'d5t, l\'c7n l\'ad\'eet \'ae\'ada t\'fb tr\'e4ng k\'d5 c\'c7n ki\'d3m \'ae\'denh v\'b5 t\'fb tr\'e4ng k\'d5 chu\'c8n v\'b5o dung d\'dech, khi c\'b8ch \'aei\'d3m ki
\'d3m \'ae\'denh            (3 }{\cf1 {\field{\*\fldinst SYMBOL 184 \\f "Symbol" \\s 13}{\fldrslt\f3\fs26}}}{\cf1  4) mm th\'b6 nh\'d1 cho t\'fb tr\'e4ng k\'d5 chuy\'d3n \'ae\'e9ng t\'f9 do. 
\par 
\par 5.3.2.2 Khi chuy\'d3n \'ae\'e9ng trong dung d\'dech, tr\'f4c c\'f1a t\'fb tr\'e4ng k\'d5 ph\'b6i vu\'abng g\'e3c v\'edi b\'d2 m\'c6t tho\'b8ng ch\'cat l\'e1ng. \'a7\'e9 nghi\'aang \'ae\'ad\'eec ki\'d3m tra t\'b9i v\'b9ch chia \'eb ph\'c7n d\'ad\'ed
i thang \'aeo.
\par 
\par \'a7\'e9 nghi\'aang cho ph\'d0p khi hi\'d6u 2 l\'c7n \'ae\'e4c s\'e8 ch\'d8 \'eb t\'b9i m\'e9t \'aei\'d3m kh\'abng l\'edn h\'acn 0,1 gi\'b8 tr\'de \'ae\'e9 chia nh\'e1 nh\'cat c\'f1a thang \'aeo.
\par 
\par 5.3.2.3 M\'d0p ti\'d5p x\'f3c gi\'f7a ch\'cat l\'e1ng v\'b5 thanh \'aeo c\'f1a t\'fb tr\'e4ng k\'d5 ph\'b6i l\'b5 \'ae\'ad\'eang tr\'dfn n\'bbm trong m\'c6t ph\'bcng n\'bbm ngang. Tr\'ad\'eang h\'eep m\'d0p ti\'d5p x\'f3c n\'b5y kh\'abng tr\'dfn, ch\'f8
ng t\'e1 vi\'d6c chu\'c8n b\'de ki\'d3m \'ae\'denh th\'f9c hi\'d6n ch\'ada t\'e8t. C\'c7n ph\'b6i ti\'d5n h\'b5nh l\'b9i vi\'d6c chu\'c8n b\'de ki\'d3m \'ae\'denh \'eb m\'f4c 4.
\par 
\par 5.3.2.4 Khi ph\'ad\'acng ti\'d6n \'aeo}{\b\cf1  }{\cf1 v\'b5 chu\'c8n ng\'f5ng chuy\'d3n \'ae\'e9ng, \'ae\'f8ng y\'aan trong dung d\'dech, kh\'abng ch\'b9m nhau v\'b5 kh\'abng ch\'b9m v\'b5o th\'b5nh \'e8ng \'aeong m\'edi \'ae\'ad\'eec \'ae\'e4c gi\'b8 tr
\'de.
\par 
