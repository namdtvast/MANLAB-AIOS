\par 3.1}{ Ph\'ad\'acng ph\'b8p ki\'d3m \'ae\'denh ph\'ad\'acng ti\'d6n \'aeo \'ae\'e9 \'c8m kh\'abng kh\'dd l\'b5 so s\'b8nh k\'d5t qu\'b6 \'aeo tr\'f9c ti\'d5p  b\'bbng ph\'ad\'acng ti\'d6n \'aeo c\'c7n ki\'d3m \'ae\'denh v\'edi gi\'b8 tr\'de chu\'c8n c\'f1
a ngu\'e5n t\'b9i 20}{\super o}{C.
\par }{\b 
\par 3.2}{ Ph\'ad\'acng ti\'d6n ki\'d3m \'ae\'denh 
\par }{\fs28 
\par }{3.2.1}{\b  }{ Ngu\'e5n chu\'c8n \'ae\'e9 \'c8m kh\'abng kh\'dd t\'f5  10 %RH \'ae\'d5n  95 %RH c\'e3 \'ae\'e9 ch\'ddnh x\'b8c g\'cap 2 l\'c7n \'ae\'e9 ch\'ddnh x\'b8c c\'f1a ph\'ad\'acng ti\'d6n \'aeo c\'c7n ki\'d3m \'ae\'denh.
\par }\pard \s15\ql \li0\ri0\widctlpar\faauto\adjustright\rin0\lin0\itap0 {\b\f39\fs28 
\par \'aelvn 87 : 2001
\par 
