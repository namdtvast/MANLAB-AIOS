\par }\pard \s15\ql \li0\ri0\widctlpar\faauto\adjustright\rin0\lin0\itap0 {
\par 3.2.4}{\b  }{Thi\'d5t b\'de \'ae\'e3ng ng\'bet ngu\'e5n cho ph\'ad\'acng ti\'d6n \'aeo c\'c7n ki\'d3m \'ae\'denh.
\par 
\par 3.2.5 Ph\'ad\'acng ti\'d6n \'aeo nhi\'d6t \'ae\'e9 v\'b5 \'ae\'e9 \'c8m m\'abi tr\'ad\'eang. 
