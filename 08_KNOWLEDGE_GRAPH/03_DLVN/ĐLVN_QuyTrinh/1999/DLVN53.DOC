\par \pard \qj\nowidctlpar 
\par \pard \qj\nowidctlpar 5.3.1.1  Nh\'f7ng y\'aau c\'c7u chung khi x\'b8c \'ae\'denh di\'d6n t\'ddch hi\'d6u d\'f4ng:
\par 
\par \pard \qj\nowidctlpar a - Tr\'ad\'edc khi c\'a9n b\'bbng ph\'b6i \'ae\'e6 ch\'cat l\'e1ng quy \'ae\'denh \'eb m\'f4c 4.1 v\'b5o pitt\'abng v\'b5 xy lanh v\'b5 ph\'b6i h\'f3t h\'d5t kh\'abng kh\'dd ra kh\'e1i h\'d6 th\'e8ng.
\par \pard \qj\nowidctlpar 
\par \pard \qj\nowidctlpar b - Khi c\'a9n b\'bbng ph\'b6i d\'efng c\'b8c qu\'b6 c\'a9n c\'f1a \'b8p k\'d5 pitt\'abng chu\'c8n, ho\'c6c c\'b8c qu\'b6 c\'a9n c\'e3 kh\'e8i l\'ad\'eeng \'ae\'b7 bi\'d5t v\'edi sai s\'e8 t\'ad\'acng \'ae\'e8i kh\'abng v\'ad\'eet qu
\'b8  1,5.10{\super -5}. 
\par \pard \qj\nowidctlpar 
\par \pard \qj\nowidctlpar c - Khi c\'a9n b\'bbng ph\'b6i quay 2 pitt\'abng v\'edi t\'e8c \'ae\'e9 kh\'abng nh\'e1 h\'acn 30 v\'dfng/ph\'f3t. 
\par \pard \qj\nowidctlpar 
\par \pard \qj\nowidctlpar d - Tr\'b9ng th\'b8i c\'a9n b\'bbng c\'f1a 2 pitt\'abng \'ae\'b9t \'ae\'ad\'eec khi \'ae\'c6t qu\'b6 c\'a9n c\'e3 kh\'e8i l\'ad\'eeng 0,1g l\'aan pitt\'abng c\'c7n ki\'d3m \'ae\'denh th\'d7 hai pitt\'abng thay \'ae\'e6i v\'de tr\'dd
 v\'b5 khi l\'cay \'aei th\'d7 ch\'f3ng tr\'eb l\'b9i v\'de tr\'dd ban \'ae\'c7u.
\par \pard \qr\nowidctlpar {\b\f25\fs28 
\par }\pard \qr\nowidctlpar {\b\f25\fs28 \'aelvn 53 : 1999
\par }\pard \qj\nowidctlpar 
