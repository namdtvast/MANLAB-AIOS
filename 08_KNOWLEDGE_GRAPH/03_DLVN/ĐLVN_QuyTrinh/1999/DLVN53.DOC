\par 1 Ph\'b9m vi \'b8p d\'f4ng
\par }\pard \qj\nowidctlpar 
\par \pard \qj\nowidctlpar Quy tr\'d7nh n\'b5y quy \'ae\'denh ph\'ad\'acng ph\'b8p v\'b5 ph\'ad\'acng ti\'d6n ki\'d3m \'ae\'denh ban \'ae\'c7u v\'b5 ki\'d3m \'ae\'denh \'ae\'denh k\'fa huy\'d5t \'b8p k\'d5 pitt\'abng c\'e3 ph\'b9m vi \'aeo t\'f5 (6,7{
{\field{\*\fldinst SYMBOL 184 \\f "Symbol" \\s 13}{\fldrslt\f1\fs26}}} 40) kPa t\'ad\'acng \'ae\'ad\'acng (50{{\field{\*\fldinst SYMBOL 184 \\f "Symbol" \\s 13}{\fldrslt\f1\fs26}}} 300) mmHg, c\'cap ch\'ddnh x\'b8c 0,2.
\par \pard \qj\nowidctlpar 
\par \pard \qj\nowidctlpar {\b 2 C\'b8c ph\'d0p ki\'d3m \'ae\'denh
\par }\pard \qj\nowidctlpar 
\par Ph\'b6i l\'c7n l\'ad\'eet ti\'d5n h\'b5nh c\'b8c ph\'d0p ki\'d3m \'ae\'denh ghi trong b\'b6ng 1.
\par 
\par \pard \qr\nowidctlpar {\b\i B\'b6ng 1
\par }\pard \qj\nowidctlpar 
\par \trowd \trgaph108\trleft-108\trbrdrt\brdrs\brdrw15 \trbrdrl\brdrs\brdrw15 \trbrdrb\brdrs\brdrw15 \trbrdrr\brdrs\brdrw15 \trbrdrh\brdrs\brdrw15 \trbrdrv\brdrs\brdrw15 \clbrdrt\brdrs\brdrw15 \clbrdrl\brdrs\brdrw15 \clbrdrb\brdrs\brdrw15 \clbrdrr
