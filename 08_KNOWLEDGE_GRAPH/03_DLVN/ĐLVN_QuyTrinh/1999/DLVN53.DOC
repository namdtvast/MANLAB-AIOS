\b Theo \'aei\'d2u n\'b5o c\'f1a QTK\'a7\cell }\pard \intbl {\b \row }\trowd \trgaph108\trleft-108\trbrdrt\brdrs\brdrw15 \trbrdrl\brdrs\brdrw15 \trbrdrb\brdrs\brdrw15 \trbrdrr\brdrs\brdrw15 \trbrdrh\brdrs\brdrw15 \trbrdrv\brdrs\brdrw15 \clbrdrt
\brdrs\brdrw15 \clbrdrl\brdrs\brdrw15 \clbrdrb\brdrs\brdrw15 \clbrdrr\brdrs\brdrw15 \cellx4847\clbrdrt\brdrs\brdrw15 \clbrdrl\brdrs\brdrw15 \clbrdrb\brdrs\brdrw15 \clbrdrr\brdrs\brdrw15 \cellx9639 \pard \qj\sb120\sa120\nowidctlpar\intbl 1. Ki\'d3m tra b
\'aan ngo\'b5i\cell \pard \qc\sb120\sa120\nowidctlpar\intbl 5.1\cell \pard \intbl \row \pard \qj\sb120\sa120\nowidctlpar\intbl 2. Ki\'d3m tra k\'fc thu\'cbt\cell \pard \qc\sb120\sa120\nowidctlpar\intbl 5.2\cell \pard \intbl \row \trowd 
\trgaph108\trleft-108\trbrdrt\brdrs\brdrw15 \trbrdrl\brdrs\brdrw15 \trbrdrb\brdrs\brdrw15 \trbrdrr\brdrs\brdrw15 \trbrdrh\brdrs\brdrw15 \trbrdrv\brdrs\brdrw15 \clbrdrt\brdrs\brdrw15 \clbrdrl\brdrs\brdrw15 \clbrdrb\brdrs\brdrw15 \clbrdrr\brdrs\brdrw15 
\cellx4847\clbrdrt\brdrs\brdrw15 \clbrdrl\brdrs\brdrw15 \clbrdrb\brdrs\brdrw15 \clbrdrr\brdrs\brdrw15 \cellx9639 \pard \qj\sb120\sa120\nowidctlpar\intbl 3. Ki\'d3m tra \'aeo l\'ad\'eang \cell \pard \qc\sb120\sa120\nowidctlpar\intbl 5.3\cell \pard \intbl 
\row \pard \qj\nowidctlpar 
\par \pard \qj\nowidctlpar 
\par \pard \qj\fi-360\li360\nowidctlpar\tx360 {\b 3 Ph\'ad\'acng ti\'d6n ki\'d3m \'ae\'denh
\par }\pard \qj\nowidctlpar {\b 
\par }\pard \qj\nowidctlpar 3.1 Chu\'c8n
\par \pard \qj\nowidctlpar\tx1110 {\f16 
\par }\pard \qj\nowidctlpar\tx1110 {\f16 - \'b8}p k\'d5 pitt\'abng chu\'c8n c\'e3 gi\'edi h\'b9n \'aeo tr\'aan \'ae\'d5n 6 bar, c\'cap ch\'ddnh x\'b8c 0,02 ho\'c6c \'b8p k\'d5 pitt\'abng chu\'c8n c\'e3 \'ae\'e9 kh\'abng \'ae\'b6m b\'b6o t\'ad\'acng \'ae\'ad
\'acng;
\par \pard \qj\nowidctlpar\tx1110 
\par - 01 c\'a9n chu\'c8n c\'cap 3 (1kg);
\par 
\par \pard \qj\nowidctlpar\tx1110 - 02 b\'e9 qu\'b6 c\'a9n chuy\'aan d\'efng, c\'cap ch\'ddnh x\'b8c F{\sub 2}, ph\'b9m vi \'aeo (500 {{\field{\*\fldinst SYMBOL 184 \\f "Symbol" \\s 13}{\fldrslt\f1\fs26}}} 1000) g;
\par \pard \qj\nowidctlpar\tx1110 
\par \pard \qj\nowidctlpar\tx1110 - 02 b\'e9 qu\'b6 c\'a9n (0,05 {{\field{\*\fldinst SYMBOL 184 \\f "Symbol" \\s 13}{\fldrslt\f1\fs26}}} 500)g, c\'cap ch\'ddnh x\'b8c F{\sub 2}.
\par \pard \qj\nowidctlpar 
\par \pard \qj\nowidctlpar 
\par 
\par 
\par \pard \qj\nowidctlpar {\b\f25\fs28 \'aelvn 53 : 1999
\par }\pard \qj\nowidctlpar 
\par 3.2 Thi\'d5t b\'de ph\'f4 v\'b5 ph\'ad\'acng ti\'d6n \'aeo ph\'f4
\par \pard \qj\nowidctlpar\tx1110 
\par \pard \qj\nowidctlpar\tx1110 - Ni-v\'ab khung c\'e3 gi\'b8 tr\'de \'ae\'e9 chia kh\'abng l\'edn h\'acn 1,5 mm/m (~ 5{\super '}) ho\'c6c \'ae\'e5ng h\'e5 so c\'e3 gi\'b8 tr\'de \'ae\'e9 chia kh\'abng l\'edn h\'acn 0,1mm;
\par \pard \qj\nowidctlpar\tx1110 
\par - Thi\'d5t b\'de \'ae\'e4c quang h\'e4c c\'e3 t\'fb s\'e8 ph\'e3ng \'ae\'b9i 24 l\'c7n, c\'e3 gi\'b8 tr\'de v\'b9ch chia 0,05 mm;
\par 
\par - \'a7\'e5ng h\'e5 b\'cam gi\'a9y c\'e3 gi\'b8 tr\'de \'ae\'e9 chia kh\'abng l\'edn h\'acn 0,2 s;
\par 
\par \pard \qj\nowidctlpar\tx1110 - Nhi\'d6t k\'d5 c\'e3 ph\'b9m vi \'aeo ( 0 {{\field{\*\fldinst SYMBOL 184 \\f "Symbol" \\s 13}{\fldrslt\f1\fs26}}} 35) {\super 0}C v\'edi sai s\'e8 kh\'abng l\'edn h\'acn {{\field{\*\fldinst SYMBOL 177 \\f "Symbol"
 \\s 13}{\fldrslt\f1\fs26}}} 0,2 {\super 0}C;{\b 
\par }\pard \qj\nowidctlpar\tx1110 
\par - Huy\'d5t \'b8p k\'d5 l\'df xo c\'e3 gi\'edi h\'b9n \'aeo tr\'aan \'ae\'d5n 40 kPa (300 mmHg);{\b 
\par }\pard \qj\nowidctlpar\tx1110 {\f16 
\par }\pard \qj\nowidctlpar\tx1110 {\f16 - \'c8}m k\'d5 c\'e3 ph\'b9m vi \'aeo (0 {{\field{\*\fldinst SYMBOL 184 \\f "Symbol" \\s 13}{\fldrslt\f1\fs26}}} 100) %RH.{\b 
\par }\pard \qj\li750\nowidctlpar {\b 
\par }\pard \qj\fi-360\li360\nowidctlpar\tx360 {\b 4 \'a7i\'d2u ki\'d6n ki\'d3m \'ae\'denh v\'b5 chu\'c8n b\'de ki\'d3m \'ae\'denh}
\par \pard \qj\nowidctlpar {\b 
\par }\pard \qj\nowidctlpar 4.1 \'a7i\'d2u ki\'d6n ki\'d3m \'ae\'denh
\par 
\par Khi ti\'d5n h\'b5nh ki\'d3m \'ae\'denh ph\'b6i \'ae\'b6m b\'b6o c\'b8c \'aei\'d2u ki\'d6n sau \'ae\'a9y:
\par \pard \qj\nowidctlpar\tx1110 
\par \pard \qj\nowidctlpar\tx1110 - Nhi\'d6t \'ae\'e9 c\'f1a m\'abi tr\'ad\'eang l\'b5 (23 {{\field{\*\fldinst SYMBOL 177 \\f "Symbol" \\s 13}{\fldrslt\f1\fs26}}} 2) {\super 0}C;
\par \pard \qj\nowidctlpar\tx1110 
\par - \'a7\'e9 \'c8m t\'ad\'acng \'ae\'e8i kh\'abng v\'ad\'eet qu\'b8 70 % ;
\par 
\par \pard \qj\nowidctlpar\tx1110 - Ph\'dfng ki\'d3m \'ae\'denh kh\'abng \'ae\'ad\'eec rung, c\'e3 b\'f4i, c\'b8c ch\'cat \'a8n m\'dfn v\'b5 kh\'abng b\'de \'ae\'e8t n\'e3ng t\'f5 m\'e9t ph\'dda;
\par \pard \qj\nowidctlpar\tx1110 
\par - Ph\'ad\'acng ti\'d6n truy\'d2n \'b8p su\'cat l\'b5 ch\'cat l\'e1ng h\'e7n h\'eep t\'f5 50% d\'c7u ho\'b6 v\'b5 50% d\'c7u bi\'d5n th\'d5.
\par \pard \qj\nowidctlpar        
\par \pard \qj\nowidctlpar 4.2 Chu\'c8n b\'de ki\'d3m \'ae\'denh
\par \pard \qj\nowidctlpar\tx1110 {\f16 
\par }\pard \qj\nowidctlpar\tx1110 {\f16 - }Huy\'d5t \'b8p k\'d5 c\'c7n ki\'d3m \'ae\'denh c\'f2ng nh\'ad b\'e9 qu\'b6 c\'a9n chu\'c8n k\'ccm theo ph\'b6i \'ae\'d3 trong ph\'dfng ki\'d3m \'ae\'denh \'ddt nh\'cat l\'b5 10 gi\'ea;
\par \pard \qj\nowidctlpar\tx1110 
\par - Ph\'b6i l\'b5m s\'b9ch d\'c7u v\'b5 b\'f4i \'eb \'b8p k\'d5 c\'c7n ki\'d3m \'ae\'denh;
\par 
\par - D\'efng v\'b6i m\'d2m v\'b5 kh\'ab c\'c8n th\'cbn lau s\'b9ch \'ae\'dca c\'a9n g\'e8c, pitt\'abng v\'b5 c\'b8c qu\'b6 c\'a9n.
\par \pard \qj\nowidctlpar 
\par \pard \qj\fi-360\li360\nowidctlpar\tx360 {\b 5 Ti\'d5n h\'b5nh ki\'d3m \'ae\'denh
\par }\pard \qj\nowidctlpar {\b 
\par }\pard \qj\nowidctlpar 5.1 Ki\'d3m tra b\'aan ngo\'b5i
\par 
\par \pard \qj\nowidctlpar - Huy\'d5t \'b8p k\'d5 pitt\'abng ph\'b6i \'ae\'f1 c\'b8c chi ti\'d5t v\'b5 ph\'f4 t\'efng nh\'ad pitt\'abng \'aeo v\'b5 xy lanh \'aeo, b\'e9  qu\'b6 c\'a9n v\'b5 b\'e9 ph\'cbn t\'b9o \'b8p su\'cat;
\par \pard \qr\nowidctlpar {\b\f25\fs28 
\par }\pard \qr\nowidctlpar {\b\f25\fs28 \'aelvn 53 : 1999
\par }\pard \qj\nowidctlpar 
\par \pard \qj\nowidctlpar - Ph\'b6i c\'e3 \'ae\'c7y \'ae\'f1 k\'fd m\'b7 hi\'d6u, s\'e8 se-ri, ph\'b9m vi \'aeo, h\'b7ng s\'b6n xu\'cat;
\par 
\par - T\'e6ng kh\'e8i l\'ad\'eeng c\'f1a c\'b8c qu\'b6 c\'a9n ph\'b6i ph\'ef h\'eep v\'edi gi\'edi h\'b9n \'aeo tr\'aan c\'f1a huy\'d5t \'b8p  k\'d5;
\par 
\par \pard \qj\nowidctlpar - C\'b8c qu\'b6 c\'a9n c\'e3 c\'efng kh\'e8i l\'ad\'eeng danh ngh\'dca ph\'b6i c\'e3 c\'efng h\'d7nh d\'b9ng, k\'ddch th\'ad\'edc; c\'b8c qu\'b6 c\'a9n kh\'abng b\'de r\'d8, x\'ad\'edc v\'b5 kh\'abng \'ae\'ad\'eec b\'b8m d\'dd
nh nhau;
\par \pard \qj\nowidctlpar 
\par \pard \qj\nowidctlpar - Pitt\'abng ph\'b6i quay t\'f9 do trong xy lanh v\'b5 ph\'b6i chuy\'d3n \'ae\'e9ng nh\'d1 nh\'b5ng theo chi\'d2u  tr\'f4c c\'f1a n\'e3;
\par \pard \qj\nowidctlpar 
\par \pard \qj\nowidctlpar - L\'bep gh\'d0p gi\'f7a \'ae\'dca c\'a9n g\'e8c v\'b5 pitt\'abng ph\'b6i ch\'c6t \'ae\'d3 kh\'abng c\'e3 chuy\'d3n \'ae\'e9ng t\'ad\'acng \'ae\'e8i gi\'f7a ch\'f3ng.
\par \pard \qj\nowidctlpar {\b 
\par }\pard \qj\nowidctlpar 5.2 Ki\'d3m tra k\'fc thu\'cbt
\par \pard\plain \s17\qj\nowidctlpar \f15\fs26 
\par \pard \s17\qj\nowidctlpar 5.2.1 Ki\'d3m tra \'ae\'e9 k\'ddn c\'f1a thi\'d5t b\'de t\'b9o \'b8p su\'cat  
\par \pard \s17\qj\nowidctlpar {\b 
\par }\pard\plain \qj\nowidctlpar \f15\fs26 \'a7\'e3ng van th\'abng \'b8p k\'d5 v\'edi kh\'abng kh\'dd v\'b5 van th\'abng v\'edi c\'b8c \'ae\'c7u n\'e8i. \'a7\'c6t c\'b8c qu\'b6 c\'a9n c\'efng v\'edi \'ae\'dca c\'a9n g\'e8c c\'e3 t\'e6ng kh\'e8i l\'ad\'eeng t
\'b9o th\'b5nh 40 kPa (300 mmHg) l\'aan \'ae\'dca c\'a9n g\'e8c. L\'bep huy\'d5t \'b8p k\'d5 \'ae\'e5ng h\'e5 v\'b5o \'ae\'c7u n\'e8i. D\'efng thi\'d5t b\'de t\'b9o \'b8p su\'cat \'ae\'ada pitt\'abng l\'aan v\'de tr\'dd l\'b5m vi\'d6c, d\'ef
ng tay quay pitt\'abng cho \'ae\'d5n khi pitt\'abng \'ae\'b9t \'ae\'ad\'eec t\'e8c \'ae\'e9 v\'dfng quay kh\'abng nh\'e1 h\'acn 30 v\'dfng/ph\'f3t r\'e5i \'ae\'d3 cho h\'d6 th\'e8ng ch\'deu t\'b6i \'eb \'b8p su\'cat n\'b5y trong 5 ph\'f3t, n\'d5u th\'ca
y s\'e8 ch\'d8 tr\'aan huy\'d5t \'b8p k\'d5 \'ae\'e5ng h\'e5 th\'cap h\'acn 40 kPa th\'d7 l\'b9i n\'d0n cho t\'edi \'b8p su\'cat n\'b5y r\'e5i \'aeo \'ae\'e9 s\'f4t \'b8p trong 5 ph\'f3t ti\'d5p theo.
\par \pard \qj\nowidctlpar 
\par \'a7\'e9 s\'f4t \'b8p kh\'abng \'ae\'ad\'eec v\'ad\'eet qu\'b8 1% gi\'b8 tr\'de \'aeo cao nh\'cat (40 kPa) trong 1 ph\'f3t.
\par \pard\plain \s17\qj\nowidctlpar \f15\fs26 
\par \pard \s17\qj\nowidctlpar 5.2.2 Ki\'d3m tra \'ae\'e9 vu\'abng g\'e3c c\'f1a \'ae\'dca c\'a9n g\'e8c v\'edi tr\'f4c pitt\'abng{\b 
\par }\pard\plain \qj\nowidctlpar \f15\fs26                
\par \'a7\'dca c\'a9n g\'e8c ph\'b6i vu\'abng g\'e3c v\'edi tr\'f4c pitt\'abng, \'ae\'e9 l\'d6ch cho ph\'d0p nh\'e1 h\'acn ho\'c6c b\'bbng 1,5mm/m (~5\rquote ). D\'efng thi\'d5t b\'de t\'b9o \'b8p su\'cat \'ae\'ada pitt\'abng l\'aan v\'de tr\'dd l\'b5m vi\'d6
c, \'ae\'c6t ni-v\'ab d\'e4c theo \'ae\'ad\'eang k\'ddnh c\'f1a \'ae\'dca c\'a9n g\'e8c, xoay v\'ddt \'aei\'d2u ch\'d8nh \'ae\'d3 \'ae\'b9t \'ae\'ad\'eec v\'de tr\'dd n\'bbm ngang c\'f1a \'ae\'dca c\'a9n. Sau \'ae\'e3 quay \'ae\'dca c\'a9n  m\'e9t g\'e3
c 180{\super 0} v\'b5 \'ae\'e4c \'ae\'e9 l\'d6ch tr\'aan ni-v\'ab, \'ae\'e9 l\'d6ch n\'b5y ph\'b6i n\'bbm trong gi\'edi h\'b9n cho ph\'d0p.
\par \pard \qj\nowidctlpar 
\par \pard \qj\nowidctlpar L\'c6p l\'b9i ph\'d0p \'aeo m\'e9t l\'c7n n\'f7a, \'ae\'c6t ni-v\'ab d\'e4c theo \'ae\'ad\'eang k\'ddnh vu\'abng g\'e3c v\'edi \'ae\'ad\'eang k\'ddnh ban \'ae\'c7u, \'ae\'e9 l\'d6ch l\'c7n n\'b5y c\'f2ng ph\'b6i n\'bbm trong gi\'ed
i h\'b9n cho ph\'d0p. C\'e3 th\'d3 d\'efng \'ae\'e5ng h\'e5 so \'ae\'d3 ki\'d3m tra \'ae\'e9 vu\'abng g\'e3c c\'f1a \'ae\'dca c\'a9n g\'e8c v\'edi tr\'f4c pitt\'abng.
\par \pard \qj\nowidctlpar 
\par \pard\plain \s17\qj\nowidctlpar \f15\fs26 5.2.3 Ki\'d3m tra th\'eai gian quay t\'f9 do c\'f1a pitt\'abng
\par \pard \s17\qj\nowidctlpar 
\par \pard\plain \qj\nowidctlpar \f15\fs26  Th\'eai gian quay t\'f9 do c\'f1a pitt\'abng \'ae\'ad\'eec x\'b8c \'ae\'denh \'eb \'b8p su\'cat  33,5 kPa (250 mmHg).
\par \pard \qj\nowidctlpar 
\par \pard \qj\nowidctlpar \'a7\'ada pitt\'abng c\'efng v\'edi \'ae\'dca c\'a9n g\'e8c l\'aan v\'de tr\'dd l\'b5m vi\'d6c, d\'efng tay quay pitt\'abng cho \'ae\'d5n khi \'ae\'b9t \'ae\'ad\'eec t\'e8c \'ae\'e9 v\'dfng quay kh\'abng nh\'e1 h\'acn 30 v\'dfng/ph
\'f3t. Th\'eai gian quay t\'f9 do c\'f1a pitt\'abng trong xy lanh \'ae\'ad\'eec t\'ddnh t\'f5 th\'eai \'aei\'d3m n\'b5y cho \'ae\'d5n khi pitt\'abng d\'f5ng h\'bcn m\'b5 kh\'abng c\'e3 th\'aam ngo\'b9i l\'f9c t\'b8c d\'f4ng.
\par \pard \qj\nowidctlpar 
\par Th\'eai gian quay t\'f9 do kh\'abng \'ae\'ad\'eec nh\'e1 h\'acn 10s.
\par \pard \nowidctlpar {\b\f25\fs28 \'aelvn 53 : 1999
\par }\pard \qj\nowidctlpar 
\par \pard \qj\nowidctlpar 5.2.4 Ki\'d3m tra t\'e8c \'ae\'e9 h\'b9 c\'f1a pitt\'abng \'aeo
\par           
\par \pard \qj\nowidctlpar T\'e8c \'ae\'e9 h\'b9 c\'f1a pitt\'abng \'aeo \'ae\'ad\'eec x\'b8c \'ae\'denh \'eb \'b8p su\'cat 33,5 kPa (250 mmHg), khi pitt\'abng \'ae\'b9t \'ae\'ad\'eec t\'e8c \'ae\'e9 v\'dfng quay kh\'abng nh\'e1 h\'acn 30v\'dfng/ph\'f3t.{\b  }
T\'e8c \'ae\'e9 h\'b9 cho ph\'d0p ph\'f4 thu\'e9c v\'b5o nhi\'d6t \'ae\'e9 v\'b5 kh\'abng \'ae\'ad\'eec v\'ad\'eet qu\'b8 gi\'b8 tr\'de quy \'ae\'denh \'eb ph\'f4 l\'f4c 1.
\par \pard \qj\nowidctlpar {\b 
\par }\pard \qj\nowidctlpar 5.3  Ki\'d3m tra \'aeo l\'ad\'eang
\par \pard \qj\nowidctlpar {\f16 
\par }\pard \qj\nowidctlpar Huy\'d5t \'b8p k\'d5 pitt\'abng \'ae\'ad\'eec ki\'d3m tra \'aeo l\'ad\'eang theo tr\'d7nh t\'f9 sau \'ae\'a9y:
\par 
\par \pard \qj\nowidctlpar 5.3.1 Di\'d6n t\'ddch hi\'d6u d\'f4ng c\'f1a pitt\'abng \'ae\'ad\'eec x\'b8c \'ae\'denh b\'bbng ph\'ad\'acng ph\'b8p c\'a9n b\'bbng thu\'fb t\'dcnh pitt\'abng chu\'c8n v\'b5 pitt\'abng c\'c7n ki\'d3m \'ae\'denh. Hai pitt\'abng \'ae
\'ad\'eec c\'a9n b\'bbng s\'ac b\'e9 \'eb \'b8p su\'cat 1 bar. Kh\'e8i l\'ad\'eeng 2 pitt\'abng c\'efng v\'edi \'ae\'dca c\'a9n g\'e8c v\'b5 c\'b8c qu\'b6 c\'a9n tham gia v\'b5o vi\'d6c c\'a9n b\'bbng s\'cf kh\'abng t\'ddnh \'ae\'d5n khi t\'ddnh to\'b8
n di\'d6n t\'ddch hi\'d6u d\'f4ng c\'f1a pitt\'abng. R\'e5i ti\'d5n h\'b5nh c\'a9n b\'bbng 3 l\'c7n theo chi\'d2u t\'a8ng v\'b5 gi\'b6m \'b8p su\'cat v\'edi c\'b8c kh\'e8i l\'ad\'eeng 0,5kg; 1kg; 1,5kg. Ghi k\'d5t qu\'b6 v\'b5o bi\'aan b\'b6n ki\'d3m \'ae
\'denh (ph\'f4 l\'f4c 2).
\par \pard \qj\nowidctlpar 
\par Di\'d6n t\'ddch pitt\'abng hi\'d6u d\'f4ng \'eb m\'e7i l\'c7n c\'a9n b\'bbng \'ae\'ad\'eec t\'ddnh theo c\'abng th\'f8c:
\par 
\par \tab \tab \tab \tab      m{\sub i}
\par \pard \qj\nowidctlpar {\f4\fs20\lang1024 {\*\do\dobxcolumn\dobypara\dodhgt12288\dpline\dpptx0\dppty0\dpptx513\dppty0\dpx3085\dpy204\dpxsize514\dpysize1\dplinesolid\dplinecor0\dplinecog0\dplinecob0\dplinew20}}\tab \tab \tab A{\sub i} = A{\sub c} \tab 
