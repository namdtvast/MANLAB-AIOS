\par \'a7\'e9 \'c8m t\'ad\'acng \'ae\'e8i        :  }{\fs26 {\field{\*\fldinst SYMBOL 163 \\f "Symbol" \\s 13}{\fldrslt\f1\fs26}}}{\fs26  70 %
\par \'a7i\'d6n \'b8p ngu\'e5n            : 220 V  }{\fs26 {\field{\*\fldinst SYMBOL 177 \\f "Symbol" \\s 13}{\fldrslt\f1\fs26}}}{\fs26   10 % 
\par }{\b\fs26 
\par 4.2}{\fs26  Tr\'ad\'edc khi ti\'d5n h\'b5nh hi\'d6u chu\'c8n ph\'b6i th\'f9c hi\'d6n c\'b8c c\'abng vi\'d6c sau \'ae\'a9y:
\par 
\par }{\fs26\expnd1\expndtw6 \'a7\'e5ng h\'e5 b\'cam gi\'a9y \'aei\'d6n t\'f6 ph\'b6i l\'b5m vi\'d6c v\'b5 \'ae\'c6t trong m\'abi tr\'ad\'eang hi\'d6u chu\'c8n \'ddt nh\'cat l\'b5 1 gi\'ea. Ph\'ad\'acng ti\'d6n hi\'d6u chu\'c8n c\'f2ng ph\'b6i t\'f9 l\'b5m 
\ldblquote \'cam\rdblquote  m\'b8y theo quy \'ae\'denh k\'fc thu\'cbt.
\par }{\b\fs26 
\par }{\b 5 Ti\'d5n h\'b5nh hi\'d6u chu\'c8n
\par }{\fs26 
\par }{\b\fs26 5.1}{\fs26  Ki\'d3m tra b\'aan ngo\'b5i 
\par 
\par  Ph\'b6i ki\'d3m tra b\'aan ngo\'b5i theo c\'b8c y\'aau c\'c7u sau \'ae\'a9y:
\par - \'a7\'e5ng h\'e5 b\'cam gi\'a9y \'aei\'d6n t\'f6 ph\'b6i c\'e3 k\'fd, m\'b7 hi\'d6u \'ae\'d3 nh\'cbn d\'b9ng v\'b5 \'ae\'d3 ph\'a9n bi\'d6t.
\par - Kh\'abng c\'e3 nh\'f7ng h\'ad h\'e1ng b\'aan ngo\'b5i \'b6nh h\'ad\'ebng \'ae\'d5n t\'ddnh n\'a8ng c\'f1a \'ae\'e5ng h\'e5.
\par 
\par }{\b\fs26 5.2}{\fs26  Ki\'d3m tra k\'fc thu\'cbt 
\par 
\par }\pard \s15\qj\fi-142\li142\nowidctlpar {\fs26 - C\'b8c ch\'d5 \'ae\'e9 l\'b5m vi\'d6c \'ae\'f3ng theo quy \'ae\'denh c\'f1a nh\'b5 s\'b6n su\'cat cho t\'f5ng lo\'b9i \'ae\'e5ng h\'e5 c\'f4 th\'d3. Hi\'d3n th\'de s\'e8 r\'e2 r\'b5ng v\'edi t\'f5ng h\'b5
ng s\'e8.
\par }\pard \s15\qj\nowidctlpar {\fs26 - C\'b8c c\'ac c\'cau kh\'ebi \'ae\'e9ng v\'b5 d\'f5ng ph\'b6i tin c\'cby, b\'bbng c\'b8ch cho ch\'b9y th\'f6 \'ddt nh\'cat l\'b5 5 l\'c7n.
