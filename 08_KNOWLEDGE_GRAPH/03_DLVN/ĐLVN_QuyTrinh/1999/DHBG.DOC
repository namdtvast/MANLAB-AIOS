\par }{\b 1 Ph\'b9m vi \'b8p d\'f4ng}
\par \pard \s15\nowidctlpar {\fs26 
\par }\pard \s15\qj\sl264\slmult1\nowidctlpar {\fs26\expnd0\expndtw4 V\'a8n b\'b6n k\'fc thu\'cbt n\'b5y quy \'ae\'denh ph\'ad\'acng ph\'b8p v\'b5 ph\'ad\'acng ti\'d6n hi\'d6u chu\'c8n \'ae\'e5ng h\'e5 b\'cam gi\'a9y \'aei\'d6n t\'f6 l\'b5 nh\'f7ng lo\'b9i 
\'ae\'e5ng h\'e5 th\'b9ch anh dao \'ae\'e9ng \'eb t\'c7n s\'e8 c\'ac b\'b6n 32,768 kHz, c\'e3 c\'ac c\'cau kh\'ebi \'ae\'e9ng v\'b5 d\'f5ng b\'bbng tay \'ae\'d3 \'aeo kho\'b6ng th\'eai gian nh\'e1 nh\'cat l\'b5 0,01 s, c\'e3 \'ae\'e9 ch\'ddnh x\'b8c t\'ed
i 0,1 s/d. V\'a8n b\'b6n n\'b5y c\'f2ng \'b8p d\'f4ng cho nh\'f7ng lo\'b9i \'ae\'e5ng h\'e5 b\'cam gi\'a9y \'aei\'d6n t\'f6 kh\'b8c, c\'e3 t\'ddnh n\'a8ng t\'ad\'acng t\'f9.
\par }\pard \s15\qj\nowidctlpar {\fs26 
\par }{\b 2 C\'b8c ph\'d0p ki\'d3m tra v\'b5 hi\'d6u chu\'c8n
\par }{\b\fs26 
\par }{\fs26 Ph\'b6i l\'c7n l\'ad\'eet ti\'d5n h\'b5nh c\'b8c ph\'d0p ki\'d3m tra v\'b5 hi\'d6u chu\'c8n sau:
\par 
\par }{\b\fs26 2.1 }{\fs26 Ki\'d3m tra b\'aan ngo\'b5i (theo \'aei\'d2u 5.1).
\par }{\b\fs26 
\par 2.2 }{\fs26 Ki\'d3m tra k\'fc thu\'cbt (theo \'aei\'d2u 5.2).
\par }{\b\fs26 
\par 2.3 }{\fs26 Hi\'d6u chu\'c8n (theo \'aei\'d2u 5.3).
\par }{\b\fs26 
\par }{\b 3 Ph\'ad\'acng ti\'d6n hi\'d6u chu\'c8n
\par }{\fs26 
\par }{\b\fs26 3.1}{\fs26  Thi\'d5t b\'de hi\'d6u chu\'c8n \'ae\'e5ng h\'e5 b\'cam gi\'a9y \'aei\'d6n t\'f6 v\'edi \'ae\'c7u \'ae\'e4c c\'b6m \'f8ng ho\'c6c dung t\'ddnh.
\par 
\par Ph\'b9m vi \'aeo : \tab nh\'e1 nh\'cat: 0,01 s/d
\par }\pard \s15\qj\fi1418\nowidctlpar {\fs26 \tab l\'edn nh\'cat : 99,9 s/d
\par }\pard \s15\qj\nowidctlpar {\fs26 \'a7\'e9 \'e6n \'ae\'denh c\'f1a th\'b9ch anh : }{\fs26 {\field{\*\fldinst SYMBOL 177 \\f "Symbol" \\s 13}{\fldrslt\f1\fs26}}}{\fs26  0,03 s/d
\par 
\par }\pard \s15\nowidctlpar {\b\fs26 3.2}{\fs26  M\'b8y \'aeo t\'c7n s\'e8  
\par }\pard \s15\qj\nowidctlpar {\fs26 
\par - \'a7\'e9 \'e6n \'ae\'denh theo ng\'b5y c\'f1a th\'b9ch anh : }{\fs26 {\field{\*\fldinst SYMBOL 163 \\f "Symbol" \\s 13}{\fldrslt\f1\fs26}}}{\fs26   3.10}{\fs26\super -7}{\fs26 .
\par - Giao di\'d6n GPIB ho\'c6c RS.232S.
\par 
\par }{\b\fs26 3.3}{\fs26  M\'b8y t\'ddnh c\'b8 nh\'a9n 
\par 
\par T\'efy theo y\'aau c\'c7u hi\'d6u chu\'c8n, }{\fs26\expnd0\expndtw-4 c\'e3 th\'d3 s\'f6 d\'f4ng c\'b8c ph\'ad\'acng ti\'d6n hi\'d6u chu\'c8n c\'e3 t\'ddnh n\'a8ng t\'ad\'acng}{\fs26  t\'f9 nh\'ad thi\'d5t b\'de hi\'d6u chu\'c8n \'ae\'e5ng h\'e5 b\'cam gi
\'a9y NMC (6).
\par }\pard \s15\nowidctlpar {\b\f25 
