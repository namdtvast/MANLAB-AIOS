\par }\pard \s15\qj\nowidctlpar {\fs26 
\par }{\b\fs26 
\par }{\b 4 \'a7i\'d2u ki\'d6n hi\'d6u chu\'c8n v\'b5 chu\'c8n b\'de hi\'d6u chu\'c8n
\par }{\b\fs26 
\par }\pard \s15\nowidctlpar {\b\fs26 4.1}{\fs26  Khi ti\'d5n h\'b5nh hi\'d6u chu\'c8n ph\'b6i \'ae\'b6m b\'b6o c\'b8c \'aei\'d2u ki\'d6n sau \'ae\'a9y:
