\par \pard \qj\fi-360\li360\nowidctlpar\tx360 {\b 3 Ph\'ad\'acng ti\'d6n ki\'d3m \'ae\'denh
\par }\pard \qj\nowidctlpar {\b 
\par }3.1 Chu\'c8n 
\par \pard \qj\nowidctlpar 
\par \pard \qj\nowidctlpar 3.1.1 Chu\'c8n \'ae\'d3 ti\'d5n h\'b5nh ki\'d3m \'ae\'denh l\'b5 \'b8p k\'d5 pitt\'abng chu\'c8n ho\'c6c \'b8p k\'d5 l\'df xo chu\'c8n c\'e3 \'ae\'e9 kh\'abng \'ae\'b6m b\'b6o \'aeo nh\'e1 h\'acn ho\'c6c b\'bbng 1/4 sai s\'e8 cho ph
\'d0p c\'f1a ph\'ad\'acng ti\'d6n c\'c7n ki\'d3m \'ae\'denh.
\par \pard \qj\nowidctlpar 
\par \pard \qj\nowidctlpar 3.1.2 Gi\'edi h\'b9n \'aeo tr\'aan c\'f1a chu\'c8n kh\'abng \'ae\'ad\'eec nh\'e1 h\'acn gi\'edi h\'b9n \'aeo tr\'aan c\'f1a ph\'ad\'acng ti\'d6n c\'c7n ki\'d3m \'ae\'denh; gi\'edi h\'b9n \'aeo d\'ad\'edi c\'f1a chu\'c8n kh\'abng \'ae
\'ad\'eec l\'edn h\'acn 1/10 gi\'edi h\'b9n \'aeo tr\'aan c\'f1a ph\'ad\'acng ti\'d6n c\'c7n ki\'d3m \'ae\'denh.
\par \pard \qj\nowidctlpar 
\par \pard \qj\nowidctlpar 3.1.3 Cho ph\'d0p s\'f6 d\'f4ng c\'b8c ph\'ad\'acng ti\'d6n chu\'c8n kh\'b8c c\'e3 \'ae\'e9 kh\'abng \'ae\'b6m b\'b6o \'aeo v\'b5 ph\'b9m vi \'aeo ph\'ef h\'eep v\'edi c\'b8c y\'aau c\'c7u n\'aau \'eb m\'f4c 3.1.1 v\'b5 3.1.2 
\par \pard \qj\nowidctlpar {\b 
\par 
\par }\pard \qj\nowidctlpar {\b\f25\fs28 \'a7lvn 54 : 1999
\par }\pard \qj\nowidctlpar {\b 
\par 
\par }\pard \qj\nowidctlpar 3.2 Thi\'d5t b\'de ph\'f4 v\'b5 ph\'ad\'acng ti\'d6n \'aeo ph\'f4 
\par 
\par \pard \qj\nowidctlpar\tx360 Thi\'d5t b\'de t\'b9o \'b8p ph\'b6i t\'a8ng gi\'b6m \'b8p su\'cat m\'e9t c\'b8ch \'ae\'d2u \'ae\'c6n, gi\'f7 \'ae\'ad\'eec \'b8p su\'cat kh\'abng thay \'ae\'e6i khi \'ae\'e4c ch\'d8 s\'e8 v\'b5 gi\'f7 ph\'ad\'acng ti\'d6n c\'c7
n ki\'d3m  ch\'deu t\'b6i \'eb \'b8p su\'cat \'f8ng v\'edi gi\'edi h\'b9n \'aeo tr\'aan. \'a7\'e9 s\'f4t \'b8p su\'cat trong th\'eai gian 5 ph\'f3t ti\'d5p theo sau 10 ph\'f3t ch\'deu t\'b6i ban \'ae\'c7u kh\'abng l\'edn h\'acn 5 % gi\'edi h\'b9n \'aeo tr
\'aan.
\par \pard \qj\nowidctlpar\tx360 
\par Thi\'d5t b\'de t\'b9o ch\'a9n kh\'abng v\'b5 t\'b9o \'b8p su\'cat tuy\'d6t \'ae\'e8i kh\'abng l\'edn h\'acn 100 Pa.
\par 
\par \pard \qj\nowidctlpar\tx360 \'a7\'e8i v\'edi \'b8p k\'d5 chu\'c8n \'abxy cho ph\'d0p d\'efng bu\'e5ng ng\'a8n c\'b8ch kh\'dd - ch\'cat l\'e1ng, ch\'cat l\'e1ng - kh\'dd c\'e3 \'b8p su\'cat l\'b5m vi\'d6c \'ae\'d5n 0,6 MPa ho\'c6c bu\'e5ng ng\'a8n c\'b8
ch ch\'cat l\'e1ng - ch\'cat l\'e1ng c\'e3 \'b8p su\'cat l\'b5m vi\'d6c \'ae\'d5n 60 MPa.
\par \pard \qj\nowidctlpar\tx360 
\par \pard \qj\nowidctlpar\tx360 Nhi\'d6t k\'d5  c\'e3 ph\'b9m vi \'aeo (0 {{\field{\*\fldinst SYMBOL 184 \\f "Symbol" \\s 13}{\fldrslt\f1\fs26}}} 50) {\super 0}C, gi\'b8 tr\'de \'ae\'e9 chia kh\'abng l\'edn h\'acn 0,2 {\super 0}C.
\par \pard \qj\nowidctlpar\tx360 {\f16 
\par }\pard \qj\nowidctlpar\tx360 {\f16 \'c8}m k\'d5  c\'e3 ph\'b9m vi \'aeo (0 {{\field{\*\fldinst SYMBOL 184 \\f "Symbol" \\s 13}{\fldrslt\f1\fs26}}} 100) % RH.
\par \pard\plain \s16\qj\nowidctlpar \f15\fs26 
