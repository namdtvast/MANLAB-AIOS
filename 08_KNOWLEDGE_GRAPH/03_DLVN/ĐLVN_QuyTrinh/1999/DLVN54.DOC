\par 4.1.2 M\'abi tr\'ad\'eang ki\'d3m \'ae\'denh
\par \pard \qj\nowidctlpar\tx735 
\par \pard \qj\nowidctlpar\tx735 \'a7\'e8i v\'edi \'b8p k\'d5 c\'cap 0,16 \'ae\'d5n 0,25 ph\'b6i \'ae\'b6m b\'b6o nhi\'d6t \'ae\'e9 m\'abi tr\'ad\'eang: ( 23 {{\field{\*\fldinst SYMBOL 177 \\f "Symbol" \\s 13}{\fldrslt\f1\fs26}}} 2 ){\super 0}C v\'b5 \'ae\'e8
i v\'edi \'b8p k\'d5 c\'cap 0,4 \'ae\'d5n 0,6 ph\'b6i \'ae\'b6m b\'b6o nhi\'d6t \'ae\'e9 m\'abi tr\'ad\'eang: ( 23 {{\field{\*\fldinst SYMBOL 177 \\f "Symbol" \\s 13}{\fldrslt\f1\fs26}}} 3 ){\super 0}C.
\par \pard \qj\nowidctlpar\tx735 
\par a - \'a7\'e9 \'c8m t\'ad\'acng \'ae\'e8i kh\'abng v\'ad\'eet qu\'b8 70%.
\par 
\par \pard \qj\nowidctlpar\tx735 b - Ph\'dfng ki\'d3m \'ae\'denh ph\'b6i tho\'b8ng kh\'dd, kh\'abng c\'e3 b\'f4i v\'b5 kh\'abng b\'de \'ae\'e8t n\'e3ng t\'f5 m\'e9t ph\'dda; tr\'b8nh ch\'can \'ae\'e9ng v\'b5 va \'ae\'cbp, n\'d5u c\'e3 th\'d7 \'ae\'e9 rung c
\'f1a kim kh\'abng v\'ad\'eet qu\'b8 1/10 kho\'b6ng c\'b8ch gi\'f7a hai v\'b9ch chia nh\'e1 nh\'cat.
\par \pard \qj\nowidctlpar {\b 
\par }\pard \qj\nowidctlpar 4.2 Chu\'c8n b\'de ki\'d3m \'ae\'denh
\par 
\par Tr\'ad\'edc khi ti\'d5n h\'b5nh ki\'d3m \'ae\'denh ph\'b6i chu\'c8n b\'de c\'b8c c\'abng vi\'d6c sau \'ae\'a9y:
\par \pard \qj\nowidctlpar\tx360 
\par \pard \qj\nowidctlpar\tx360 - Ph\'ad\'acng ti\'d6n c\'c7n ki\'d3m \'ae\'denh v\'b5 ph\'ad\'acng ti\'d6n chu\'c8n ph\'b6i \'ae\'d3 trong ph\'dfng ki\'d3m \'ae\'denh \'ddt nh\'cat 6 gi\'ea. 
\par \pard \qj\nowidctlpar\tx360 
\par \pard \qj\nowidctlpar\tx360 - C\'a9n b\'bbng ni- v\'ab (n\'d5u d\'efng \'b8p k\'d5 pitt\'abng chu\'c8n) v\'b5 ki\'d3m tra m\'f8c d\'c7u \'eb thi\'d5t b\'de t\'b9o \'b8p ho\'c6c thi\'d5t b\'de t\'b9o ch\'a9n kh\'abng. \'a7\'c8y h\'d5t b\'e4t kh\'dd ra kh
\'e1i thi\'d5t b\'de.
\par \pard \qj\nowidctlpar\tx360 
\par - L\'b5m s\'b9ch \'ae\'c7u n\'e8i v\'b5 ph\'ad\'acng ti\'d6n c\'c7n ki\'d3m \'ae\'denh.
\par 
\par \pard \qj\nowidctlpar\tx360 - L\'bep ph\'ad\'acng ti\'d6n c\'c7n ki\'d3m \'ae\'denh v\'b5 ph\'ad\'acng ti\'d6n chu\'c8n v\'b5o v\'de tr\'dd l\'b5m vi\'d6c \'ae\'f3ng theo ph\'ad\'acng quy \'ae\'denh. \'a7\'e9 l\'d6ch cho ph\'d0p so v\'edi v\'de tr\'dd l
\'b5m vi\'d6c kh\'abng \'ae\'ad\'eec v\'ad\'eet qu\'b8 5 {\super 0}.
\par \pard \qj\nowidctlpar 
\par \pard \qj\nowidctlpar - \'a7\'e8i v\'edi ph\'ad\'acng ti\'d6n kh\'abng c\'e3 k\'fd hi\'d6u l\'bep \'ae\'c6t s\'cf l\'bep theo ph\'ad\'acng th\'bcng \'ae\'f8ng.
\par 
\par \pard \qj\fi-360\li360\nowidctlpar\tx360 {\b 5 Ti\'d5n h\'b5nh ki\'d3m \'ae\'denh
\par }\pard \qj\nowidctlpar {\b 
\par }\pard \qj\fi-720\li720\nowidctlpar\tx720 5.1 Ki\'d3m tra b\'aan ngo\'b5i
\par \pard \qj\nowidctlpar 
\par \pard \qj\nowidctlpar Ph\'b6i ki\'d3m tra b\'aan ngo\'b5i theo c\'b8c y\'aau c\'c7u sau \'ae\'a9y:
\par 
\par \pard \qj\nowidctlpar 5.1.1 Ph\'ad\'acng ti\'d6n c\'c7n ki\'d3m \'ae\'denh ph\'b6i \'eb t\'d7nh tr\'b9ng t\'e8t, c\'e3 \'ae\'c7y \'ae\'f1 c\'b8c chi ti\'d5t v\'b5 ph\'f4 t\'efng, kh\'abng b\'de \'a8n m\'dfn, b\'c8n, n\'f8t, han r\'d8; kim kh\'abng b\'de
 cong ho\'c6c g\'c9y; kh\'abng b\'de h\'e1ng m\'c6t s\'e8, ren \'ae\'c7u n\'e8i v\'b5 c\'b8c chi ti\'d5t kh\'b8c.
\par \pard \qj\nowidctlpar 
\par \pard \qj\nowidctlpar 5.1.2 K\'ddnh c\'f1a ph\'ad\'acng ti\'d6n c\'c7n ki\'d3m \'ae\'denh  kh\'abng c\'e3 v\'d5t n\'f8t, b\'e4t, b\'c8n, m\'e8c v\'b5 kh\'abng c\'e3 c\'b8c khuy\'d5t t\'cbt kh\'b8c c\'b6n tr\'eb vi\'d6c \'ae\'e4c s\'e8 ch\'d8, c\'e3 th\'d3
 thay k\'ddnh b\'bbng v\'cbt li\'d6u trong su\'e8t kh\'b8c, nh\'adng ph\'b6i gi\'f7 \'ae\'ad\'eec s\'f9 trong su\'e8t \'ae\'e3 trong \'aei\'d2u ki\'d6n l\'b5m vi\'d6c l\'a9u d\'b5i.
\par \pard \qj\nowidctlpar 
\par 
\par 
\par 
\par 
\par 
\par \pard \qj\nowidctlpar {\b\f25\fs28 \'a7lvn 54 : 1999
\par }\pard \qj\nowidctlpar 
\par 
\par 5.1.3 K\'fd, nh\'b7n hi\'d6u
\par 
\par Ph\'b6i ki\'d3m tra k\'fd, nh\'b7n hi\'d6u theo c\'b8c y\'aau c\'c7u sau \'ae\'a9y:
\par \pard \qj\nowidctlpar\tx360 
\par \pard \qj\nowidctlpar\tx360 - \'a7\'acn v\'de \'aeo;
\par 
\par - C\'cap ch\'ddnh x\'b8c;
\par 
\par - M\'abi tr\'ad\'eang \'aeo (\'ae\'e8i v\'edi ch\'cat kh\'dd \'ae\'c6c bi\'d6t);
\par 
\par - S\'e8 se-ri;
\par 
\par - T\'ad th\'d5 l\'bep \'ae\'c6t: n\'bbm ngang hay th\'bcng \'ae\'f8ng.
\par 
\par \pard \qj\nowidctlpar 5.2 Ki\'d3m tra k\'fc thu\'cbt
\par \pard \qj\nowidctlpar {\b 
\par }\pard \qj\nowidctlpar Ph\'b6i ki\'d3m tra k\'fc thu\'cbt theo c\'b8c y\'aau c\'c7u sau;
\par 
\par \pard \qj\nowidctlpar 5.2.1 \'a7\'acn v\'de \'aeo \'b8p su\'cat ph\'b6i l\'b5 Pa (pascan) v\'b5 c\'b8c \'ad\'edc v\'b5 b\'e9i c\'f1a n\'e3. Tr\'ad\'eang h\'eep c\'b8c ph\'ad\'acng ti\'d6n \'aeo ghi kh\'bec theo \'ae\'acn v\'de \'aeo kh\'b8c th\'d7 v\'c9
n ti\'d5n h\'b5nh ki\'d3m \'ae\'denh nh\'adng c\'c7n chuy\'d3n \'ae\'e6i       ra Pa.      
\par \pard \qj\nowidctlpar 
\par 5.2.2 Gi\'edi h\'b9n \'aeo tr\'aan c\'f1a \'b8p k\'d5, ch\'a9n kh\'abng k\'d5  thu\'e9c m\'e9t trong hai d\'b7y sau:
\par               1.10{\super n} ;  1,6.10{\super n} ; 2,5.10{\super n} ; 4.10{\super n}; 6.10{\super n}; 
\par \pard \qj\nowidctlpar               1.10{\super n};   2.10{\super n};  5.10{\super n}; 
\par \pard \qj\nowidctlpar 
\par Trong \'ae\'e3 n l\'b5 m\'e9t s\'e8 nguy\'aan d\'ad\'acng, \'a9m ho\'c6c b\'bbng kh\'abng.
\par 
\par Ch\'cap nh\'cbn nh\'f7ng \'b8p k\'d5 c\'e3 d\'b6i \'aeo kh\'b8c v\'edi quy \'ae\'denh tr\'aan.
\par 
\par 5.2.3 C\'cap ch\'ddnh x\'b8c c\'f1a \'b8p k\'d5 v\'b5 ch\'a9n kh\'abng k\'d5 ph\'b6i thu\'e9c m\'e9t trong hai d\'b7y sau:
\par                0,16; 0,25; 0,4; (0,35); 0,6 (0,5) v\'b5
\par                0,2;  0,6; (0,5).
\par 
\par 5.2.4 Gi\'b8 tr\'de \'ae\'e9 chia ph\'b6i g\'c7n b\'bbng sai s\'e8 cho ph\'d0p v\'b5 theo d\'b7y sau:
\par          \tab 1.10{\super n};   2.10{\super n};  5.10{\super n}.
\par Trong \'ae\'e3 n l\'b5 m\'e9t s\'e8 nguy\'aan d\'ad\'acng, \'a9m ho\'c6c b\'bbng 0.
\par 
\par \pard \qj\nowidctlpar 5.2.5 Vi\'d6c \'ae\'b8nh s\'e8 thang \'aeo ph\'b6i th\'ddch h\'eep v\'edi v\'b9ch chia, gi\'b8 tr\'de nh\'e1 nh\'cat gi\'f7a hai v\'b9ch chia li\'d2n nhau kh\'abng \'ae\'ad\'eec v\'ad\'eet qu\'b8 hai l\'c7n sai s\'e8 c\'ac b\'b6
n cho ph\'d0p. B\'d2 r\'e9ng m\'e7i v\'b9ch chia kh\'abng \'ae\'ad\'eec v\'ad\'eet qu\'b8 1/5 kho\'b6ng c\'b8ch gi\'ad\'b7 hai v\'b9ch chia li\'aan ti\'d5p; g\'b9ch th\'f8 n\'a8m, th\'f8 m\'ad\'eai ph\'b6i d\'b5i h\'acn c\'b8c v\'b9ch kh\'b8c v\'b5 v\'b9
ch th\'f8 m\'ad\'eai ph\'b6i \'ae\'b8nh s\'e8.
\par \pard \qj\nowidctlpar 
\par 
\par 
\par 
\par 
\par \pard \qr\nowidctlpar {\b\f25\fs28 \'a7lvn 54 : 1999
\par }\pard \qj\nowidctlpar 
\par \pard \qj\nowidctlpar 
\par \pard \qj\nowidctlpar 5.2.6 {\f16 \'eb} tr\'b9ng th\'b8i kh\'abng l\'b5m vi\'d6c, kim ph\'b6i tr\'efng v\'edi v\'b9ch "0" ho\'c6c l\'d6ch v\'edi v\'b9ch "0" m\'e9t gi\'b8 tr\'de kh\'abng v\'ad\'eet qu\'b8 gi\'b8 tr\'de sai s\'e8 cho ph\'d0p ( xem 5.3.1).

\par \pard \qj\nowidctlpar 
\par \pard \qj\nowidctlpar Kim ph\'b6i chuy\'d3n \'ae\'e9ng \'ae\'d2u \'ae\'c6n , kh\'abng s\'b8t v\'b5o m\'c6t s\'e8 v\'b5 ph\'b6i ph\'f1 t\'f5 1/4 d\'d5n 3/4 chi\'d2u d\'b5i  c\'f1a v\'b9ch chia ng\'ben nh\'cat.
\par \pard \qj\nowidctlpar 
\par \pard \qj\fi-360\li360\nowidctlpar\tx360 5.3\tab  Ki\'d3m tra \'aeo l\'ad\'eang 
\par \pard \qj\nowidctlpar 
\par \pard \qj\nowidctlpar C\'b8c \'b8p k\'d5 v\'b5 ch\'a9n kh\'abng k\'d5 \'ae\'ad\'eec ki\'d3m tra \'aeo l\'ad\'eang theo tr\'d7nh t\'f9 , y\'aau c\'c7u v\'b5 ph\'ad\'acng ph\'b8p sau \'ae\'a9y:
\par \pard \qj\nowidctlpar 
\par 5.3.1 Sai s\'e8 c\'ac b\'b6n cho ph\'d0p:
\par 
\par \pard \qj\nowidctlpar a -  {{\field{\*\fldinst SYMBOL 177 \\f "Symbol" \\s 13}{\fldrslt\f1\fs26}}} 0,8k \'ae\'e8i v\'edi  ki\'d3m \'ae\'denh ban \'ae\'c7u.
\par \pard \qj\nowidctlpar\tx360 b -  {{\field{\*\fldinst SYMBOL 177 \\f "Symbol" \\s 13}{\fldrslt\f1\fs26}}} k \'ae\'e8i v\'edi  ki\'d3m \'ae\'denh \'ae\'denh k\'fa.
\par \pard \qj\nowidctlpar Trong \'ae\'e3:  {\fs44  }{\fs44\sub k}{\fs52\sub  =}{\sub   }{\ul C\'cap ch\'ddnh x\'b8c }{\ul {\field{\*\fldinst SYMBOL 180 \\f "Symbol" \\s 13}{\fldrslt\f1\fs26}}}{\ul  gi\'edi h\'b9n \'aeo tr\'aan}
\par \pard \qj\nowidctlpar                                                  100
\par 
\par 5.3.2 Sai s\'e8 khi t\'a8ng v\'b5 khi gi\'b6m \'b8p su\'cat kh\'abng \'ae\'ad\'eec v\'ad\'eet qu\'b8 qui \'ae\'denh \'eb \'aei\'d2u 5.3.1.
\par 
\par \pard \qj\nowidctlpar 5.3.3 Sai s\'e8 \'ae\'b5n h\'e5i (\'ae\'e9 h\'e5i sai) kh\'abng \'ae\'ad\'eec v\'ad\'eet qu\'b8 gi\'b8 tr\'de tuy\'d6t \'ae\'e8i c\'f1a sai s\'e8 c\'ac b\'b6n cho ph\'d0p quy \'ae\'denh \'eb \'aei\'d2u 5.3.1.
\par \pard \qj\nowidctlpar 
\par \pard \qj\nowidctlpar 5.3.4 Ph\'ad\'acng ti\'d6n ki\'d3m \'ae\'denh ph\'b6i \'ae\'ad\'eec ki\'d3m tra \'ddt nh\'cat 8 \'aei\'d3m ph\'a9n b\'e8 \'ae\'d2u tr\'aan to\'b5n b\'e9 thang \'aeo. {\f16 \'b8}p su\'cat ph\'b6i \'ae\'ad\'eec t\'a8ng \'ae\'d2u \'ae
\'c6n qua c\'b8c \'aei\'d3m \'aeo, cho ch\'deu t\'b6i 5 ph\'f3t \'eb gi\'edi h\'b9n \'aeo tr\'aan r\'e5i l\'b9i gi\'b6m \'b8p su\'cat \'ae\'d2u \'ae\'c6n qua c\'b8c \'aei\'d3m \'aeo. Tr\'ad\'edc khi \'ae\'e4c ph\'b6i g\'e2 nh\'d1 l\'aan v\'e1 \'b8p k\'d5
 v\'b5 ghi ch\'d8 s\'e8 v\'b5o bi\'aan b\'b6n ki\'d3m \'ae\'denh. {\f16 \'ae}\'e8i v\'edi ch\'a9n kh\'abng k\'d5 cho ph\'d0p ch\'deu t\'b6i \'eb \'b8p su\'cat nh\'e1 h\'acn \'b8p su\'cat gi\'edi h\'b9n \'aeo tr\'aan nh\'adng kh\'abng nh\'e1 h\'ac
n - 0,095 MPa.
\par \pard \qj\nowidctlpar 
\par \pard \qj\nowidctlpar 5.3.5 \'a7\'c7u m\'f3t ph\'ad\'acng ti\'d6n c\'c7n ki\'d3m \'ae\'denh v\'b5 ph\'ad\'acng ti\'d6n  chu\'c8n ph\'b6i n\'bbm tr\'aan c\'efng m\'e9t m\'c6t ph\'bcng n\'bbm ngang, n\'d5u ch\'aanh l\'d6ch \'b8p su\'cat gi\'f7a hai \'ae\'c7
u m\'f3t l\'edn h\'acn 1/10 sai s\'e8 c\'ac b\'b6n cho ph\'d0p th\'d7 ph\'b6i t\'ddnh \'ae\'d5n sai s\'e8 do c\'e9t ch\'cat l\'e1ng \'ae\'e3 g\'a9y ra. 
\par \pard \qj\nowidctlpar 
\par 5.3.6 Khi ki\'d3m tra theo \'aei\'d2u 5.3.4 ph\'b6i: 
\par 
\par \pard \qj\nowidctlpar\tx360 a - \'a7\'e8i v\'edi \'b8p k\'d5 v\'b5 ch\'a9n kh\'abng k\'d5 chu\'c8n c\'cap ch\'ddnh x\'b8c 0,16 (0,15) ph\'b6i ti\'d5n h\'b5nh ba lo\'b9t \'aeo li\'aan ti\'d5p theo chi\'d2u t\'a8ng v\'b5 gi\'b6m \'b8p su\'cat.
\par \pard \qj\nowidctlpar\tx360 
\par \pard \qj\nowidctlpar\tx360 b - \'a7\'e8i v\'edi \'b8p k\'d5 v\'b5 ch\'a9n kh\'abng k\'d5 chu\'c8n c\'cap ch\'ddnh x\'b8c 0,25; 0,4(0,35); 0,6(0,5) ch\'d8 c\'c7n hai lo\'b9t \'aeo li\'aan ti\'d5p theo chi\'d2u t\'a8ng v\'b5 gi\'b6m \'b8p su\'cat .
\par \pard \qj\nowidctlpar 
\par \pard \qj\nowidctlpar 5.3.7 \'a7\'e8i v\'edi \'b8p k\'d5 c\'e3 thang \'aeo ghi kh\'bec theo \'ae\'acn v\'de \'b8p su\'cat, ghi k\'d5t qu\'b6 v\'b5o bi\'aan b\'b6n ki\'d3m \'ae\'denh theo m\'c9u \'eb ph\'f4 l\'f4c. 
\par \pard \qj\nowidctlpar 
\par 
\par \pard \nowidctlpar {\b\f25\fs28 \'a7lvn 54 : 1999
\par }\pard \qj\nowidctlpar 
\par \pard \qj\nowidctlpar 
\par \pard \qj\nowidctlpar \'a7\'e8i v\'edi \'b8p k\'d5 c\'e3 thang \'aeo ghi kh\'bec theo v\'b9ch , ghi k\'d5t qu\'b6 v\'b5o bi\'aan b\'b6n ki\'d3m \'ae\'denh theo m\'c9u \'eb ph\'f4 l\'f4c, nh\'adng ph\'b6i chuy\'d3n \'ae\'e6i c\'b8c tr\'de s\'e8 \'eb c\'b8
c c\'e9t theo v\'b9ch ho\'c6c theo \'ae\'acn v\'de \'b8p su\'cat t\'ad\'acng \'f8ng v\'edi chu\'c8n.
\par \pard \qj\nowidctlpar 
\par 5.4 X\'b8c \'ae\'denh \'b6nh h\'ad\'ebng c\'f1a ma s\'b8t
\par 
\par \pard \qj\nowidctlpar {\f16 \'b6}nh h\'ad\'ebng c\'f1a ma s\'b8t \'ae\'ad\'eec x\'b8c \'ae\'denh \'ae\'e5ng th\'eai v\'edi vi\'d6c x\'b8c \'ae\'denh sai s\'e8 c\'ac b\'b6n cho ph\'d0p c\'f1a ph\'ad\'acng ti\'d6n theo \'aei\'d2u 5.3.1 \'ae\'d5n 5.3.3.

\par \pard \qj\nowidctlpar {\f16 
\par }\pard \qj\nowidctlpar {\f16 \'b6}nh h\'ad\'ebng c\'f1a ma s\'b8t \'ae\'ad\'eec x\'b8c \'ae\'denh b\'bbng hi\'d6u s\'e8 ch\'d8 c\'f1a ph\'ad\'acng ti\'d6n \'aeo tr\'ad\'edc v\'b5 sau khi g\'e2 nh\'d1 v\'b5o v\'e1 c\'f1a \'b8p k\'d5 \'eb m\'e7i m\'e9t \'ae
i\'d3m \'aeo v\'b5 gi\'b8 tr\'de \'ae\'e3 kh\'abng \'ae\'ad\'eec v\'ad\'eet qu\'b8 1/2 sai s\'e8 c\'ac b\'b6n cho ph\'d0p.
\par \pard \qj\nowidctlpar 
\par \pard \qj\nowidctlpar {\b 6} {\b X\'f6 l\'fd k\'d5t qu\'b6 ki\'d3m \'ae\'denh
\par }\pard \qj\nowidctlpar 
\par \pard \qj\nowidctlpar 6.1 N\'d5u ph\'ad\'acng ti\'d6n ki\'d3m \'ae\'denh \'ae\'b9t y\'aau c\'c7u theo c\'b8c m\'f4c 5.1; 5.2; 5.3 v\'b5 5.4 \'ae\'ad\'eec k\'d1p ch\'d7, d\'b8n tem, c\'cap gi\'cay ch\'f8ng nh\'cbn ki\'d3m \'ae\'denh v\'b5 \'ae\'ad\'eec ph
\'d0p s\'f8 d\'f4ng.
\par \pard \qj\nowidctlpar 
\par \pard \qj\nowidctlpar 6.2 N\'d5u ph\'ad\'acng ti\'d6n ki\'d3m \'ae\'denh kh\'abng \'ae\'b9t y\'aau c\'c7u th\'d7 kh\'abng \'ae\'ad\'eec c\'cap gi\'cay ch\'f8ng nh\'cbn ki\'d3m \'ae\'denh, xo\'b8 b\'e1 d\'cau ki\'d3m \'ae\'denh c\'f2 (n\'d5u c\'e3).
\par \pard \qj\nowidctlpar 
\par 6.3 Chu k\'fa ki\'d3m \'ae\'denh: 1 n\'a8m.
\par 
\par 
\par 
