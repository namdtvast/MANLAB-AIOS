\par 1 Ph\'b9m vi \'b8p d\'f4ng
\par }\pard \qj\nowidctlpar 
\par \pard \qj\nowidctlpar V\'a8n b\'b6n k\'fc thu\'cbt n\'b5y quy \'ae\'denh quy tr\'d7nh ki\'d3m \'ae\'denh ban \'ae\'c7u v\'b5 ki\'d3m \'ae\'denh \'ae\'denh k\'fa c\'b8c \'b8p k\'d5, ch\'a9n kh\'abng k\'d5 chu\'c8n ki\'d3u l\'df xo ch\'d8 th\'de tr\'f9c ti
\'d5p  c\'e3 c\'cap ch\'ddnh x\'b8c t\'f5 0,16 (0,15) \'ae\'d5n 0,6 v\'b5 ph\'b9m vi \'aeo t\'f5 ( - 0,1 {{\field{\*\fldinst SYMBOL 184 \\f "Symbol" \\s 13}{\fldrslt\f1\fs26}}} 160) MPa t\'ad\'acng \'ae\'ad\'acng ( -1 {{\field{\*\fldinst SYMBOL 184 \\f 
"Symbol" \\s 13}{\fldrslt\f1\fs26}}} 1600) bar. 
\par \pard \qj\nowidctlpar 
