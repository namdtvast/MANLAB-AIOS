\par }\pard\plain \s1\qr\keepn\nowidctlpar\outlinelevel0\adjustright \b\f15\fs26 {\i\f53 Ph\'f4 l\'f4c 1
\par }\pard\plain \nowidctlpar\adjustright \f15\fs26 {
\par }\pard \qc\nowidctlpar\adjustright {\b\f17\fs28 Y\'aau c\'c7u k\'fc thu\'cbt v\'b5 \'aeo l\'ad\'eang
\par }\pard \qj\nowidctlpar\adjustright {
\par 
\par 1. H\'d7nh d\'b8ng, v\'cbt li\'d6u, k\'d5t c\'cau c\'f1a xit\'d0c ph\'b6i \'ae\'b6m b\'b6o \'ae\'f1 b\'d2n v\'f7ng d\'ad\'edi \'b6nh h\'ad\'ebng c\'f1a m\'abi tr\'ad\'eang v\'b5 ch\'cat l\'e1ng \'aeong ch\'f8a, kh\'abng \'ae\'ad\'eec bi\'d5n d\'b9
ng trong \'aei\'d2u ki\'d6n v\'cbn h\'b5nh quy \'ae\'denh. 
\par 
\par 2. H\'d7nh d\'b9ng, k\'d5t c\'cau ph\'b6i \'ae\'b6m b\'b6o kh\'abng t\'b9o t\'f3i kh\'dd trong qu\'b8 tr\'d7nh n\'b9p ch\'cat l\'e1ng v\'b5o v\'b5 kh\'abng \'ae\'e4ng l\'b9i ch\'cat l\'e1ng khi x\'b6 ra \'eb \'aei\'d2u ki\'d6n m\'c6t b\'bbng t\'ad\'acng 
\'ae\'e8i c\'f1a \'ae\'ad\'eang ray.
\par 
\par }\pard\plain \s15\qj\nowidctlpar\adjustright \f15\fs26 {3. Xit\'d0c ph\'b6i c\'e3 \'aei\'d3m m\'e8c \'aeo c\'e8 \'ae\'denh r\'e2 r\'b5ng v\'b5 d\'d4 nh\'d7n th\'cay. V\'de tr\'dd \'aeo ph\'b6i \'aei qua \'aei\'d3m m\'e8c tr\'efng v\'edi \'ae\'ad\'eang k
\'ddnh th\'bcng \'ae\'f8ng c\'f1a xit\'d0c v\'b5 c\'bet \'ae\'ad\'eang sinh th\'cap nh\'cat t\'b9i \'aei\'d3m kh\'abng c\'e3 l\'e7 , v\'cbt c\'b6n trong b\'b8n k\'ddnh 10 cm. 
\par }\pard\plain \qj\nowidctlpar\adjustright \f15\fs26 {
\par 4. Ph\'c7n gh\'d0p n\'e8i gi\'f7a th\'a9n v\'b5 ph\'c7n tr\'f4c c\'e6 xit\'d0c ph\'b6i \'ae\'b6m b\'b6o th\'bcng \'ae\'f8ng (vu\'abng g\'e3c), ph\'b6i c\'e3 k\'d5t c\'cau \'ae\'b6m b\'b6o tho\'b8t h\'d5t t\'f3i kh\'dd t\'b9o th\'b5nh xung quanh khu v\'f9
c c\'e6 xit\'d0c. 
\par 
\par 5. Mi\'d6ng c\'e6 xit\'d0c ph\'b6i \'eb v\'de tr\'dd cao nh\'cat v\'b5 c\'e3 n\'bep \'ae\'cby k\'ddn . V\'dfng \'ae\'d6m gi\'f7a n\'bep v\'b5 mi\'d6ng ph\'b6i l\'b5m b\'bbng v\'cbt li\'d6u ch\'deu x\'a8ng d\'c7u . N\'bep \'ae\'ad\'eec b\'bet ch\'c6t v\'b5
o c\'e6 b\'bbng k\'d5t c\'cau bu l\'abng, trong \'ae\'e3 ph\'b6i c\'e3 \'ddt nh\'cat 2 bu l\'abng c\'e3 s\'bdn l\'e7 \'ae\'d3 lu\'e5n d\'a9y ni\'aam phong k\'d1p ch\'d7. 
\par 
\par 6. Van h\'ab h\'cap \'ae\'ad\'eec l\'bep ch\'c6t tr\'aan n\'bep xit\'d0c v\'b5 ph\'b6i l\'b5m vi\'d6c \'ae\'ad\'eec c\'b6 2 chi\'d2u \'ae\'b6m b\'b6o th\'eb ra khi \'b8p su\'cat d\'ad b\'aan trong xit\'d0c l\'edn h\'acn ho\'c6c b\'bbng 0,5 at v\'b5 th\'eb
 v\'b5o khi \'b8p su\'cat ch\'a9n kh\'abng trong xit\'d0c nh\'e1 h\'acn ho\'c6c b\'bbng 0,015 at.
\par }\pard\plain \s15\qj\nowidctlpar\adjustright \f15\fs26 {
\par 7. C\'b8c thi\'d5t b\'de ph\'f4 c\'c7n thi\'d5t c\'e3 b\'aan trong xit\'d0c ph\'b6i c\'e8 \'ae\'denh, kh\'abng c\'b6n tr\'eb vi\'d6c n\'b9p ch\'cat l\'e1ng v\'b5o v\'b5 x\'b6 ch\'cat l\'e1ng ra; ph\'b6i c\'e3 c\'ac c\'cau h\'eep l\'fd \'ae\'d3 ni\'aa
m phong k\'d1p ch\'d7 ch\'e8ng thay \'ae\'e6i khi s\'f6 d\'f4ng v\'cbn h\'b5nh. 
\par }\pard\plain \qj\nowidctlpar\adjustright \f15\fs26 {
\par 8. \'a7\'e9 nh\'b9y trong to\'b5n ph\'b9m vi \'aeo \'ddt nh\'cat l\'b5 3 mm cho 2 % dung t\'ddch danh \'ae\'denh. 
\par 
\par 9. \'a7\'e9 k\'ddn c\'f1a xit\'d0c \'ae\'ad\'eec th\'f6 b\'bbng n\'ad\'edc \'eb \'b8p su\'cat kh\'dd quy\'d3n c\'c7n ph\'b6i kh\'abng c\'e3 c\'b8c v\'d5t r\'df r\'d8 ho\'c6c \'c8m \'ad\'edt t\'b9i c\'b8c ch\'e7 n\'e8i. 
\par 
\par 10. Dung t\'ddch c\'f1a xit\'d0c th\'abng th\'ad\'eang ph\'b6i \'ae\'ad\'eec x\'b8c \'ae\'denh bao g\'e5m c\'b6 ph\'c7n \'e8ng x\'b6 cho t\'edi t\'cbn van ch\'c6n cu\'e8i c\'efng khi n\'bep mi\'d6ng \'ae\'ad\'eec m\'eb (n\'d5u kh\'abng c\'e3 quy \'ae\'de
nh kh\'b8c).
\par 
\par 11. Bi\'d3n nh\'b7n hi\'d6u. 
\par 
\par 11.1 M\'e7i xit\'d0c ph\'b6i c\'e3 bi\'d3n nh\'b7n hi\'d6u \'ae\'ad\'eec l\'b5m b\'bbng v\'cbt li\'d6u b\'d2n trong qu\'b8 tr\'d7nh v\'cbn h\'b5nh b\'d7nh th\'ad\'eang v\'b5 ph\'b6i cho ph\'d0p ghi kh\'bec \'ae\'ad\'eec s\'e8 li\'d6u r\'e2 r\'b5ng.  

\par Ch\'f7 v\'b5 s\'e8 c\'c7n ph\'b6i r\'e2, kh\'abng t\'c8y xo\'b8 \'ae\'ad\'eec. Chi\'d2u cao c\'f1a ch\'f7 v\'b5 s\'e8 kh\'abng \'ae\'ad\'eec nh\'e1 h\'acn 3 mm.
\par 
\par 11.2 Bi\'d3n nh\'b7n hi\'d6u ph\'b6i \'ae\'ad\'eec g\'ben c\'e8 \'ae\'denh t\'b9i 1 trong 2 \'ae\'c7u c\'f1a xit\'d0c v\'b5 c\'e3 c\'ac c\'cau \'ae\'d3 ni\'aam phong k\'d1p ch\'d7. 
\par 
\par }\pard \qj\sb120\nowidctlpar\adjustright {N\'e9i dung bi\'d3u nh\'b7n hi\'d6u ph\'b6i bao g\'e5m:
\par - T\'aan ho\'c6c nh\'b7n hi\'d6u c\'ac s\'eb s\'b6n xu\'cat; 
\par - S\'e8 \'ae\'a8ng k\'fd c\'f1a xit\'d0c \'ae\'ad\'eang s\'bet;
\par - Dung t\'ddch to\'b5n ph\'c7n V (m}{\super 3}{);
\par - Chi\'d2u cao ki\'d3m tra H (mm);
\par - S\'e8 v\'b5 n\'a8m c\'cap ch\'f8ng ch\'d8 hi\'d6u chu\'c8n (l\'cbp b\'b6ng).
\par }\pard\plain \s16\qj\nowidctlpar\adjustright \f15\fs26 {
