\par }\pard \s16\qj\nowidctlpar\adjustright {f}{\sub i}{' ; f}{\sub i}{" : kho\'b6ng c\'b8ch t\'f5 d\'a9y d\'e4i \'ae\'d5n \'aei\'d3m ti\'d5p gi\'b8p gi\'f7a \'ae\'c7u v\'edi ph\'c7n tr\'f4 t\'b9i \'ae\'ad\'eang 
\par \tab   sinh th\'cap nh\'cat v\'b5 cao nh\'cat c\'f1a xit\'d0c t\'ad\'acng \'f8ng, mm; 
\par i  = 1 , 2.
\par 
\par 
\par \'a7\'d3 \'ae\'b6m b\'b6o cho ph\'d0p \'aeo \'ae\'ad\'eec ch\'ddnh x\'b8c c\'c7n ph\'b6i c\'e3 thi\'d5t b\'de g\'b8 l\'bep th\'ddch h\'eep cho vi\'d6c \'aeo n\'b5y. V\'dd d\'f4: c\'e3 th\'d3 s\'f6 d\'f4ng b\'e9 g\'b8 g\'e5m \'aake, d\'a9y d\'e4i v\'b5
 thanh n\'e8i sao cho thanh n\'e8i v\'b5 m\'e9t chi\'d2u c\'f1a \'aake c\'efng n\'bbm tr\'aan \'ae\'ad\'eang sinh cao nh\'cat c\'f1a xit\'d0c c\'dfn d\'a9y \'ae\'e4i v\'b5 chi\'d2u kia c\'f1a \'aake n\'bbm tr\'aan \'ae\'ad\'eang th\'bcng \'aei qua \'aei
\'d3m xa nh\'cat c\'f1a \'ae\'c7u xit\'d0c.
\par }\pard \s16\qj\fi567\nowidctlpar\adjustright {
\par 
\par }\pard \s16\qr\fi567\nowidctlpar\adjustright {\b\f17\fs28 \'aelvn 58 : 1999
\par }{
\par }\pard \s16\qj\nowidctlpar\adjustright {\b 3.7 \'a7o c\'b8c th\'abng s\'e8 tr\'aan c\'e6 xit\'d0c 
\par }\pard \s16\qj\fi567\nowidctlpar\adjustright {
\par }\pard \s16\qj\nowidctlpar\adjustright {D\'efng th\'ad\'edc cu\'e9n, th\'ad\'edc v\'b9ch c\'e3 gi\'b8 tr\'de \'ae\'e9 chia \'ae\'d5n 1 mm \'ae\'d3 \'aeo c\'b8c th\'abng s\'e8 c\'f1a c\'e6 xit\'d0c g\'e5m:
\par }\pard \s16\qj\fi567\nowidctlpar\adjustright {h - kho\'b6ng c\'b8ch t\'f5 v\'de tr\'dd \'aeo m\'f8c ch\'cat l\'e1ng \'ae\'d5n \'ae\'ad\'eang sinh cao nh\'cat, mm;
\par t  - ph\'c7n l\'f3n c\'f1a c\'e6 v\'b5o ph\'c7n tr\'f4 c\'f1a xit\'d0c, mm;
\par a - kho\'b6ng c\'b8ch t\'f5 v\'de tr\'dd \'aeo m\'f8c ch\'cat l\'e1ng \'ae\'d5n \'aei\'d3m m\'e8c \'aeo chi\'d2u d\'b5i ph\'c7n tr\'f4 t\'b9i \'ae\'c7u xit\'d0c g\'c7n nh\'cat d\'e4c theo \'ae\'ad\'eang sinh cao nh\'cat, mm.
\par 
\par }\pard \s16\nowidctlpar\adjustright {C\'b8ch \'aeo c\'f4 th\'d3 \'ae\'ad\'eec m\'ab t\'b6 tr\'aan h\'d7nh 5.
