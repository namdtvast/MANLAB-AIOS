\par }\pard \s16\qj\nowidctlpar\adjustright {\b 3.8 X\'b8c \'ae\'denh chi\'d2u cao ki\'d3m tra H}{\b\sub max }{\b 
\par }{
\par D\'efng th\'ad\'edc \'aeo chi\'d2u cao m\'f8c ch\'cat l\'e1ng x\'b8c \'ae\'denh kho\'b6ng c\'b8ch t\'f5 \'aei\'d3m m\'e8c p \'ae\'d5n \'aei\'d3m th\'cap nh\'cat c\'f1a xit\'d0c. Th\'f9c hi\'d6n ph\'d0p \'aeo kh\'abng \'ddt h\'acn 3 l\'c7n. Sai l\'d6ch k
\'d5t qu\'b6 gi\'f7a c\'b8c l\'c7n \'aeo kh\'abng \'ae\'ad\'eec v\'ad\'eet qu\'b8 2mm.
\par 
\par Chi\'d2u cao ki\'d3m tra \'ae\'ad\'eec t\'ddnh b\'bbng trung b\'d7nh c\'e9ng c\'f1a k\'d5t qu\'b6 c\'b8c ph\'d0p \'aeo n\'e3i tr\'aan v\'b5 \'ae\'ad\'eec l\'b5m tr\'dfn \'ae\'d5n mm.
\par }\pard \s16\qj\fi567\nowidctlpar\adjustright {
\par }\pard \s16\qj\nowidctlpar\adjustright {\b 3.9 X\'b8c \'ae\'denh th\'d3 t\'ddch cho\'b8n ch\'e7  
\par }{
\par Th\'d3 t\'ddch c\'b8c v\'cbt cho\'b8n ch\'e7 trong xit\'d0c \'ae\'ad\'eec x\'b8c \'ae\'denh b\'bbng c\'b8ch \'aeo, t\'ddnh tr\'f9c ti\'d5p theo k\'ddch th\'ad\'edc v\'b5 v\'de tr\'dd c\'f1a n\'e3. 
\par 
\par }{\b\f18 3.10 }{\b T\'ddnh to\'b8n l\'cbp b\'b6ng}{\b\f18 
\par }{
\par 3.10.1 Dung t\'ddch to\'b5n ph\'c7n c\'f1a xit\'d0c 
\par 
\par 
\par }\pard \s16\nowidctlpar\adjustright {\b\f17\fs28 \'aelvn 58 : 1999
\par }{
