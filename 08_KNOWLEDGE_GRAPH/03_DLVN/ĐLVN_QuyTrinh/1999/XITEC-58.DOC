\par H}{\sub gh
\par }{\cell \cell \cell \cell \cell \cell \cell }\pard\plain \nowidctlpar\widctlpar\intbl\adjustright \f15\fs26 {\row }\pard\plain \s16\qj\nowidctlpar\adjustright \f15\fs26 {\b\super 
\par 
\par }{\i\ul\super *}{\i\ul  Ch\'f3 \'fd:}{ Khi l\'cbp b\'b6ng s\'e8 li\'d6u tr\'aan ph\'b6i hi\'d6u ch\'d8nh dung t\'ddch xit\'d0c do v\'cbt cho\'b8n ch\'e7 (n\'d5u c\'e3) g\'a9y n\'aan trong ph\'b9m vi cho\'b8n ch\'e7.
\par 
\par }\pard \s16\nowidctlpar\adjustright {\b 
\par }{\b\fs28 4 L\'cbp b\'b6ng dung t\'ddch b\'bbng ph\'ad\'acng ph\'b8p dung t\'ddch 
\par }{\b 
\par }\pard \s16\qj\nowidctlpar\adjustright {\b 4.1 Nguy\'aan t\'bec chung 
\par }{
\par \'a7\'e6 li\'aan ti\'d5p t\'f5ng l\'ad\'eeng ch\'cat l\'e1ng \'ae\'b7 \'ae\'ad\'eec ch\'e4n v\'b5o xit\'d0c v\'b5 \'aeo chi\'d2u cao m\'f8c ch\'cat l\'e1ng sau m\'e7i l\'c7n \'ae\'e6 ta s\'cf c\'e3 \'ae\'ad\'eec m\'e9t m\'e8i quan h\'d6 gi\'f7a chi\'d2
u cao ch\'f8a v\'b5 th\'d3 t\'ddch ch\'cat l\'e1ng. S\'f6 d\'f4ng ph\'ad\'acng ph\'b8p n\'e9i suy tuy\'d5n t\'ddnh \'ae\'d3 l\'cbp b\'b6ng dung t\'ddch cho xit\'d0c d\'f9a tr\'aan c\'b8c s\'e8 li\'d6u n\'e3i tr\'aan.
\par Do ti\'d5t di\'d6n ngang c\'f1a xit\'d0c thay \'ae\'e6i theo chi\'d2u cao ch\'f8a n\'aan m\'e8i quan h\'d6 gi\'f7a dung t\'ddch v\'b5 chi\'d2u cao kh\'abng ph\'b6i l\'b5 tuy\'d5n t\'ddnh. H\'acn n\'f7a khi \'aeo m\'f8c ch\'cat l\'e1ng ta c\'dfn g\'c6p ph
\'b6i sai s\'e8 \'ae\'e4c m\'f8c n\'aan ph\'b6i ch\'e4n s\'e8 l\'ad\'eeng \'aei\'d3m \'aeo v\'b5 dung l\'ad\'eeng ch\'cat l\'e1ng c\'f1a m\'e7i l\'c7n \'ae\'e6 sao cho l\'ad\'eeng ch\'cat l\'e1ng \'ae\'e6 v\'b5o xit\'d0c trong m\'e7i ph\'d0p \'aeo chi\'d5
m m\'e9t chi\'d2u cao tho\'b6 m\'b7n m\'e8i quan h\'d6 b\'cbc nh\'cat v\'edi dung t\'ddch.
\par }{\i 
\par }{\b 4.2 Ph\'ad\'acng ti\'d6n \'aeo 
\par }{
\par - B\'d7nh chu\'c8n dung t\'ddch h\'b9ng 2 ho\'c6c \'ae\'e5ng h\'e5 chu\'c8n c\'cap ch\'ddnh x\'b8c kh\'abng th\'cap h\'acn 0.2 c\'e3 c\'ec dung t\'ddch v\'b5 ph\'b9m vi \'aeo th\'ddch h\'eep \'ae\'d3 h\'b9n ch\'d5 th\'eai gian \'aeo v\'b5 c\'b8c \'b6nh h
\'ad\'ebng kh\'b8c c\'f1a m\'abi tr\'ad\'eang xung quanh.
\par - Th\'ad\'edc \'aeo chi\'d2u cao m\'f8c ch\'cat l\'e1ng c\'e3 gi\'b8 tr\'de \'ae\'e9 chia 1 mm.
\par }\pard \s16\nowidctlpar\adjustright {
\par S\'ac \'ae\'e5 b\'e8 tr\'dd ph\'ad\'acng ti\'d6n \'aeo \'ae\'ad\'eec m\'ab t\'b6 tr\'aan h\'d7nh 6.
\par 
\par 
\par 
\par }\pard \s16\qr\nowidctlpar\adjustright {\b\f17\fs28 \'aelvn 58 : 1999
