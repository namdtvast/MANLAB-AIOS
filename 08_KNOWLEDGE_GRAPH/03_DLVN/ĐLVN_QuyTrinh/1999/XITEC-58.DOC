\par }\pard \s16\qj\sl288\slmult1\nowidctlpar\adjustright {\lang1024\cgrid {\shp{\*\shpinst\shpleft467\shptop331\shpright1007\shpbottom331\shpfhdr0\shpbxcolumn\shpbypara\shpwr3\shpwrk0\shpfblwtxt0\shpz52\shplid1078
{\sp{\sn shapeType}{\sv 20}}{\sp{\sn fFlipH}{\sv 0}}{\sp{\sn fFlipV}{\sv 0}}{\sp{\sn fShadow}{\sv 0}}}{\shprslt{\*\do\dobxcolumn\dobypara\dodhgt8244\dpline\dpptx0\dppty0\dpptx540\dppty0\dpx467\dpy331\dpxsize540\dpysize0
\dplinew15\dplinecor0\dplinecog0\dplinecob0}}}}{V}{\sub i}{ : dung t\'ddch c\'f1a xit\'d0c t\'ddnh \'ae\'d5n \'aei\'d3m \'aeo th\'f8 i, m}{\super 3 }{(V}{\sub o}{ ng\'c7m \'ae\'denh l\'b5 b\'bbng 0 m}{\super 3}{).
\par  i  = 1 , 42.
\par 
\par }\pard \s16\qj\nowidctlpar\adjustright {\i\ul Ch\'f3 \'fd:}{\i  
\par }\pard \s16\qj\sb120\nowidctlpar\adjustright {1. C\'abng th\'f8c tr\'aan \'ae\'ad\'eec \'b8p d\'f4ng cho tr\'d7nh t\'f9 t\'ddnh to\'b8n khi x\'b6 ch\'cat l\'e1ng t\'f5 thi\'d5t b\'de chu\'c8n v\'b5o xit\'d0c. C\'e3 th\'d3 \'b8p d\'f4ng tr\'d7nh t\'f9 ng
\'ad\'eec l\'b9i, t\'f8c l\'b5 h\'f3t ch\'cat l\'e1ng t\'f5 xit\'d0c ch\'f8a \'ae\'c7y ra thi\'d5t b\'de chu\'c8n, khi \'ae\'e3 ph\'b6i x\'bep x\'d5p l\'b9i c\'b8c k\'d5t qu\'b6 \'aeo theo tr\'d7nh t\'f9 nh\'ad khi \'ae\'e6 v\'b5o xit\'d0c tr\'ad\'ed
c khi t\'ddnh to\'b8n l\'cbp b\'b6ng.
\par 2. Trong khi l\'cbp b\'b6ng, c\'b8c cm chi\'d2u cao n\'bbm trong kho\'b6ng k\'d5 ti\'d5p c\'f1a hai m\'f8c ch\'cat l\'e1ng th\'d7 ph\'b6i th\'f9c hi\'d6n ph\'d0p n\'e9i suy k\'d5t qu\'b6 gi\'f7a hai m\'f8c k\'d5 ti\'d5p \'ae\'e3.
\par }\pard \s16\qj\fi567\nowidctlpar\adjustright {
\par 
\par }\pard \s16\nowidctlpar\adjustright {\b\f17\fs28 \'aelvn 58 : 1999
\par }\pard \s16\qj\nowidctlpar\adjustright {\b\fs28 
\par 
\par 5 Tr\'d7nh b\'b5y b\'b6ng dung t\'ddch
\par }{
\par B\'b6ng dung t\'ddch cho xit\'d0c n\'bbm ngang \'ae\'ad\'eec l\'cbp g\'e5m 2 ph\'c7n:
\par - Trang b\'d7a g\'e5m c\'b8c n\'e9i dung sau: c\'b8c \'ae\'c6c tr\'adng k\'fc thu\'cbt v\'b5 \'aeo l\'ad\'eang, s\'e8 hi\'d6u, v\'de tr\'dd l\'bep \'ae\'c6t, c\'ac quan l\'cbp b\'b6ng,... theo m\'c9u \'eb ph\'f4 l\'f4c 2}{\b  }{(\'ae\'e8i v\'edi xit\'d0c 
\'ae\'ad\'eec l\'cbp theo ph\'ad\'acng ph\'b8p h\'d7nh h\'e4c) v\'b5 ph\'f4 l\'f4c 3}{\b  }{(\'ae\'e8i v\'edi xit\'d0c \'ae\'ad\'eec l\'cbp theo ph\'ad\'acng ph\'b8p dung t\'ddch).
\par - C\'b8c trang ti\'d5p theo tr\'d7nh b\'b5y dung t\'ddch c\'f1a xit\'d0c theo t\'f5ng cm chi\'d2u cao ch\'f8a b\'bet \'ae\'c7u t\'f5 1cm \'ae\'d5n chi\'d2u cao ch\'f8a gi\'edi h\'b9n c\'f1a xit\'d0c theo m\'c9u \'eb ph\'f4 l\'f4c 4.
\par Dung t\'ddch ph\'c7n l\'ce t\'f5ng mm \'ae\'ad\'eec t\'ddnh cho t\'f5ng kho\'b6ng cm v\'b5 \'ae\'ad\'eec tr\'d7nh b\'b5y \'eb c\'e9t b\'aan c\'b9nh c\'e9t bi\'d3u th\'de dung t\'ddch xit\'d0c .
\par 
\par 
\par }{\b\fs28 6 Sai s\'e8 l\'cbp b\'b6ng
\par }{\b\f18 
\par }{Sai s\'e8 l\'edn nh\'cat \'ae\'e8i v\'edi c\'b8c gi\'b8 tr\'de trong b\'b6ng dung t\'ddch \'ae\'ad\'eec l\'cbp theo c\'b8c ph\'ad\'acng ph\'b8p n\'e3i tr\'aan kh\'abng v\'ad\'eet qu\'b8 }{{\field{\*\fldinst SYMBOL 177 \\f "Symbol" \\s 13}{\fldrslt
\f3\fs26}}}{ 0.3 % th\'d3 t\'ddch ch\'d8 th\'de trong ph\'b9m vi \'aeo. 
\par 
\par 
\par }\pard\plain \nowidctlpar\adjustright \f15\fs26 {
