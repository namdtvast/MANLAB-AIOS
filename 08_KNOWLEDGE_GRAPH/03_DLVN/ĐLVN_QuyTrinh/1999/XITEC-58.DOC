\par }{\i\ul Trong \'ae\'e3:}{  
\par V}{\sub t.p}{ l\'b5 dung t\'ddch to\'b5n ph\'c7n danh \'ae\'denh c\'f1a xit\'d0c.
\par }\pard\plain \qj\nowidctlpar\adjustright \f15\fs26 {\i 
\par }{\b\f17\fs28 \'aelvn 58 : 1999
\par }{\b 
\par 4.4 X\'b8c \'ae\'denh s\'e8 hi\'d6u ch\'d8nh do \'ae\'e9 nghi\'aang g\'a9y ra 
\par }{
\par T\'b9i v\'de tr\'dd \'aeo, xit\'d0c c\'e3 th\'d3 b\'de nghi\'aang theo ph\'ad\'acng n\'bbng ngang. Do chi\'d2u cao m\'f8c ch\'cat l\'e1ng \'aeo \'ae\'ad\'eec \'f8ng v\'edi tr\'b9ng th\'b8i nghi\'aang s\'cf kh\'b8c v\'edi tr\'ad\'eang h\'eep xit\'d0c ho
\'b5n to\'b5n n\'bbm ngang. Khi l\'cbp b\'b6ng dung t\'ddch ph\'b6i t\'ddnh to\'b8n chi\'d2u cao l\'cbp b\'b6ng \'f8ng v\'edi tr\'b9ng th\'b8i ho\'b5n to\'b5n n\'bbm ngang. V\'d7 v\'cby c\'c7n ph\'b6i x\'b8c \'ae\'denh s\'e8 hi\'d6u ch\'d8nh \'ae\'e9 nghi
\'aang do m\'c6t b\'bbng \'eb v\'de tr\'dd \'ae\'e3 g\'a9y ra v\'b5 hi\'d6u ch\'d8nh v\'b5o k\'d5t qu\'b6 chi\'d2u cao m\'f8c ch\'cat l\'e1ng \'aeo \'ae\'ad\'eec \'ae\'d3 c\'e3 \'ae\'ad\'eec chi\'d2u cao t\'ddnh to\'b8n l\'cbp b\'b6ng. 
\par }\pard\plain \s16\qj\nowidctlpar\adjustright \f15\fs26 {\'a7\'e9 nghi\'aang c\'f1a xit\'d0c theo ph\'ad\'acng n\'bbm ngang \'ae\'ad\'eec x\'b8c \'ae\'denh b\'bbng c\'b8ch \'aeo ch\'aanh l\'d6ch \'ae\'e9 cao c\'f1a 2 \'ae\'c7u xit\'d0c tr\'aan \'ae\'ad\'ea
ng sinh th\'cap nh\'cat ho\'c6c cao nh\'cat theo 2 ph\'ad\'acng ph\'b8p d\'ad\'edi \'ae\'a9y:
\par 
\par a) \'a7o \'eb b\'aan trong xit\'d0c
\par \'a7\'e6 v\'b5o xit\'d0c m\'e9t l\'ad\'eeng n\'ad\'edc \'ae\'f1 \'ae\'d3 ph\'f1 k\'ddn h\'d5t \'ae\'ad\'eang sinh th\'cap nh\'cat c\'f1a xit\'d0c. Sau \'ae\'e3 \'aeo chi\'d2u cao m\'f8c n\'ad\'edc t\'b9i 2 \'aei\'d3m s\'b8t 2 \'ae\'c7u xit\'d0c tr\'aan 
\'ae\'ad\'eang sinh th\'cap nh\'cat t\'ad\'acng \'f8ng v\'edi v\'de tr\'dd c\'b8c \'aei\'d3m m\'e8c \'aeo chi\'d2u d\'b5i ph\'c7n tr\'f4. Hi\'d6u m\'f8c n\'ad\'edc cho ta ch\'aanh l\'d6ch \'ae\'e9 cao c\'f1a 2 \'ae\'c7u xit\'d0c. 
\par 
\par b) \'a7o \'eb ph\'dda ngo\'b5i xit\'d0c 
\par Cho n\'ad\'edc s\'b9ch v\'b5o th\'ad\'edc \'e8ng thu\'fb, kh\'f6 b\'e4t kh\'dd trong c\'b8c \'e8ng d\'c9n v\'b5 \'ae\'c6t 2 th\'ad\'edc c\'b9nh nhau \'ae\'d3 x\'b8c \'ae\'denh v\'de tr\'dd c\'a9n b\'bbng ban \'ae\'c7u. C\'c7n \'aei\'d2u ch\'d8nh sao cho m
\'f8c n\'ad\'edc tr\'aan c\'b8c \'e8ng thu\'fb \'eb v\'b5o kho\'b6ng gi\'f7a c\'f1a thang \'aeo.
\par \'a7\'c6t th\'ad\'edc \'e8ng thu\'fb v\'b5o hai \'aei\'d3m t\'ad\'acng \'f8ng v\'edi c\'b8c \'aei\'d3m m\'e8c \'aeo chi\'d5u d\'b5i ph\'c7n tr\'f4 c\'f1a    xit\'d0c tr\'aan \'ae\'ad\'eang sinh cao nh\'cat. 
\par \'a7\'e9 nghi\'aang c\'f1a xit\'d0c l\'b5 ch\'aanh l\'d6ch m\'f8c n\'ad\'edc \'aeo \'ae\'ad\'eec t\'b9i hai \'ae\'c7u xit\'d0c. 
\par 
\par S\'e8 hi\'d6u ch\'ddnh do \'ae\'e9 nghi\'aang c\'f1a xit\'d0c g\'a9y ra \'ae\'ad\'eec t\'ddnh theo c\'abng th\'f8c:
\par 
\par }\pard \s16\nowidctlpar\adjustright {                                                        }{{\field{\*\fldinst SYMBOL 68 \\f "Symbol" \\s 13}{\fldrslt\f3\fs26}}}{h         L
