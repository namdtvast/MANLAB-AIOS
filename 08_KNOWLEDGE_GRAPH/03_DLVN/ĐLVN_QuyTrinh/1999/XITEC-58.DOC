\par }\pard\plain \s2\keepn\nowidctlpar\outlinelevel1\adjustright \i\f15\fs26 {\b\fs28 Rail tankers - Methods and means of calibration
\par }\pard\plain \nowidctlpar\adjustright \f15\fs26 {\b\fs28 
\par 
\par 1 Ph\'b9m vi \'b8p d\'f4ng 
\par }{\b 
\par }\pard \qj\nowidctlpar\adjustright {V\'a8n b\'b6n k\'fc thu\'cbt n\'b5y quy \'ae\'denh ph\'ad\'acng ph\'b8p v\'b5 ph\'ad\'acng ti\'d6n l\'cbp b\'b6ng dung t\'ddch \'eb v\'de }{\expnd0\expndtw-4 tr\'dd n\'bbm ngang cho c\'b8c xit\'d0c \'ae\'ad\'eang s\'be
t (g\'e4i t\'bet l\'b5 xit\'d0c) dung t\'ddch danh \'ae\'denh (10 }{\expnd0\expndtw-4 {\field{\*\fldinst SYMBOL 184 \\f "Symbol" \\s 13}{\fldrslt\f3\fs26}}}{\expnd0\expndtw-4  120) m}{\expnd0\expndtw-4\super 3}{ c\'e3 c\'b8c ch\'d8 ti\'aau k\'fc thu\'cb
t v\'b5 \'aeo l\'ad\'eang ph\'ef h\'eep v\'edi quy \'ae\'denh trong ph\'f4 l\'f4c 1.
\par 
\par }{\b\fs28 2 C\'b8c kh\'b8i ni\'d6m, \'ae\'denh ngh\'dca 
\par }{\b 
\par 2.1 H\'d7nh d\'b8ng v\'b5 k\'d5t c\'cau c\'ac b\'b6n 
\par }{
\par M\'e7i xit\'d0c bao g\'e5m: th\'a9n v\'b5 c\'b8c \'ae\'c7u xit\'d0c; c\'e6 xit\'d0c; c\'b8c thi\'d5t b\'de ph\'f4c v\'f4 vi\'d6c giao nh\'cbn h\'b5ng ho\'b8.
\par 
\par }\pard\plain \s15\qj\nowidctlpar\adjustright \f15\fs26 {2.1.1 Ph\'c7n th\'a9n c\'e3 d\'b9ng h\'d7nh tr\'f4, ti\'d5t di\'d6n tr\'dfn g\'e5m nhi\'d2u t\'c7ng \'ae\'ad\'eec h\'b5n n\'e8i li\'aan ti\'d5p nhau; hai \'ae\'c7u c\'e3 d\'b9ng ph\'bcng ho\'c6c l
\'e5i h\'d7nh ch\'e1m c\'c7u ho\'c6c n\'e3n. Xit\'d0c \'ae\'ad\'eec ch\'d5 t\'b9o t\'f5 c\'b8c t\'cam th\'d0p cu\'e9n c\'e3 k\'d5t c\'cau v\'f7ng ch\'bec \'ae\'b6m b\'b6o kh\'abng b\'de thay \'ae\'e6i dung t\'ddch trong qu\'b8 tr\'d7nh s\'f6 d\'f4ng. T
\'b9i n\'aci th\'ddch h\'eep xit\'d0c \'ae\'ad\'eec l\'bep van th\'eb v\'b5 ch\'e8ng s\'d0t. Xit\'d0c \'ae\'ad\'eec l\'bep \'ae\'c6t n\'bbm ngang tr\'aan khung ho\'c6c tr\'aan c\'b8c gi\'b8 \'ae\'ec chuy\'aan d\'efng trong v\'cbn chuy\'d3n \'ae\'ad\'ea
ng s\'bet. 
\par }\pard\plain \qj\nowidctlpar\adjustright \f15\fs26 {
\par 2.1.2 C\'e6 xit\'d0c c\'e3 d\'b9ng h\'d7nh tr\'f4 \'ae\'f8ng v\'b5 c\'e3 n\'bep \'ae\'cby k\'ddn \'ae\'ad\'eec l\'bep \'ae\'c6t th\'bcng \'ae\'f8ng ph\'dda tr\'aan \'ae\'ad\'eang sinh cao nh\'cat c\'f1a ph\'c7n tr\'f4. C\'e6 xit\'d0c d\'efng \'ae\'d3 l
\'b5m c\'f6a ra v\'b5o, l\'e7 n\'b9p nhi\'aan li\'d6u v\'b5 l\'e7 \'aeo m\'f8c ch\'cat l\'e1ng.     
\par 
\par 2.1.3 C\'b8c thi\'d5t b\'de ph\'f4c v\'f4 giao nh\'cbn bao g\'e5m: l\'e7 x\'b6, \'e8ng x\'b6, van ch\'c6n v\'b5 mi\'d6ng x\'b6. L\'e7 x\'b6 ph\'b6i b\'e8 tr\'dd \'eb ph\'c7n th\'cap nh\'cat c\'f1a xit\'d0c v\'b5 g\'c7n 2 \'ae\'c7u; \'e8ng x\'b6 c\'e3 \'ae
\'e9 d\'e8c c\'c7n thi\'d5t \'ae\'d3 \'ae\'b6m b\'b6o x\'b6 h\'d5t ch\'cat l\'e1ng, mi\'d6ng x\'b6 c\'e3 van \'ae\'e3ng k\'ddn. 
\par Xit\'d0c ph\'b6i c\'e3 c\'c7u thang, s\'b5n thao t\'b8c \'ae\'d3 c\'e3 th\'d3 th\'f9c hi\'d6n ph\'d0p \'aeo, ki\'d3m tra \'ae\'ad\'eec thu\'cbn ti\'d6n. 
\par 
\par }{\b 2.2 Dung t\'ddch danh \'ae\'denh 
\par }{
\par L\'b5 th\'d3 t\'ddch c\'f1a ch\'cat l\'e1ng ch\'f8a \'ae\'ad\'eec trong xit\'d0c \'eb \'aei\'d2u ki\'d6n v\'cbn h\'b5nh t\'b9i nhi\'d6t \'ae\'e9 ti\'aau chu\'c8n quy \'ae\'denh.
\par 
\par }{\b 2.3 Dung t\'ddch to\'b5n ph\'c7n 
\par }{
\par L\'b5 th\'d3 t\'ddch t\'e8i \'aea c\'f1a ch\'cat l\'e1ng m\'b5 xit\'d0c c\'e3 th\'d3 ch\'f8a t\'edi khi tr\'b5n \'eb \'aei\'d2u ki\'d6n v\'cbn h\'b5nh t\'b9i  nhi\'d6t \'ae\'e9 ti\'aau chu\'c8n quy \'ae\'denh. }{\i 
\par }{\b\f17\fs28 \'aelvn 58 : 1999
\par }{\i 
\par }{\b 2.4 Dung t\'ddch gi\'b7n n\'eb 
\par }{
\par L\'b5 hi\'d6u s\'e8 gi\'f7a dung t\'ddch to\'b5n ph\'c7n v\'b5 dung t\'ddch danh \'ae\'denh. 
\par }{\i 
\par }{\b 2.5 Tr\'f4c \'aeo th\'bcng \'ae\'f8ng 
\par }{\i 
\par }{L\'b5 \'ae\'ad\'eang th\'bcng \'ae\'f8ng \'aei qua t\'a9m c\'f1a c\'e6 xit\'d0c m\'b5 tr\'aan \'ae\'e3 c\'b8c m\'f8c ch\'cat l\'e1ng \'ae\'ad\'eec x\'b8c \'ae\'denh. 
\par 
\par }{\b 2.6 \'a7i\'d3m m\'e8c (p)
\par }{
\par L\'b5 \'aei\'d3m n\'bbm tr\'aan tr\'f4c \'aeo th\'bcng \'ae\'f8ng v\'b5 l\'e7 \'aeo \'ae\'ad\'eec s\'f6 d\'f4ng l\'b5m \'aei\'d3m m\'e8c \'ae\'d3 \'aeo chi\'d2u cao m\'f8c ch\'cat l\'e1ng trong xit\'d0c. 
\par }{\i 
\par }{\b 2.7 Chi\'d2u cao ki\'d3m tra (H}{\b\sub max}{\b )
\par }{
\par L\'b5 kho\'b6ng c\'b8ch \'aeo theo tr\'f4c \'aeo th\'bcng \'ae\'f8ng gi\'f7a \'aei\'d3m m\'e8c (p) v\'b5 \'aei\'d3m th\'cap nh\'cat n\'bbm tr\'aan m\'c6t trong c\'f1a xit\'d0c.
\par 
\par }{\b 2.8 B\'b6ng dung t\'ddch 
\par }{
\par L\'b5 s\'f9 tr\'d7nh b\'b5y \'eb d\'b9ng b\'b6ng c\'f1a h\'b5m to\'b8n h\'e4c V(H) th\'d3 hi\'d6n m\'e8i quan h\'d6 gi\'f7a chi\'d2u cao ch\'f8a H ( bi\'d5n \'ae\'e9c l\'cbp ) v\'b5 dung t\'ddch ch\'f8a V (bi\'d5n ph\'f4 thu\'e9c).
\par 
\par }{\b 2.9 Chi\'d2u cao ch\'f8a gi\'edi h\'b9n (H}{\b\sub gh}{\b )
\par }{
\par L\'b5 chi\'d2u cao \'f8ng v\'edi m\'f8c ch\'f8a gi\'edi h\'b9n c\'f1a xit\'d0c.
\par }{\b 
\par 2.10 V\'cbt cho\'b8n ch\'e7
\par }{
\par L\'b5 b\'cat k\'fa chi ti\'d5t n\'b5o \'b6nh h\'ad\'ebng t\'edi dung t\'ddch c\'f1a xit\'d0c. V\'cbt cho\'b8n ch\'e7 \'ae\'ad\'eec coi l\'b5 d\'ad\'acng (+) khi th\'d3 t\'ddch c\'f1a n\'e3 \'ae\'ad\'eec c\'e9ng th\'aam v\'b5o dung t\'ddch danh \'ae\'de
nh c\'f1a xit\'d0c v\'b5 coi l\'b5 \'a9m (-) khi th\'d3 t\'ddch c\'f1a n\'e3 l\'b5m gi\'b6m dung t\'ddch danh \'ae\'denh c\'f1a xit\'d0c.}{\b 
\par 
\par 2.11 V\'efng l\'cbp b\'b6ng
\par }{
\par L\'b5 ph\'b9m vi dung t\'ddch c\'f1a xit\'d0c \'ae\'ad\'eec l\'cbp b\'b6ng t\'f5 v\'efng \'ae\'b8y t\'edi dung t\'ddch danh \'ae\'denh.
\par }\pard\plain \s16\qj\nowidctlpar\adjustright \f15\fs26 {\b 
\par 2.12 Th\'d3 t\'ddch \'aeo t\'e8i thi\'d3u (V}{\b\sub min}{\b )
\par 
\par }{L\'b5 th\'d3 t\'ddch \'f8ng v\'edi c\'e9t ch\'cat l\'e1ng c\'e3 chi\'d2u cao 200 mm t\'b9i ph\'c7n c\'e3 ti\'d5t di\'d6n ngang l\'edn nh\'cat c\'f1a xit\'d0c. Kh\'b8i ni\'d6m c\'f4 th\'d3 v\'b5 c\'b8ch t\'ddnh th\'d3 t\'ddch \'aeo t\'e8i thi\'d3u \'ae
\'ad\'eec m\'ab t\'b6 trong ph\'f4 l\'f4c 5.
\par }\pard\plain \qj\nowidctlpar\adjustright \f15\fs26 {
\par }{\b\fs28 3 L\'cbp b\'b6ng dung t\'ddch b\'bbng ph\'ad\'acng ph\'b8p h\'d7nh h\'e4c 
\par }{\i 
\par 
\par }\pard \qr\nowidctlpar\adjustright {\b\f17\fs28 \'aelvn 58 : 1999
\par }{\i 
\par }\pard \qj\nowidctlpar\adjustright {\b 3.1 C\'b8c th\'abng s\'e8 c\'ac b\'b6n c\'f1a xit\'d0c c\'c7n x\'b8c \'ae\'denh 
\par }{
\par - \'a7\'ad\'eang k\'ddnh, D: Gi\'b8 tr\'de trung b\'d7nh c\'f1a \'ae\'ad\'eang k\'ddnh trong c\'b8c t\'c7ng c\'f1a xit\'d0c;
\par - Chi\'d2u d\'b5i, L: Chi\'d2u d\'b5i trong trung b\'d7nh ph\'c7n tr\'f4 c\'f1a xit\'d0c;
\par - Chi\'d2u cao \'ae\'c7u, f: Chi\'d2u cao trung b\'d7nh c\'f1a \'ae\'c7u xit\'d0c;
\par - Chi\'d2u cao ki\'d3m tra, H}{\sub max}{;
\par - Chi\'d2u cao ch\'f8a gi\'edi h\'b9n, H}{\sub gh}{.}{\i 
\par 
\par }{\b 3.2 Ph\'ad\'acng ti\'d6n \'aeo 
\par }{\i 
\par }{- Th\'ad\'edc th\'d0p cu\'e9n, gi\'b8 tr\'de \'ae\'e9 chia 1 mm;
\par - Th\'ad\'edc \'aeo trong, gi\'b8 tr\'de \'ae\'e9 chia 1 mm;
\par - Th\'ad\'edc v\'b9ch, gi\'b8 tr\'de \'ae\'e9 chia 1 mm;
\par - Th\'ad\'edc \'e8ng thu\'fb, gi\'b8 tr\'de \'ae\'e9 chia 1 mm;
\par - Th\'ad\'edc cu\'e9n c\'e3 qu\'b6 r\'e4i, gi\'b8 tr\'de \'ae\'e9 chia 1 mm;
\par - M\'b8y \'aeo b\'d2 d\'b5y kim lo\'b9i, \'ae\'e9 ch\'ddnh x\'b8c 0,1 mm.
\par }\pard\plain \s16\qj\nowidctlpar\adjustright \f15\fs26 {\b 
\par 3.3  X\'b8c \'ae\'denh \'ae\'ad\'eang k\'ddnh trong trung b\'d7nh c\'f1a xit\'d0c 
\par }{
\par 3.3.1 \'a7o \'eb b\'aan trong xit\'d0c
\par 
\par Ph\'ad\'acng ti\'d6n \'aeo l\'b5 th\'ad\'edc \'aeo trong c\'e3 gi\'b8 tr\'de \'ae\'e9 chia 1 mm v\'b5 c\'b8c thi\'d5t b\'de g\'b8 th\'ddch h\'eep \'ae\'d3 \'ae\'b6m b\'b6o \'aeo \'ae\'f3ng \'ae\'ad\'eang k\'ddnh ti\'d5t di\'d6n ngang c\'f1a xit\'d0c.

\par }{\expnd0\expndtw4 M\'e7i t\'c7ng c\'f1a xit\'d0c \'ae\'ad\'eec \'aeo t\'b9i 2 ti\'d5t di\'d6n c\'b8ch \'ae\'d2u m\'e8i gh\'d0p gi\'f7a c\'b8c t\'c7ng kho\'b6ng 1/3 b\'d2 r\'e9ng c\'f1a t\'c7ng \'ae\'e3. T\'b9i m\'e7i ti\'d5t di\'d6n \'aeo theo hai h\'ad
\'edng vu\'abng g\'e3c v\'edi nhau.}{ \'a7\'ad\'eang k\'ddnh theo m\'e7i h\'ad\'edng \'ae\'ad\'eec \'aeo hai l\'c7n. Sai l\'d6ch gi\'f7a hai l\'c7n \'aeo kh\'abng \'ae\'ad\'eec v\'ad\'eet qu\'b8 2 mm. \'a7\'ad\'eang k\'ddnh trong c\'f1a ti\'d5t di\'d6n 
\'ae\'ad\'eec t\'ddnh b\'bbng gi\'b8 tr\'de trung b\'d7nh c\'f1a c\'b8c ph\'d0p \'aeo theo hai h\'ad\'edng vu\'abng g\'e3c n\'aau tr\'aan.
\par }\pard \s16\nowidctlpar\adjustright {C\'b8ch \'aeo \'ae\'ad\'eec m\'ab t\'b6 tr\'aan h\'d7nh 2.
\par 
\par 
\par 
\par }{\lang1024\cgrid {\shp{\*\shpinst\shpleft3317\shptop92\shpright5313\shpbottom2658\shpfhdr0\shpbxcolumn\shpbypara\shpwr3\shpwrk0\shpfblwtxt0\shpz143\shplid1171{\sp{\sn shapeType}{\sv 20}}{\sp{\sn fFlipH}{\sv 1}}{\sp{\sn fFlipV}{\sv 0}}
