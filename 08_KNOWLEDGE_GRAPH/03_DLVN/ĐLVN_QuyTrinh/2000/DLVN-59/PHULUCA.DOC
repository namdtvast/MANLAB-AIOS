\par }{\f49\fs18 
\par }\pard\plain \s16\qc \b\f18\fs28 {\f25 B\'d7nh chu\'c8n b\'bbng thu\'fb tinh
\par Y\'a3U C\'c7U K\'fc THU\'cbT V\'b5 \'a7O L\'a6\'eaNG C\'a5 B\'b6N
\par }\pard\plain \qj \f15\fs28 {\fs26 
\par }{\b 1 \'a7\'denh ngh\'dca
\par }\pard\plain \s20\qj \f15\fs26 
\par \pard\plain \qj \f15\fs28 {\b\fs26 1.1 Dung t\'ddch  
\par }{\fs26 
\par 1.1.1 Dung t\'ddch \ldblquote \'ae\'e6 v\'b5o\rdblquote  c\'f1a b\'d7nh chu\'c8n dung t\'ddch b\'bbng thu\'fb tinh (g\'e4i t\'bet l\'b5 b\'d7nh chu\'c8n) \'f8ng v\'edi m\'e9t v\'b9ch d\'cau tr\'aan thang \'aeo l\'b5 th\'d3 t\'ddch n\'ad\'edc m\'b5 b\'d7
nh ch\'f8a \'ae\'ad\'eec t\'b9i nhi\'d6t \'ae\'e9 ti\'aau chu\'c8n khi \'ae\'ad\'eec n\'b9p \'ae\'c7y t\'edi v\'b9ch d\'cau \'ae\'e3.
\par }{\i\fs26 
\par }{\fs26 1.1.2 Dung t\'ddch \ldblquote \'ae\'e6  ra\rdblquote  c\'f1a b\'d7nh chu\'c8n \'f8ng v\'edi m\'e9t v\'b9ch d\'cau tr\'aan thang \'aeo l\'b5  th\'d3 t\'ddch  n\'ad\'edc \'ae\'e6 ra t\'f5 b\'d7nh chu\'c8n t\'b9i nhi\'d6t \'ae\'e9 ti\'aau chu\'c8
n sau khi \'ae\'ad\'eec n\'b9p \'ae\'c7y t\'edi v\'b9ch d\'cau  \'ae\'e3 r\'e5i \'ae\'e6 ra.
\par  
\par }{\i\fs26\ul Ghi ch\'f3:}{\i\fs26  C\'a9u "n\'b9p \'ae\'c7y \'ae\'d5n v\'b9ch d\'cau" c\'e3 ngh\'dca l\'b5 m\'c6t cong c\'f1a n\'ad\'edc trong c\'e6 b\'d7nh chu\'c8n \'ae\'ad\'eec \'aei\'d2u ch\'d8nh sao cho m\'c6t ph\'bcng ngang \'aei qua m\'d0p tr\'aa
n c\'f1a v\'b9ch d\'cau l\'b5 ti\'d5p tuy\'d5n v\'edi \'aei\'d3m th\'cap nh\'cat c\'f1a m\'c6t cong khi quan s\'b8t trong m\'c6t ph\'bcng n\'b5y.
\par }{\fs26 
\par }{\b\fs26 1.2 Dung t\'ddch danh \'ae\'denh
\par }{\fs26 
\par Dung t\'ddch danh \'ae\'denh  c\'f1a b\'d7nh chu\'c8n l\'b5 gi\'b8 tr\'de th\'d3 t\'ddch d\'efng \'ae\'d3 k\'fd hi\'d6u cho b\'d7nh chu\'c8n  (xem m\'f4c 2.2).
\par 
\par }{\b 2 Dung t\'ddch danh \'ae\'denh
\par }{\fs26 
\par }{\b\fs26 2.1 \'a7\'acn v\'de
\par }{\fs26 
\par \'a7\'acn v\'de c\'f1a dung t\'ddch l\'b5 centimet kh\'e8i (cm}{\fs26\super 3}{\fs26 ) ho\'c6c decimet kh\'e8i (dm}{\fs26\super 3}{\fs26 ). C\'e3 th\'d3 s\'f6 d\'f4ng \'ae\'acn v\'de \ldblquote mililit\rdblquote   (mL) v\'b5 \ldblquote l\'ddt\rdblquote 
 (L) thay cho centimet kh\'e8i v\'b5 decimet kh\'e8i.
\par }{\b\i\fs26 
\par }{\b\fs26 2.2 C\'b8c gi\'b8 tr\'de
\par }{\fs26 
\par a) B\'d7nh chu\'c8n ph\'b6i c\'e3 m\'e9t trong c\'b8c dung t\'ddch danh \'ae\'denh sau: 1 x 10}{\fs26\super n }{\fs26 dm}{\fs26\super 3}{\fs26 , 2 x 10}{\fs26\super n }{\fs26 dm}{\fs26\super 3}{\fs26  ho\'c6c 5  x 10}{\fs26\super n }{\fs26 dm}{
\fs26\super 3}{\fs26 , trong \'ae\'e3 n l\'b5 s\'e8 d\'ad\'acng, \'a9m ho\'c6c b\'bbng kh\'abng.
\par 
\par }{\fs26\expnd1\expndtw8 b) \'a7\'e8i v\'edi nhu c\'c7u s\'f6 d\'f4ng \'ae\'c6c bi\'d6t, b\'d7nh chu\'c8n c\'e3 th\'d3 c\'e3 dung t\'ddch danh \'ae\'denh b\'bbng 250 cm}{\fs26\expnd1\expndtw8\super 3}{\fs26\expnd1\expndtw8  v\'b5 2,5 dm}{
\fs26\expnd1\expndtw8\super 3}{\fs26\expnd1\expndtw8 .
\par }\pard\plain \s20\qj \f15\fs26 
\par \pard\plain \qj \f15\fs28 {\b\fs26 2.3 Nhi\'d6t \'ae\'e9 ti\'aau chu\'c8n
\par }{\fs26 
\par Nhi\'d6t \'ae\'e9 ti\'aau chu\'c8n l\'b5 nhi\'d6t \'ae\'e9  m\'b5 t\'b9i \'ae\'e3 th\'d3 t\'ddch n\'ad\'edc \'ae\'e6 v\'b5o ho\'c6c \'ae\'e6 ra t\'ad\'acng \'f8ng v\'edi  dung t\'ddch danh \'ae\'denh c\'f1a n\'e3. Nhi\'d6t \'ae\'e9 n\'b5y \'ae\'ad\'eec l
\'cay b\'bbng 20 }{\fs26\super o}{\fs26 C.
\par }{\b 3 V\'cbt li\'d6u
\par }{\fs26 
\par }{\b\fs26 3.1}{\fs26  B\'d7nh chu\'c8n ph\'b6i \'ae\'ad\'eec ch\'d5 t\'b9o b\'bbng thu\'fb tinh s\'b9ch, trong su\'e8t, \'ae\'ad\'eec gia c\'abng t\'e8t v\'b5 c\'e3 c\'b8c \'ae\'c6c t\'ddnh v\'d2 nhi\'d6t \'ae\'e9 v\'b5 ho\'b8 h\'e4c th\'ddch h\'eep.

\par 
\par }{\b\fs26 3.2}{\fs26  Thu\'fb tinh kh\'abng \'ae\'ad\'eec c\'e3 c\'b8c khuy\'d5t t\'cbt l\'b5m \'b6nh h\'ad\'ebng \'ae\'d5n vi\'d6c quan s\'b8t ho\'c6c s\'f6 d\'f4ng b\'d7nh chu\'c8n, \'ae\'c6c bi\'d6t t\'b9i v\'efng l\'a9n c\'cbn c\'f1a c\'b8c v\'b9ch d
\'cau tr\'aan thang \'aeo.
\par 
\par }{\b 4 K\'d5t c\'cau, h\'d7nh d\'b9ng v\'b5 k\'ddch th\'ad\'edc
\par }{\fs26 
\par }{\b\fs26 4.1}{\b\i\fs26  }{\fs26  B\'d7nh chu\'c8n ph\'b6i c\'e3 k\'d5t c\'cau b\'d2n v\'f7ng \'ae\'d3 ch\'deu \'ae\'ad\'eec \'aei\'d2u ki\'d6n s\'f6 d\'f4ng b\'d7nh th\'ad\'eang.
\par \'a7\'e9 d\'b5y th\'b5nh b\'d7nh \'eb b\'cat k\'fa v\'de tr\'dd n\'b5o \'ae\'d2u kh\'abng \'ae\'ad\'eec nh\'e1 h\'acn gi\'b8 tr\'de cho trong b\'b6ng A1. 
\par }{\b\i\fs26 
\par }{\b\fs26 4.2}{\fs26  C\'e6 b\'d7nh chu\'c8n ph\'b6i c\'e3 d\'b9ng h\'d7nh tr\'f4.
\par \'a7\'ad\'eang k\'ddnh trong ph\'c7n kh\'bec \'ae\'e9 c\'f1a c\'e6 kh\'abng \'ae\'ad\'eec v\'ad\'eet qu\'b8 gi\'edi h\'b9n cho trong b\'b6ng A1}{\b\i\fs26 .
\par }{\fs26 
\par }{\b\fs26 4.3}{\fs26  B\'d7nh chu\'c8n ph\'b6i \'ae\'f8ng v\'f7ng \'ae\'ad\'eec theo ph\'ad\'acng th\'bcng \'ae\'f8ng khi \'ae\'c6t tr\'aan m\'c6t ph\'bcng n\'bbm ngang.
\par }{\b\i\fs26 
\par }{\b\fs26 4.4 }{\fs26 M\'d0p tr\'aan c\'f1a c\'e6 ph\'b6i nh\'bdn, vu\'abng g\'e3c v\'edi tr\'f4c c\'f1a b\'d7nh chu\'c8n v\'b5 ph\'b6i \'ae\'ad\'eec vi\'d2n m\'d0p.
\par }\pard\plain \s20\qj \f15\fs26 
\par \pard\plain \qj \f15\fs28 {\b\fs26 4.5}{\fs26  H\'d7nh d\'b9ng t\'e6ng qu\'b8t c\'f1a b\'d7nh chu\'c8n c\'e3 dung t\'ddch t\'f5 10 cm}{\fs26\super 3 }{\fs26  \'ae\'d5n 10 dm}{\fs26\super 3 }{\fs26  \'ae\'ad\'eec m\'ab t\'b6 trong h\'d7nh A1}{\b\fs26  }{
\fs26 (ki\'d3u A). C\'b8c b\'d7nh chu\'c8n c\'e3 dung t\'ddch t\'f5 1 dm}{\fs26\super 3  }{\fs26 \'ae\'d5n 10 dm}{\fs26\super 3}{\fs26  c\'e3 th\'d3 c\'e3 h\'d7nh d\'b9ng nh\'ad m\'ab t\'b6 trong h\'d7nh A2 (ki\'d3u B).
\par 
\par 
\par 
\par 
\par 
\par 
\par 
\par 
\par 
\par 
\par 
\par 
\par 
\par                                                                                                                                   
\par 
\par }\pard\plain \s20\qj \f15\fs26 
\par \pard\plain \qj \f15\fs28 {\fs26 
\par 
\par 
\par 
\par 
\par }{\b\fs26 4.6}{\b\i\fs26  }{\fs26 C\'b8c k\'ddch th\'ad\'edc c\'ac b\'b6n c\'f1a b\'d7nh chu\'c8n ph\'b6i  ph\'ef h\'eep v\'edi y\'aau c\'c7u trong b\'b6ng A1}{\b\i\fs26 .}{\b\fs26 
\par }{\fs26 
\par }\pard\plain \s1\qr\keepn \b\f15\fs28 {\i\fs26 B\'b6ng A1} 
