\par }{\i\fs26 (*) h}{\i\fs26\sub 1}{\i\fs26  : kho\'b6ng c\'b8ch gi\'f7a v\'b9ch d\'cau d\'ad\'edi c\'efng v\'b5 \'aei\'d3m cu\'e8i c\'f1a c\'e6 m\'b5 t\'b9i \'ae\'e3 \'ae\'ad\'eang k\'ddnh c\'e6 c\'e3 s\'f9 thay \'ae\'e6i (xem h\'d7nh A1).
\par }{\fs26 
\par }{\b\fs26 4.7 Kh\'bec \'ae\'e9
\par }{\fs26 
\par B\'d7nh chu\'c8n c\'e3 th\'d3 \'ae\'ad\'eec kh\'bec \'ae\'e9 v\'edi m\'e9t v\'b9ch d\'cau \'f8ng v\'edi dung t\'ddch danh \'ae\'denh v\'b5 c\'b8c v\'b9ch d\'cau \'f8ng v\'edi gi\'edi h\'b9n sai s\'e8 cho ph\'d0p l\'edn nh\'cat c\'f1a ph\'ad\'acng ti\'d6n 
\'aeo c\'c7n ki\'d3m \'ae\'denh, ho\'c6c thang \'aeo v\'edi c\'b8c v\'b9ch d\'cau.
\par 
\par }{\b 5 Thang \'aeo, v\'b9ch d\'cau
\par }{\fs26 
\par }\pard\plain \s22\qj \f15\fs28 {\b\fs26 5.1}{\fs26  Thang \'aeo c\'c7n ph\'b6i \'ae\'d2u, c\'b8c v\'b9ch d\'cau ph\'b6i r\'e2 n\'d0t, \'ae\'d2u, c\'e3 \'ae\'e9 d\'b5y b\'bbng nhau v\'b5 kh\'abng v\'ad\'eet qu\'b8  0,3 mm.
\par }\pard\plain \qj \f15\fs28 {\fs26 
\par }{\b\fs26 5.2}{\fs26  C\'b8c v\'b9ch d\'cau ph\'b6i vu\'abng g\'e3c v\'edi  tr\'f4c d\'e4c c\'f1a ph\'c7n kh\'bec \'ae\'e9 c\'f1a b\'d7nh chu\'c8n.
\par 
\par }{\b\fs26 5.3}{\fs26  C\'b8c v\'b9ch d\'cau ph\'b6i \'ae\'ad\'eec kh\'bec \'ae\'e9 tr\'aan c\'e6 c\'f1a b\'d7nh chu\'c8n. Kho\'b6ng c\'b8ch gi\'f7a v\'b9ch tr\'aan c\'efng v\'b5 m\'d0p tr\'aan c\'f1a c\'e6 kh\'abng \'ae\'ad\'eec nh\'e1 h\'acn 10 mm.

\par 
\par Kho\'b6ng c\'b8ch gi\'f7a v\'b9ch d\'ad\'eai c\'efng v\'b5 \'aei\'d3m d\'ad\'edi c\'f1a c\'e6 t\'b9i n\'aci c\'e6 b\'bet \'ae\'c7u m\'eb r\'e9ng kh\'abng \'ae\'ad\'eec nh\'e1 h\'acn c\'b8c gi\'b8 tr\'de cho trong b\'b6ng A1.
\par }{\b\fs26 5.4}{\fs26  V\'b9ch d\'cau \'f8ng v\'edi dung t\'ddch danh \'ae\'denh \ldblquote \'ae\'e6 v\'b5o\rdblquote  ho\'c6c \ldblquote \'ae\'e6 ra\rdblquote  c\'c7n ph\'b6i k\'d0o d\'b5i \'ddt nh\'cat l\'b5 9/10 chu vi c\'e6 v\'b5 li\'d2n n\'d0t. N\'d5
u c\'e3 s\'f9 ng\'bet qu\'b7ng n\'b5o \'ae\'e3 tr\'aan v\'b9ch n\'b5y th\'d7 n\'e3 ph\'b6i n\'bbm tr\'aan \'ae\'ad\'eang sinh b\'aan c\'b9nh c\'f1a c\'e6 khi nh\'d7n v\'b5o b\'d7nh chu\'c8n t\'f5 ph\'dda tr\'ad\'edc.
\par 
\par }{\b\fs26 5.5}{\b\i\fs26  }{\fs26 B\'d7nh chu\'c8n c\'e3 th\'d3 \'ae\'ad\'eec kh\'bec \'ae\'e9 b\'bbng c\'b8c v\'b9ch d\'cau bi\'d3u th\'de dung t\'ddch \ldblquote \'ae\'e6 v\'b5o\rdblquote  ho\'c6c \ldblquote \'ae\'e6 ra\rdblquote .
\par  
\par }{\b\fs26 5.6}{\fs26  Kho\'b6ng kh\'bec \'ae\'e9 c\'f1a thang \'aeo \'eb ph\'dda tr\'aan v\'b5 d\'ad\'edi v\'b9ch d\'cau dung t\'ddch danh \'ae\'denh (\ldblquote \'ae\'e6 v\'b5o\rdblquote  ho\'c6c \ldblquote \'ae\'e6 ra\rdblquote ) ph\'b6i ph\'ef h\'eep v
\'edi c\'b8c y\'aau c\'c7u trong b\'b6ng A2.
\par }\pard \qc {\b\i\fs26 
\par }\pard \qr {\b\i\fs26 B\'b6ng A2
\par }\pard \qc {\b Thang \'aeo}{\b\fs26 
\par }\pard \qj {\fs26 
