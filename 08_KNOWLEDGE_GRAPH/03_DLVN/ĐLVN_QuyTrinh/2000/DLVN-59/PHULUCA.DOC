\clbrdrr\brdrs\brdrw15 \cellx5796\clbrdrl\brdrs\brdrw15 \clbrdrb\brdrs\brdrw15 \clbrdrr\brdrs\brdrw15 \cellx9781 \pard \qc\intbl {\fs26 \cell \cell \cell }\pard \intbl {\fs26 \row }\pard \qj {\fs26 
\par B\'d7nh chu\'c8n c\'e3 c\'abng d\'f4ng \'ae\'c6c bi\'d6t
\par 
\par }\trowd \trgaph108\trleft-108\trbrdrt\brdrs\brdrw30 \trbrdrl\brdrs\brdrw30 \trbrdrb\brdrs\brdrw30 \trbrdrr\brdrs\brdrw30 \trbrdrh\brdrs\brdrw30 \trbrdrv\brdrs\brdrw30 \clbrdrt\brdrs\brdrw15 \clbrdrl\brdrs\brdrw15 \clbrdrb\brdrs\brdrw15 \clbrdrr
\brdrs\brdrw15 \cellx2844\clbrdrt\brdrs\brdrw15 \clbrdrl\brdrs\brdrw15 \clbrdrb\brdrs\brdrw15 \clbrdrr\brdrs\brdrw15 \cellx5796\clbrdrt\brdrs\brdrw15 \clbrdrl\brdrs\brdrw15 \clbrdrb\brdrs\brdrw15 \clbrdrr\brdrs\brdrw30 \cellx9781 \pard \qc\intbl {\fs26 
250 cm}{\fs26\super 3}{\fs26 
\par 2,5 dm}{\fs26\super 3}{\fs26 \cell 0,3
\par 1,4\cell 0,10
\par 0,40\cell }\pard \intbl {\fs26 \row }\pard \qj {\b 
\par 7 Ghi nh\'b7n
\par }\pard\plain \s20\qj \f15\fs26 
\par \pard\plain \qj \f15\fs28 {\b\fs26 7.1}{\fs26  Tr\'aan th\'b5nh b\'d7nh chu\'c8n \'eb ph\'dda ngo\'b5i c\'e6 ph\'b6i ghi kh\'bec c\'b8c n\'e9i dung sau :
\par }\pard \qj\fi720 {\fs26 a) M\'e9t ho\'c6c nhi\'d2u ch\'f7 c\'b8i th\'ddch h\'eep bi\'d3u th\'de r\'bbng b\'d7nh chu\'c8n;
\par b) }{\f16\fs26 D}{\fs26 ung t\'ddch danh \'ae\'denh b\'bbng ch\'f7 s\'e8 }{\f16\fs26 \'b6}{\fs26  r\'cbp k\'ccm theo k\'fd hi\'d6u cm}{\fs26\super 3}{\fs26  (hay ml) ho\'c6c dm}{\fs26\super 3}{\fs26  (ho\'c6c L);
\par c) K\'fd hi\'d6u "20 }{\fs26\super 0}{\fs26 C" \'ae\'d3 bi\'d3u th\'de nhi\'d6t \'ae\'e9 ti\'aau chu\'c8n;
\par d) T\'aan ho\'c6c k\'fd hi\'d6u c\'f1a c\'ac s\'eb s\'b6n xu\'cat;
\par f) S\'e8 ch\'d5 t\'b9o c\'f1a b\'d7nh chu\'c8n.
\par }\pard \qj {\b\i\fs26 
\par }{\b\fs26 7.2}{\b\i\fs26   }{\fs26 Tr\'aan c\'e6 b\'d7nh chu\'c8n ph\'b6i ghi kh\'bec c\'b8c n\'e9i dung sau :
\par }\pard\plain \s17\qj\fi720 \f15\fs26 a) K\'fd hi\'d6u \ldblquote In\rdblquote  \'ae\'e8i di\'d6n  v\'edi v\'b9ch d\'cau \ldblquote 0\rdblquote  quy \'ad\'edc bi\'d3u th\'de r\'bbng dung t\'ddch \ldblquote \'ae\'e6 v\'b5o\rdblquote c\'f1a b\'d7nh chu\'c8
n s\'cf b\'bbng v\'edi dung t\'ddch danh \'ae\'denh c\'f1a n\'e3 khi n\'b9p \'ae\'c7y t\'edi v\'b9ch d\'cau n\'b5y, ho\'c6c 
\par b) K\'fd hi\'d6u \ldblquote Ex\rdblquote  \'ae\'e8i di\'d6n  v\'edi v\'b9ch d\'cau \ldblquote 0\rdblquote  quy \'ad\'edc bi\'d3u th\'de r\'bbng dung t\'ddch \ldblquote \'ae\'e6 ra\rdblquote  c\'f1a b\'d7nh chu\'c8n s\'cf b\'bbng v\'edi dung t\'ddch danh 
\'ae\'denh c\'f1a n\'e3 khi n\'b9p \'ae\'c7y t\'edi v\'b9ch d\'cau n\'b5y. 
\par 
\par \pard\plain \qj \f15\fs28 {\b\fs26 7.3}{\fs26  C\'b8c b\'d7nh chu\'c8n \'ae\'ad\'eec s\'f6 d\'f4ng \'ae\'d3 \'aeo c\'b8c ch\'cat l\'e1ng kh\'abng u\'e8ng \'ae\'ad\'eec c\'c7n ph\'b6i c\'e3 ch\'f3 th\'ddch \ldblquote  d\'efng cho c\'b8c ch\'cat l\'e1ng kh
\'abng u\'e8ng \'ae\'ad\'eec\rdblquote .
\par 
\par }{\b\fs26 7.4}{\b\i\fs26  }{\fs26 T\'cat c\'b6 c\'b8c k\'fd hi\'d6u ghi kh\'bec ph\'b6i r\'e2 r\'b5ng, d\'d4 \'ae\'e4c v\'b5 kh\'abng t\'c8y xo\'b8 \'ae\'ad\'eec trong \'aei\'d2u ki\'d6n s\'f6 d\'f4ng b\'d7nh th\'ad\'eang.
\par 
\par }{\b 8 Bao g\'e3i
\par }{\b\fs26 
\par 8.1}{\fs26  Khi c\'c7n thi\'d5t b\'d7nh chu\'c8n c\'e3 th\'d3 \'ae\'ad\'eec \'ae\'f9ng trong c\'b8c h\'e9p k\'ddn l\'b5m b\'bbng v\'cbt li\'d6u ch\'e8ng \'a8n m\'dfn, \'ae\'ad\'eec l\'e3t b\'bbng nhung, da, nh\'f9a m\'d2m ho\'c6c v\'cbt li\'d6u th\'ddch h
\'eep kh\'b8c.
\par 
\par }{\b\fs26 8.2}{\fs26  B\'d7nh chu\'c8n c\'c7n ph\'b6i \'ae\'ad\'eec \'ae\'f9ng \'ae\'f3ng trong h\'e9p c\'f1a ch\'f3ng \'ae\'d3 tr\'b8nh b\'cat k\'fa s\'f9 x\'aa d\'dech, r\'aci l\'b5m h\'ad h\'e1ng.
\par 
\par }{\b 9 Ghi nh\'b7n h\'e9p \'ae\'f9ng
\par }{\fs26 
\par }{\b\fs26 9.1}{\fs26  H\'e9p \'ae\'f9ng b\'d7nh chu\'c8n ph\'b6i c\'e3 bi\'d3n nh\'b7n hi\'d6u c\'e3 th\'d3 \'ae\'ad\'eec g\'ben c\'e8 \'ae\'denh v\'b5o h\'e9p.
\par 
\par Tr\'aan bi\'d3n nh\'b7n hi\'d6u c\'c7n ph\'b6i c\'e3 s\'e8 nh\'cbn d\'b9ng c\'f1a b\'d7nh chu\'c8n, Khi c\'c7n c\'e3 th\'d3 c\'e3 th\'aam c\'b8c  th\'abng tin sau :
\par \tab a) D\'cau nh\'cbn d\'b9ng qu\'e8c gia;
\par }\pard \qj\fi720 {\fs26 b) K\'fd hi\'d6u nh\'cbn d\'b9ng c\'f1a b\'d7nh chu\'c8n;
\par c) T\'aan c\'ac s\'eb s\'b6n xu\'cat;
\par d) Dung t\'ddch c\'f1a c\'b8c b\'d7nh chu\'c8n trong b\'e9;
\par }\pard \qj {\b\fs26 
\par 9.2 }{\fs26 C\'e3 th\'d3 s\'f6 d\'f4ng c\'b8c k\'fd nh\'b7n hi\'d6u kh\'b8c kh\'abng tr\'b8i v\'edi c\'b8c quy \'ae\'denh c\'f1a Nh\'b5 n\'ad\'edc.
\par }}