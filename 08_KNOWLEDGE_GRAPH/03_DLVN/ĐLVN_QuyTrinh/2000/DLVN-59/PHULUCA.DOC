}\pard \intbl {\fs26 \row }\pard \qj {\fs26 
\par 5.6.1 B\'d7nh chu\'c8n bi\'d3u th\'de dung t\'ddch \ldblquote \'ae\'e6 v\'b5o\rdblquote  ph\'b6i c\'e3 k\'fd hi\'d6u l\'b5 \ldblquote In\rdblquote  v\'b5 b\'d7nh chu\'c8n bi\'d3u th\'de dung t\'ddch \ldblquote \'ae\'e6 ra\rdblquote  ph\'b6i c\'e3 k\'fd hi
\'d6u l\'b5 \ldblquote Ex\rdblquote .
\par 
\par 
\par 
\par }{\b\fs26 5.7}{\b\i\fs26  }{\fs26 C\'b8c v\'b9ch d\'cau \'ae\'ad\'eec \'ae\'b8nh s\'e8 (xem b\'b6ng A2) ph\'b6i d\'b5i h\'acn \'ae\'b8ng k\'d3 c\'b8c v\'b9ch kh\'abng \'ae\'b8nh s\'e8 \'ae\'d3 \'ae\'b6m b\'b6o d\'d4 quan s\'b8t v\'b5 ph\'a9n bi\'d6t ch
\'f3ng. \'a7\'e8i v\'edi b\'d7nh chu\'c8n kh\'abng \'ae\'ad\'eec kh\'bec \'ae\'e9 thang \'aeo th\'d7 c\'b8c v\'b9ch d\'cau \'f8ng v\'edi gi\'edi h\'b9n sai s\'e8 cho ph\'d0p l\'edn nh\'cat c\'f1a ph\'ad\'acng ti\'d6n \'aeo c\'c7n ki\'d3m \'ae\'denh ph\'b6
i \'ae\'ad\'eec \'ae\'b8nh s\'e8 b\'bbng gi\'b8 tr\'de c\'f1a gi\'edi h\'b9n sai s\'e8 \'ae\'b7 n\'aau.
\par 
\par }{\b\fs26 5.8}{\fs26  C\'b8c v\'b9ch d\'cau kh\'abng \'ae\'b8nh s\'e8 (xem b\'b6ng A2) ph\'b6i c\'e3 chi\'d2u d\'b5i t\'e8i thi\'d3u b\'bbng 1/2 chu vi c\'e6.
\par 
\par }{\b\fs26 5.9}{\fs26  C\'b8c v\'b9ch d\'cau v\'b5 ch\'f7 s\'e8 ph\'b6i r\'e2 r\'b5ng, d\'d4 \'ae\'e4c v\'b5 kh\'abng t\'c8y xo\'b8 \'ae\'ad\'eec.
\par }{\b\fs26 
\par }{\b 6 Sai s\'e8 cho ph\'d0p l\'edn nh\'cat}
\par {\b\i\fs26 
\par }{\b\fs26 6.1}{\fs26  Sai s\'e8 cho ph\'d0p l\'edn nh\'cat khi ki\'d3m \'ae\'denh ban \'ae\'c7u v\'b5 \'ae\'denh k\'fa \'ae\'e8i v\'edi dung t\'ddch \ldblquote \'ae\'e6 v\'b5o\rdblquote  (dung t\'ddch \ldblquote In\rdblquote ) t\'ad\'acng \'f8ng v\'edi b
\'cat k\'fa v\'b9ch d\'cau n\'b5o c\'f1a thang \'aeo ph\'b6i \'ae\'b8p \'f8ng c\'b8c y\'aau c\'c7u n\'aau trong }{\i\fs26 c\'e9t E1}{\fs26  c\'f1a b\'b6ng A3.
\par 
\par }{\b\fs26 6.2 }{\fs26 Sai s\'e8 cho ph\'d0p l\'edn nh\'cat \'ae\'e8i v\'edi dung t\'ddch \ldblquote \'ae\'e6 v\'b5o\rdblquote  (dung t\'ddch \ldblquote In\rdblquote ) gi\'f7a 2 v\'b9ch d\'cau b\'cat k\'fa c\'f1a thang \'aeo ph\'b6i \'ae\'b8p \'f8ng c\'b8
c y\'aau c\'c7u n\'aau trong }{\i\fs26 c\'e9t E2}{\fs26  c\'f1a b\'b6ng A3.
\par 
\par }{\b\fs26 6.3}{\fs26  Sai s\'e8 cho ph\'d0p l\'edn nh\'cat \'ae\'e8i v\'edi dung t\'ddch \ldblquote \'ae\'e6 ra\rdblquote  (dung t\'ddch \ldblquote Ex\rdblquote ) t\'ad\'acng \'f8ng v\'edi b\'cat k\'fa v\'b9ch d\'cau n\'b5o c\'f1a thang \'aeo ho\'c6c gi
\'f7a 2 v\'b9ch d\'cau b\'cat k\'fa l\'edn h\'acn 50 % so v\'edi y\'aau c\'c7u \'ae\'e8i v\'edi dung t\'ddch \ldblquote \'ae\'e6 v\'b5o\rdblquote  nh\'ad \'ae\'b7 cho trong m\'f4c 6.1 v\'b5 6.2.
\par 
\par }\pard\plain \s3\qr\keepn \b\f15\fs26 {\i   B\'b6ng A3
\par }\pard \s3\qc\keepn {\fs28 Sai s\'e8 cho ph\'d0p l\'edn nh\'cat \'ae\'e8i v\'edi dung t\'ddch "\'ae\'e6 v\'b5o" ("In")
\par }\pard\plain \qj \f15\fs28 {\fs26 
\par }\trowd \trgaph108\trleft-108\trkeep\trbrdrt\brdrs\brdrw15 \trbrdrl\brdrs\brdrw15 \trbrdrb\brdrs\brdrw15 \trbrdrr\brdrs\brdrw15 \trbrdrh\brdrs\brdrw15 \trbrdrv\brdrs\brdrw15 \clbrdrt\brdrs\brdrw15 \clbrdrl\brdrs\brdrw15 \clbrdrr\brdrs\brdrw15 \cellx2844
