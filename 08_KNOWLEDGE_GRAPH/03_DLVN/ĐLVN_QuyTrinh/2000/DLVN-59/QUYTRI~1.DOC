\par b) C\'b8c qu\'b6 c\'a9n chu\'c8n F}{\fs26\sub 2}{\fs26  t\'f5 1 g \'ae\'d5n 10 kg;
\par c) Ch\'cat l\'e1ng ki\'d3m \'ae\'denh : n\'ad\'edc c\'cat;
\par }\pard \qj\sb120\nowidctlpar {\fs26 d) Nhi\'d6t k\'d5 (0 }{\fs26 {\field{\*\fldinst SYMBOL 184 \\f "Symbol" \\s 13}{\fldrslt\f1\fs26}}}{\fs26  50) }{\fs26\super o}{\fs26 C, gi\'b8 tr\'de \'ae\'e9 chia 0,1 }{\fs26\super o}{\fs26 C; Nhi\'d6t k\'d5 (0 }{
\fs26 {\field{\*\fldinst SYMBOL 184 \\f "Symbol" \\s 13}{\fldrslt\f1\fs26}}}{\fs26  50) }{\fs26\super o}{\fs26 C, gi\'b8 tr\'de \'ae\'e9 chia 0,2 }{\fs26\super o}{\fs26 C;
\par }\pard \qj\ri329\sb120\nowidctlpar {\fs26 e) }{\f16\fs26 \'c8}{\fs26 m k\'d5, sai s\'e8 l\'edn nh\'cat cho ph\'d0p }{\fs26 {\field{\*\fldinst SYMBOL 177 \\f "Symbol" \\s 13}{\fldrslt\f1\fs26}}}{\fs26  5 %;
\par f) Baromet, sai s\'e8 l\'edn nh\'cat cho ph\'d0p }{\fs26 {\field{\*\fldinst SYMBOL 177 \\f "Symbol" \\s 13}{\fldrslt\f1\fs26}}}{\fs26  10 hPa.
\par }\pard \qj\sb120\nowidctlpar {\fs26 g) Th\'ad\'edc c\'c6p, gi\'b8 tr\'de chia \'ae\'e9 0,1mm ; th\'ad\'edc v\'b9ch, gi\'b8 tr\'de \'ae\'e9 chia 1mm; th\'ad\'edc cu\'e9n, gi\'b8 tr\'de \'ae\'e9 chia 1mm;
\par h) \'a7\'e5ng h\'e5 b\'cam gi\'a9y, gi\'b8 tr\'de \'ae\'e9 chia 0,1 s;
\par i) C\'b8c thi\'d5t b\'de ph\'f4 : b\'d7nh c\'a9n, ca, ph\'d4u, \'e8ng \'aeong b\'bbng thu\'fb tinh, \'e8ng d\'c9n  m\'d2m, gi\'b8 \'ae\'ec,...  
\par }\pard \qj\nowidctlpar 
\par 
\par {\b 4 \'a7i\'d2u ki\'d6n ki\'d3m \'ae\'denh v\'b5 chu\'c8n b\'de ki\'d3m \'ae\'denh
\par }{\fs26 
\par }{\b\fs26 4.1 \'a7i\'d2u ki\'d6n ki\'d3m \'ae\'denh 
\par }{\fs26 
\par Khi ti\'d5n h\'b5nh ki\'d3m \'ae\'denh ph\'b6i \'ae\'b6m b\'b6o c\'b8c \'aei\'d2u ki\'d6n sau \'ae\'a9y:
\par }\pard \qj\sb120\nowidctlpar {\fs26 - Nhi\'d6t \'ae\'e9 m\'abi tr\'ad\'eang v\'b5 n\'ad\'edc n\'bbm trong kho\'b6ng (15 }{\fs26 {\field{\*\fldinst SYMBOL 184 \\f "Symbol" \\s 13}{\fldrslt\f1\fs26}}}{\fs26  30) }{\fs26\super o}{\fs26 C.
\par - S\'f9 thay \'ae\'e6i nhi\'d6t \'ae\'e9 c\'f1a n\'ad\'edc trong qu\'b8 tr\'d7nh th\'f9c hi\'d6n m\'e9t ph\'d0p \'aeo kh\'abng \'ae\'ad\'eec v\'ad\'eet       qu\'b8 0,2 }{\fs26\super o}{\fs26 C.
\par - S\'f9 thay \'ae\'e6i nhi\'d6t \'ae\'e9 kh\'abng kh\'dd kh\'abng v\'ad\'eet qu\'b8 1 }{\fs26\super o}{\fs26 C/h v\'b5 ch\'aanh l\'d6ch nhi\'d6t \'ae\'e9 c\'f1a ch\'cat l\'e1ng ki\'d3m \'ae\'denh v\'b5 kh\'abng kh\'dd kh\'abng v\'ad\'eet qu\'b8 0,5 }{
\fs26\super o}{\fs26 C.
\par }\pard \qr\sb60\sa60\sl-360\slmult1\nowidctlpar {\b\f25 \'a7LVN 59 : 2000
\par }\pard \qj\nowidctlpar {\fs26 
\par Nhi\'d6t \'ae\'e9 m\'abi tr\'ad\'eang  \'ae\'ad\'eec x\'b8c \'ae\'denh v\'edi \'ae\'e9 ch\'ddnh x\'b8c \'ae\'d5n 0,2 }{\fs26\super o}{\fs26 C, nhi\'d6t \'ae\'e9 c\'f1a n\'ad\'edc \'ae\'ad\'eec x\'b8c \'ae\'denh v\'edi \'ae\'e9 ch\'ddnh x\'b8c \'ae\'d5
n 0,1 }{\fs26\super o}{\fs26 C.
\par 
\par }{\b\fs26 4.2 Chu\'c8n b\'de ki\'d3m \'ae\'denh 
\par }{\fs26 
\par D\'efng axit sunphuaric lo\'b7ng, n\'ad\'edc s\'b9ch v\'b5 ch\'cat t\'c8y r\'f6a l\'b5m s\'b9ch b\'d2 m\'c6t b\'aan trong c\'f1a chu\'c8n c\'c7n ki\'d3m \'ae\'denh v\'b5 c\'b8c thi\'d5t b\'de ph\'f4 kh\'b8c nh\'ad b\'d7nh c\'a9n, ca, ph\'d4u, \'e8ng \'ae
ong. B\'d7nh chu\'c8n theo ki\'d3u \ldblquote \'ae\'e6 v\'b5o\rdblquote  sau khi l\'b5m s\'b9ch ph\'b6i \'ae\'ad\'eec s\'cay kh\'ab b\'d2 m\'c6t b\'aan trong.
\par }\pard \qj\ri38\nowidctlpar {\fs26 
\par Chu\'c8n c\'c7n ki\'d3m \'ae\'denh, ch\'cat l\'e1ng ki\'d3m \'ae\'denh, c\'b8c ph\'ad\'acng ti\'d6n \'aeo v\'b5 c\'b8c thi\'d5t b\'de ph\'f4 kh\'b8c \'ae\'ad\'eec \'ae\'c6t trong ph\'dfng th\'dd nghi\'d6m \'ae\'b7 \'ae\'ad\'eec \'e6n \'ae\'denh nhi\'d6t 
\'ae\'e9 \'ae\'d3 \'ae\'b6m b\'b6o c\'b8c \'aei\'d2u ki\'d6n ki\'d3m \'ae\'denh theo y\'aau c\'c7u trong m\'f4c 4.1.
\par }\pard\plain \s1\qj\keepn\nowidctlpar \b\f15\fs28\kerning28 
\par 5 Ti\'d5n h\'b5nh ki\'d3m \'ae\'denh
\par \pard\plain \qj\nowidctlpar \f15\fs28 {\b\fs26 
\par 5.1 Ki\'d3m tra b\'aan ngo\'b5i 
\par }\pard\plain \s16\qj\nowidctlpar \f15\fs26 
\par {\expnd0\expndtw2 Quan s\'b8t b\'bbng m\'bet \'ae\'d3 x\'b8c \'ae\'denh s\'f9 ph\'ef h\'eep c\'f1a chu\'c8n c\'c7n ki\'d3m \'ae\'denh v\'edi c\'b8c y\'aau c\'c7u quy \'ae\'denh trong c\'b8c m\'f4c 3, t\'f5 4.1 \'ae\'d5n 4.5, 4.7, 5 v\'b5 7 c\'f1a ph\'f4 l
\'f4c A (\'ae\'e8i v\'edi b\'d7nh chu\'c8n), c\'b8c }{\expnd0\expndtw4 m\'f4c 3, t\'f5 4.1 \'ae\'d5n 4.9, 6, 8 c\'f1a ph\'f4 l\'f4c B (\'ae\'e8i v\'edi buret), c\'b8c m\'f4c 3, 4, 5.1, 7, 9 c\'f1a ph\'f4 l\'f4c C (\'ae\'e8i v\'edi pipet) . 
\par }\pard\plain \qj\nowidctlpar \f15\fs28 {\b\fs26 
\par 5.2 Ki\'d3m tra k\'fc thu\'cbt
\par }{\fs26 
\par 5.2.1 Ki\'d3m tra c\'b8c k\'ddch th\'ad\'edc c\'ac b\'b6n
\par }\pard\plain \s16\qj\nowidctlpar \f15\fs26 
\par D\'efng c\'b8c ph\'ad\'acng ti\'d6n n\'aau trong m\'f4c 3.2 g \'ae\'d3 ki\'d3m tra s\'f9 ph\'ef h\'eep c\'f1a c\'b8c k\'ddch th\'ad\'edc c\'f1a chu\'c8n c\'c7n ki\'d3m \'ae\'denh v\'edi c\'b8c y\'aau c\'c7u quy \'ae\'denh trong m\'f4c 4.6 c\'f1a ph\'f4 l
\'f4c A (\'ae\'e8i v\'edi b\'d7nh chu\'c8n), m\'f4c 5.10 c\'f1a ph\'f4 l\'f4c B (\'ae\'e8i v\'edi buret), m\'f4c 5.2 c\'f1a ph\'f4 l\'f4c C (\'ae\'e8i v\'edi pipet) .
\par 
\par 5.2.2 Ki\'d3m tra \'ae\'e9 k\'ddn c\'f1a van x\'b6 
\par \pard\plain \qj\nowidctlpar \f15\fs28 {\fs26 
\par Buret \'ae\'ad\'eec \'ae\'c6t c\'e8 \'ae\'denh tr\'aan gi\'b8 \'ae\'ec theo chi\'d2u th\'bcng \'ae\'f8ng. N\'b9p n\'ad\'edc \'ae\'c7y \'ae\'d5n v\'b9ch d\'cau \ldblquote 0\rdblquote .
\par 
\par \'a7\'e3ng van x\'b6 v\'b5 gi\'f7 trong kho\'b6ng th\'eai gian 30 ph\'f3t. N\'d5u trong th\'eai gian \'ae\'e3 kh\'abng ph\'b8t hi\'d6n th\'cay r\'df r\'d8 t\'b9i \'ae\'c7u v\'dfi x\'b6 v\'b5 m\'f8c n\'ad\'edc tr\'aan thang \'aeo kh\'abng thay \'ae\'e6i qu
\'b8 m\'e9t gi\'b8 tr\'de \'ae\'e9 chia th\'d7 van x\'b6 c\'f1a buret \'ae\'ad\'eec coi l\'b5 k\'ddn. 
\par 
\par N\'d5u buret c\'e3 \'e8ng n\'b9p th\'d7 ph\'b6i ki\'d3m tra c\'b6 \'ae\'e9 k\'ddn c\'f1a van x\'b6 trong \'aei\'d2u ki\'d6n buret r\'e7ng v\'b5 \'e8ng n\'b9p \'ae\'ad\'eec n\'b9p \'ae\'c7y n\'ad\'edc t\'edi m\'f8c 250 mm cao h\'acn v\'b9ch d\'cau 
\ldblquote 0\rdblquote  c\'f1a buret theo tr\'d7nh t\'f9 v\'b5 \'aei\'d2u ki\'d6n n\'aau tr\'aan.
\par 
\par }\pard \nowidctlpar {\b\f25 \'a7LVN 59 : 2000
\par }\pard \qj\nowidctlpar {\fs26 
\par 
\par 5.2.3 Ki\'d3m tra th\'eai gian ch\'b6y
\par 
\par N\'b9p \'ae\'c7y n\'ad\'edc v\'b5o buret (ho\'c6c pipet).
\par 
\par Gi\'f7 buret (ho\'c6c pipet) \'eb v\'de tr\'dd th\'bcng \'ae\'f8ng, hi\'d6u ch\'d8nh m\'c6t cong c\'f1a n\'ad\'edc tr\'efng v\'edi v\'b9ch d\'cau \ldblquote 0\rdblquote  c\'f1a buret (ho\'c6c v\'b9ch d\'cau tr\'aan c\'efng c\'f1a pipet). 
\par 
\par Cho n\'ad\'edc ch\'b6y t\'f9 do v\'b5o b\'d7nh ch\'f8a b\'bbng c\'b8ch m\'eb h\'d5t c\'ec van x\'b6 (ho\'c6c th\'b6 t\'f9 do ho\'b5n to\'b5n m\'d0p tr\'aan c\'f1a pipet) cho \'ae\'d5n khi m\'c6t cong c\'f1a n\'ad\'edc \'ae\'b9t t\'edi v\'de tr\'dd \'ae
\'c7u v\'dfi x\'b6 c\'f1a buret (\'ae\'c7u m\'f3t c\'f1a pipet). \'a7\'e8i v\'edi pipet b\'d7nh ch\'f8a  \'ae\'ad\'eec \'ae\'c6t h\'aci nghi\'aang \'ae\'d3 \'ae\'c7u m\'f3t kh\'cf ch\'b9m v\'b5o th\'b5nh trong c\'f1a b\'d7nh ch\'f8a nh\'adng kh\'abng \'ae
\'ad\'eec c\'e3 s\'f9 x\'aa d\'dech n\'b5o. D\'efng \'ae\'e5ng h\'e5 b\'cam gi\'a9y \'ae\'d3 x\'b8c \'ae\'denh th\'eai gian ch\'b6y. 
\par 
\par Ch\'aanh l\'d6ch gi\'f7a th\'eai gian ch\'b6y x\'b8c \'ae\'denh theo ph\'ad\'acng ph\'b8p tr\'aan v\'b5 gi\'b8 tr\'de ghi kh\'bec kh\'abng \'ae\'ad\'eec v\'ad\'eet qu\'b8 gi\'edi h\'b9n quy \'ae\'denh trong m\'f4c 6 ph\'f4 l\'f4c B (\'ae\'e8i v\'ed
i buret) v\'b5 m\'f4c 6 ph\'f4 l\'f4c C (\'ae\'e8i v\'edi pipet).
\par 
\par }{\b\fs26 5.3 Ki\'d3m tra \'aeo l\'ad\'eang 
\par }{\fs26 
\par 5.3.1 X\'b8c \'ae\'denh sai s\'e8 c\'f1a chu\'c8n t\'b9i c\'b8c v\'b9ch d\'cau
\par 
\par Vi\'d6c x\'b8c \'ae\'denh sai s\'e8 \'ae\'ad\'eec th\'f9c hi\'d6n \'ae\'e8i v\'edi c\'b8c v\'b9ch d\'cau sau :
\par 
\par a) B\'d7nh chu\'c8n : v\'b9ch d\'cau dung t\'ddch danh \'ae\'denh (\ldblquote \'ae\'e6 v\'b5o\rdblquote  ho\'c6c \ldblquote \'ae\'e6 ra\rdblquote ) v\'b5 4 v\'b9ch d\'cau kh\'b8c, trong \'ae\'e3 c\'e3 v\'b9ch tr\'aan c\'efng v\'b5 v\'b9ch d\'ad\'edi c\'ef
ng;
\par 
\par b) Buret : v\'b9ch d\'cau dung t\'ddch danh \'ae\'denh v\'b5 4 v\'b9ch d\'cau kh\'b8c c\'b8ch \'ae\'d2u nhau n\'bbm gi\'f7a v\'b9ch d\'cau \ldblquote 0\rdblquote  v\'b5 v\'b9ch d\'cau dung t\'ddch danh \'ae\'denh;
\par 
\par c) Pipet : v\'b9ch d\'cau dung t\'ddch danh \'ae\'denh v\'b5 4 v\'b9ch d\'cau kh\'b8c c\'b8ch \'ae\'d2u nhau n\'bbm gi\'f7a v\'b9ch d\'cau \ldblquote 0\rdblquote  v\'b5 v\'b9ch d\'cau dung t\'ddch danh \'ae\'denh.
\par 
\par 5.3.1.1 X\'b8c \'ae\'denh kh\'e8i l\'ad\'eeng n\'ad\'edc c\'cat \'f8ng v\'edi m\'e9t v\'b9ch d\'cau
\par 
\par a) B\'d7nh chu\'c8n ki\'d3u \ldblquote \'ae\'e6 v\'b5o\rdblquote 
\par 
\par - \'a7\'c6t b\'d7nh chu\'c8n \'ae\'b7 \'ae\'ad\'eec l\'b5m s\'b9ch v\'b5 s\'cay kh\'ab l\'aan b\'b5n c\'a9n \'ae\'d3 x\'b8c \'ae\'denh kh\'e8i l\'ad\'eeng r\'e7ng;
\par - \'a7o nhi\'d6t \'ae\'e9 c\'f1a n\'ad\'edc c\'cat t\'b9i b\'d7nh ch\'f8a;
\par - \'a7\'c6t b\'d7nh chu\'c8n l\'aan m\'c6t ph\'bcng v\'b5 n\'b9p n\'ad\'edc c\'cat v\'b5o b\'d7nh cho t\'edi khi m\'c6t cong c\'f1a n\'ad\'edc tr\'efng v\'edi m\'d0p tr\'aan c\'f1a v\'b9ch d\'cau t\'ad\'acng \'f8ng;
\par 
\par }\pard \qr\nowidctlpar {\b\f25 \'a7LVN 59 : 2000
\par 
\par }\pard \qj\sb120\sl288\slmult1\nowidctlpar {\fs26 - Ki\'d3m tra v\'b5 lo\'b9i tr\'f5 n\'ad\'edc c\'dfn b\'b8m d\'ddnh tr\'aan b\'d2 m\'c6t b\'aan ngo\'b5i v\'b5 b\'aan trong b\'d7nh chu\'c8n \'eb ph\'dda tr\'aan v\'b9ch d\'cau v\'b5 b\'e4t kh\'dd trong b
\'d7nh;
\par - \'a7\'c6t b\'d7nh chu\'c8n l\'aan b\'b5n c\'a9n \'ae\'d3 x\'b8c \'ae\'denh kh\'e8i l\'ad\'eeng n\'ad\'edc c\'cat v\'b5 b\'d7nh chu\'c8n;
\par - \'a7\'e4c gi\'b8 tr\'de nhi\'d6t \'ae\'e9, \'b8p su\'cat v\'b5 \'ae\'e9 \'c8m c\'f1a kh\'abng kh\'dd.
\par }\pard \qj\nowidctlpar {\fs26 
\par b) B\'d7nh chu\'c8n ki\'d3u \ldblquote \'ae\'e6 ra\rdblquote 
\par 
\par }\pard \qj\sb120\sl264\slmult1\nowidctlpar {\fs26 - N\'b9p \'ae\'c7y b\'d7nh chu\'c8n \'ae\'b7 \'ae\'ad\'eec l\'b5m s\'b9ch t\'edi v\'b9ch d\'cau t\'ad\'acng \'f8ng;
\par - X\'b6 h\'d5t n\'ad\'edc ra kh\'e1i b\'d7nh chu\'c8n, cho n\'ad\'edc ch\'b6y nh\'e1 gi\'e4t trong th\'eai gian kho\'b6ng 60 gi\'a9y;
\par - \'a7\'c6t b\'d7nh chu\'c8n l\'aan m\'c6t b\'b5n c\'a9n \'ae\'d3 x\'b8c \'ae\'denh kh\'e8i l\'ad\'eeng r\'e7ng;
\par - \'a7o nhi\'d6t \'ae\'e9 c\'f1a n\'ad\'edc c\'cat t\'b9i b\'d7nh ch\'f8a;
\par - \'a7\'c6t b\'d7nh chu\'c8n l\'aan m\'c6t ph\'bcng v\'b5 n\'b9p n\'ad\'edc c\'cat v\'b5o b\'d7nh cho t\'edi khi m\'c6t cong c\'f1a n\'ad\'edc tr\'efng v\'edi m\'d0p tr\'aan c\'f1a v\'b9ch d\'cau t\'ad\'acng \'f8ng;
\par - Ki\'d3m tra v\'b5 lo\'b9i tr\'f5 n\'ad\'edc c\'dfn b\'b8m d\'ddnh tr\'aan b\'d2 m\'c6t b\'aan ngo\'b5i v\'b5 b\'aan trong b\'d7nh chu\'c8n \'eb ph\'dda tr\'aan v\'b9ch d\'cau v\'b5 b\'e4t kh\'dd trong b\'d7nh;
\par - \'a7\'c6t b\'d7nh chu\'c8n l\'aan b\'b5n c\'a9n \'ae\'d3 x\'b8c \'ae\'denh kh\'e8i l\'ad\'eeng n\'ad\'edc c\'cat v\'b5 b\'d7nh chu\'c8n;
\par - \'a7\'e4c gi\'b8 tr\'de nhi\'d6t \'ae\'e9, \'b8p su\'cat v\'b5 \'ae\'e9 \'c8m c\'f1a kh\'abng kh\'dd,
\par }\pard \qj\nowidctlpar {\fs26 
\par c) Buret
\par 
\par }\pard \qj\sb120\sl264\slmult1\nowidctlpar {\fs26 - \'a7\'c6t buret v\'b5o gi\'b8 \'ae\'ec theo v\'de tr\'dd th\'bcng \'ae\'f8ng;
\par - \'a7o nhi\'d6t \'ae\'e9 c\'f1a n\'ad\'edc c\'cat t\'b9i b\'d7nh ch\'f8a;
\par - N\'b9p n\'ad\'edc c\'cat v\'b5o buret t\'edi m\'f8c cao h\'acn v\'b9ch d\'cau \ldblquote 0\rdblquote  v\'b5i mm;
\par - Lau s\'b9ch n\'ad\'edc c\'dfn b\'b8m d\'ddnh b\'aan ngo\'b5i \'ae\'c7u v\'dfi x\'b6;
\par - X\'b6 n\'ad\'edc d\'c7n d\'c7n cho t\'edi khi m\'c6t cong c\'f1a n\'ad\'edc tr\'efng v\'edi m\'d0p tr\'aan c\'f1a v\'b9ch d\'cau t\'ad\'acng \'f8ng;
\par - Kh\'cf ch\'b9m th\'b5nh \'ad\'edt c\'f1a b\'d7nh ch\'f8a v\'b5o \'ae\'c7u v\'dfi x\'b6 \'ae\'d3 lo\'b9i tr\'f5 h\'d5t n\'ad\'edc c\'dfn b\'b8m d\'ddnh \'eb \'ae\'e3;
\par - Ki\'d3m tra v\'b5 lo\'b9i tr\'f5 n\'ad\'edc c\'dfn b\'b8m d\'ddnh tr\'aan b\'d2 m\'c6t b\'aan ngo\'b5i v\'b5 b\'aan trong buret \'eb ph\'dda tr\'aan v\'b9ch d\'cau v\'b5 b\'e4t kh\'dd trong buret;
\par - X\'b8c \'ae\'denh kh\'e8i l\'ad\'eeng c\'f1a b\'d7nh c\'a9n v\'b5 n\'f3t \'ae\'cby \'ae\'b7 \'ae\'ad\'eec l\'b5m s\'b9ch v\'b5 x\'b6 h\'d5t n\'ad\'edc;
\par 
\par }\pard \nowidctlpar {\b\f25 \'a7LVN 59 : 2000
\par }\pard \qj\sb120\sl288\slmult1\nowidctlpar {\fs26 
\par }\pard \qj\sb100\nowidctlpar {\fs26 - X\'b6 n\'ad\'edc t\'f9 do t\'f5 buret v\'b5o b\'d7nh c\'a9n v\'b5 ch\'f3 \'fd \'ae\'d3 th\'b5nh c\'f1a b\'d7nh c\'a9n kh\'abng ch\'b9m v\'b5o \'ae\'c7u v\'dfi x\'b6 c\'f1a buret;
\par - Gi\'f7 kho\'b8 van x\'b6 \'eb v\'de tr\'dd m\'eb ho\'b5n to\'b5n cho t\'edi khi m\'f8c n\'ad\'edc ch\'d8 c\'dfn c\'b8ch v\'b9ch d\'cau t\'ad\'acng \'f8ng v\'b5i mm th\'d7 gi\'b6m d\'dfng ch\'b6y v\'b5 \'aei\'d2u ch\'d8nh sao cho m\'c6t cong c\'f1a n\'ad
\'edc v\'f5a ch\'b9m v\'b5o m\'d0p tr\'aan c\'f1a v\'b9ch d\'cau t\'ad\'acng \'f8ng;
\par - Kh\'cf ch\'b9m  th\'b5nh trong c\'f1a b\'d7nh c\'a9n v\'b5o \'ae\'c7u v\'dfi x\'b6 c\'f1a buret \'ae\'d3 thu h\'d5t n\'ad\'edc v\'b5o b\'d7nh c\'a9n;
\par - \'a7\'c6t b\'d7nh c\'a9n l\'aan b\'b5n c\'a9n \'ae\'d3 x\'b8c \'ae\'denh kh\'e8i l\'ad\'eeng n\'ad\'edc c\'cat v\'b5 b\'d7nh c\'a9n;
\par - \'a7\'e4c gi\'b8 tr\'de nhi\'d6t \'ae\'e9, \'b8p su\'cat v\'b5 \'ae\'e9 \'c8m c\'f1a kh\'abng kh\'dd.
\par }\pard \qj\nowidctlpar {\fs26 
\par d) Pipet
\par 
\par }\pard \qj\sb100\nowidctlpar {\fs26 - \'a7o nhi\'d6t \'ae\'e9 c\'f1a n\'ad\'edc c\'cat t\'b9i b\'d7nh ch\'f8a;
\par - Nh\'f3ng \'ae\'c7u m\'f3t c\'f1a n\'e3 v\'b5o n\'ad\'edc c\'cat v\'b5 h\'f3t n\'ad\'edc \'ae\'d3 n\'b9p v\'b5o pipet t\'edi m\'f8c cao h\'acn v\'b9ch d\'cau \ldblquote 0\rdblquote  v\'b5i mm. Gi\'f7 pipet \'eb v\'de tr\'dd th\'bcng \'ae\'f8ng;
\par - X\'b6 n\'ad\'edc d\'c7n d\'c7n cho t\'edi khi m\'c6t cong c\'f1a n\'ad\'edc tr\'efng v\'edi  m\'d0p tr\'aan c\'f1a v\'b9ch d\'cau t\'ad\'acng \'f8ng;
\par - Kh\'cf ch\'b9m  th\'b5nh \'ad\'edt c\'f1a b\'d7nh ch\'f8a v\'b5o \'ae\'c7u v\'dfi m\'f3t \'ae\'d3 lo\'b9i tr\'f5 h\'d5t n\'ad\'edc c\'dfn b\'b8m d\'ddnh \'eb \'ae\'e3;
\par - Ki\'d3m tra v\'b5 lo\'b9i tr\'f5 n\'ad\'edc c\'dfn b\'b8m d\'ddnh tr\'aan b\'d2 m\'c6t b\'aan ngo\'b5i v\'b5 b\'aan trong pipet \'eb ph\'dda tr\'aan v\'b9ch d\'cau v\'b5 b\'e4t kh\'dd trong pipet;
\par - X\'b8c \'ae\'denh kh\'e8i l\'ad\'eeng c\'f1a b\'d7nh c\'a9n v\'b5 n\'f3t \'ae\'cby \'ae\'b7 \'ae\'ad\'eec l\'b5m s\'b9ch v\'b5 x\'b6 h\'d5t n\'ad\'edc;
\par - X\'b6 n\'ad\'edc t\'f9 do t\'f5 pipet v\'b5o b\'d7nh c\'a9n v\'b5 \'ae\'d3 th\'b5nh trong c\'f1a b\'d7nh c\'a9n kh\'cf ch\'b9m v\'b5o \'ae\'c7u m\'f3t c\'f1a pipet;
\par - \'a7\'eei cho n\'ad\'edc \'ae\'ad\'eec x\'b6 ra ho\'b5n to\'b5n kh\'e1i pipet cho t\'edi khi m\'c6t cong c\'f1a n\'ad\'edc d\'f5ng l\'b9i ngay t\'b9i \'ae\'c7u m\'f3t c\'f1a pipet. Sau v\'b5i gi\'a9y kh\'cf d\'dech chuy\'d3n \'ae\'c7u m\'f3t c\'f1
a pipet d\'e4c theo th\'b5nh c\'f1a b\'d7nh c\'a9n \'ae\'d3 thu n\'e8t gi\'e4t ch\'cat l\'e1ng c\'dfn \'ae\'e4ng t\'b9i \'ae\'e3;
\par - \'a7\'c6t b\'d7nh c\'a9n l\'aan b\'b5n c\'a9n \'ae\'d3 x\'b8c \'ae\'denh kh\'e8i l\'ad\'eeng n\'ad\'edc c\'cat v\'b5 b\'d7nh c\'a9n;
\par - \'a7\'e4c gi\'b8 tr\'de nhi\'d6t \'ae\'e9, \'b8p su\'cat v\'b5 \'ae\'e9 \'c8m c\'f1a kh\'abng kh\'dd.
\par 
