\par }\pard\plain \s1\qc\keepn\nowidctlpar \b\i\f15\fs28 {\b0\i0 
\par }\pard\plain \qj\nowidctlpar \f15\fs26 Chi\'d2u d\'b5i c\'f1a kho\'b6ng chia \'ae\'e9 ph\'b6i \'ae\'b6m b\'b6o sao cho chi\'d2u d\'b5i c\'f1a to\'b5n thang \'aeo n\'bbm trong gi\'edi h\'b9n \'ae\'ad\'eec quy \'ae\'denh trong b\'b6ng C2.
\par 
\par {\b 7.5} \'a7\'d3 d\'d4 ph\'a9n bi\'d6t, chi\'d2u d\'b5i c\'f1a c\'b8c v\'b9ch d\'cau ph\'b6i kh\'b8c nhau, c\'f4 th\'d3 nh\'ad sau:
\par {\b\i 
\par }7.5.1{\b\i  }V\'b9ch d\'b5i ph\'b6i k\'d0o d\'b5i to\'b5n b\'e9 chu vi ho\'c6c kho\'b6ng 9/10 chu vi c\'f1a pipet v\'b5 li\'d2n n\'d0t. N\'d5u c\'e3 s\'f9 ng\'bet qu\'b7ng n\'b5o \'ae\'e3 tr\'aan v\'b9ch n\'b5y th\'d7 n\'e3 ph\'b6i n\'bbm tr\'aan \'ae
\'ad\'eang sinh b\'aan c\'b9nh khi nh\'d7n v\'b5o pipet t\'f5 ph\'dda tr\'ad\'edc.
\par {\b\i 
\par }7.5.2{\b\i  }Chi\'d2u d\'b5i c\'f1a v\'b9ch trung b\'d7nh ph\'b6i b\'bbng kho\'b6ng 2/3 chu vi c\'f1a pipet.
\par {\b\i 
\par }7.5.3{\b\i  }Chi\'d2u d\'b5i c\'f1a v\'b9ch ng\'ben ph\'b6i b\'bbng ho\'c6c l\'edn h\'acn 1/2 chu vi c\'f1a pipet.
\par {\b\i 
\par }7.5.4{\b\i  }Ph\'c7n k\'d0o d\'b5i sang hai ph\'dda c\'f1a v\'b9ch trung b\'d7nh ph\'b6i l\'b5 \'ae\'e8i x\'f8ng t\'ad\'acng \'f8ng v\'edi c\'b8c \'ae\'c7u m\'f3t c\'f1a{\b  }v\'b9ch ng\'ben.
\par \pard \nowidctlpar {\b\i 
\par }{\b 7.6}{\b\i  }Vi\'d6c b\'e8 tr\'dd c\'b8c v\'b9ch c\'e3 \'ae\'e9 d\'b5i kh\'b8c nhau ph\'b6i tu\'a9n th\'f1 theo c\'b8c y\'aau c\'c7u d\'ad\'edi \'ae\'a9y:
\par \pard \qj\nowidctlpar {\b\i 
\par }7.6.1{\b\i  } Pipet c\'e3 dung t\'ddch \'ae\'denh danh l\'b5 1 cm{\super 3} v\'b5 10 cm{\super 3 }:
\par \pard \qj\sb120\nowidctlpar \tab a) V\'b9ch d\'cau \'f8ng v\'edi dung t\'ddch danh \'ae\'denh v\'b5 c\'b8ch 10 v\'b9ch l\'b5 v\'b9ch d\'b5i;
\par \tab b) Ph\'b6i c\'e3 1 v\'b9ch trung b\'d7nh n\'bbm gi\'f7a 2 v\'b9ch d\'b5i li\'d2n k\'d2 nhau;
\par {\expnd-1\expndtw-6 \tab c) Ph\'b6i c\'e3 4 v\'b9ch ng\'ben c\'b8ch \'ae\'d2u n\'bbm gi\'f7a v\'b9ch trung b\'d7nh v\'b5 v\'b9ch d\'b5i li\'d2n k\'d2 nhau.}
\par \pard \qj\nowidctlpar {\b\i 
\par }7.6.2{\b\i  }Pipet c\'e3 dung t\'ddch danh \'ae\'denh l\'b5 2 cm{\super 3} v\'b5 25 cm{\super 3 }:
\par \pard \qj\sb120\nowidctlpar \tab a)  V\'b9ch d\'cau \'f8ng v\'edi dung t\'ddch danh \'ae\'denh v\'b5 c\'b8ch 5 v\'b9ch l\'b5 v\'b9ch d\'b5i;
\par \tab b)  Ph\'b6i c\'e3 4 v\'b9ch ng\'ben c\'b8ch \'ae\'d2u n\'bbm gi\'f7a 2 v\'b9ch d\'b5i li\'d2n k\'d2 nhau.
\par \pard \qj\nowidctlpar {\b\i 
\par }7.6.3{\b\i  }Pipet c\'e3 dung t\'ddch danh \'ae\'denh l\'b5 5 cm{\super 3} :
\par \pard \qj\sb120\nowidctlpar \tab a)  V\'b9ch d\'cau \'f8ng v\'edi dung t\'ddch danh \'ae\'denh v\'b5 c\'b8ch 10 v\'b9ch l\'b5 v\'b9ch d\'b5i;
\par \tab b)  Ph\'b6i c\'e3 4 v\'b9ch trung b\'d7nh c\'b8ch \'ae\'d2u n\'bbm gi\'f7a 2 v\'b9ch d\'b5i li\'d2n k\'d2 nhau;
\par \tab c)  Ph\'b6i c\'e3 1 v\'b9ch ng\'ben n\'bbm gi\'f7a 2 v\'b9ch trung b\'d7nh li\'d2n k\'d2 v\'b5 gi\'f7a v\'b9ch trung b\'d7nh v\'b5 v\'b9ch d\'b5i li\'d2n k\'d2 nhau.
\par \pard \qj\nowidctlpar {\b 
\par 7.7} Khi nh\'d7n v\'b5o pipet t\'f5 ph\'dda tr\'ad\'edc t\'b9i v\'de tr\'dd s\'f6 d\'f4ng b\'d7nh th\'ad\'eang th\'d7 \'aei\'d3m b\'bet \'ae\'c7u c\'f1a m\'e7i v\'b9ch ng\'ben ph\'b6i n\'bbm tr\'aan m\'e9t \'ae\'ad\'eang th\'bcng \'ae\'f8ng t\'ad\'ebng t
\'ad\'eeng, b\'bet \'ae\'c7u t\'f5 gi\'f7a  m\'c6t ph\'dda tr\'ad\'edc c\'f1a pipet v\'b5 k\'d0o d\'b5i v\'d2 ph\'dda b\'aan tr\'b8i.
\par {\b 
\par 7.8} C\'b8c v\'b9ch ph\'b6i \'ae\'ad\'eec \'ae\'b8nh s\'e8 t\'f5 d\'ad\'edi l\'aan tr\'aan, \'aei\'d3m \ldblquote 0\rdblquote  l\'b5 \'aei\'d3m \'ae\'c7u m\'f3t c\'f1a pipet; c\'b8c kho\'b6ng \'ae\'ad\'eec \'ae\'b8nh s\'e8 ph\'b6i ph\'ef h\'eep v\'edi c
\'b8c y\'aau c\'c7u trong b\'b6ng C3.
\par {\b 
\par 7.9} C\'b8c ch\'f7 s\'e8 ph\'b6i \'ae\'ad\'eec ghi kh\'bec ngay tr\'aan nh\'f7ng v\'b9ch d\'b5i t\'ad\'acng \'f8ng v\'b5 \'eb v\'d2 ph\'dda b\'aan ph\'b6i c\'f1a c\'b8c v\'b9ch ng\'ben h\'acn li\'d2n k\'d2.
\par {\b 
\par 7.10 }C\'b8c v\'b9ch chia v\'b5 ch\'f7 s\'e8 ph\'b6i r\'e2 n\'d0t, d\'d4 \'ae\'e4c v\'b5 kh\'abng t\'c8y xo\'b8 \'ae\'ad\'eec.
\par {\b 
\par }\pard \qj\sb100\sa60\nowidctlpar {\b\fs28 8 Sai s\'e8 cho ph\'d0p l\'edn nh\'cat 
\par }\pard \qj\nowidctlpar {\b\i 
\par }{\b 8.1} Sai s\'e8 cho ph\'d0p{\b  }l\'edn nh\'cat c\'f1a dung t\'ddch danh \'ae\'denh c\'f1a pipet khi ki\'d3m \'ae\'denh ban \'ae\'c7u v\'b5 \'ae\'denh k\'fa \'ae\'ad\'eec cho trong b\'b6ng C4:
\par \pard \qj\sb100\sa60\nowidctlpar 
\par \pard \qr\sb100\sa60\nowidctlpar {\b\i B\'b6ng C4
\par }
