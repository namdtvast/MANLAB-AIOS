{\pntxtb (}{\pntxta )}}{\*\pnseclvl9\pnlcrm\pnstart1\pnindent720\pnhang{\pntxtb (}{\pntxta )}}\pard\plain \qr\nowidctlpar \f15\fs26 {\b\i\f49\fs28 Ph\'f4 l\'f4c C}{\b\f49\fs28  
\par }\pard \qc\nowidctlpar {\b\i\f85 
\par }\pard\plain \s21\qc\nowidctlpar \b\f16\fs32 {\f25\fs28 PIPET chu\'c8n - y\'aau c\'c7u k\'fc thu\'cbt v\'b5 \'aeo l\'ad\'eang
\par }\pard\plain \qj\nowidctlpar \f15\fs26 
\par {\b\fs28 1 \'a7\'denh ngh\'dca
\par }
\par {\b 1.1 Dung t\'ddch 
\par }
\par Dung t\'ddch \'f8ng v\'edi m\'e9t v\'b9ch d\'cau b\'cat k\'fa tr\'aan thang \'aeo l\'b5 th\'d3 t\'ddch c\'f1a n\'ad\'edc \'eb nhi\'d6t \'ae\'e9 ti\'aau chu\'c8n \'ae\'ad\'eec x\'b6 ra t\'f5 pipet sau khi n\'b9p \'ae\'c7y t\'edi v\'b9ch d\'cau \'ae\'e3 c
\'f1a pipet.
\par 
\par {\i\ul Ghi ch\'f3:}{\i  M\'c6t cong c\'f1a n\'ad\'edc trong pipet \'ae\'ad\'eec \'aei\'d2u ch\'d8nh sao cho m\'c6t ph\'bbng theo ph\'ad\'acng n\'bbm ngang \'aei qua m\'d0p tr\'aan c\'f1a v\'b9ch d\'cau ti\'d5p tuy\'d5n v\'edi \'aei\'d3m th\'cap nh\'cat c
\'f1a m\'c6t cong khi quan s\'b8t trong m\'c6t ph\'bcng n\'b5y. 
\par 
\par }{\b 1.2 Dung t\'ddch danh \'ae\'denh 
\par }
\par Dung t\'ddch danh \'ae\'denh l\'b5 gi\'b8 tr\'de th\'d3 t\'ddch b\'bbng s\'e8 l\'edn nh\'cat \'ae\'ad\'eec bi\'d3u th\'de tr\'aan thang \'aeo c\'f1a pipet.
\par 
\par {\b 1.3 Th\'eai gian ch\'b6y 
\par }
\par L\'b5 th\'eai gian c\'c7n thi\'d5t \'ae\'d3 m\'c6t cong c\'f1a n\'ad\'edc h\'b9 t\'f9 do t\'f5 v\'b9ch d\'cau cao nh\'cat \'ae\'d5n \'aei\'d3m m\'b5 m\'c6t cong d\'f5ng l\'b9i t\'b9i \'ae\'c7u m\'f3t c\'f1a pipet.
\par 
\par {\b\fs28 2 Dung t\'ddch danh \'ae\'denh 
\par }
\par {\b 2.1 \'a7\'acn v\'de 
\par }
\par \'a7\'acn v\'de c\'f1a dung t\'ddch l\'b5 centimet kh\'e8i (cm{\super 3}).
\par \pard\plain \s15\qj\nowidctlpar \f15\fs26 
\par C\'e3 th\'d3 s\'f6 d\'f4ng \'ae\'acn v\'de mililit (mL) thay cho centimet kh\'e8i.
\par \pard\plain \qj\nowidctlpar \f15\fs26 
\par {\b 2.2 Gi\'b8 tr\'de  
\par }
\par Dung t\'ddch danh \'ae\'denh c\'f1a pipet ph\'b6i c\'e3 m\'e9t trong c\'b8c gi\'b8 tr\'de sau: 1 cm{\super 3}, 2 cm{\super 3}, 5 cm{\super 3},  10 cm{\super 3}, 25 cm{\super 3}, 50 cm{\super 3}, 100 cm{\super 3} v\'b5 200 cm{\super 3}.          
\par 
\par {\i\ul Ghi ch\'f3: }{\i Khi s\'f6 d\'f4ng v\'edi nh\'f7ng m\'f4c \'ae\'ddch \'ae\'c6c bi\'d6t, cho ph\'d0p pipet c\'e3 dung t\'ddch danh \'ae\'denh kh\'b8c (v\'dd d\'f4 : 20 cm}{\i\super 3}{\i ) v\'edi \'aei\'d2u ki\'d6n ch\'f3ng ph\'ef h\'eep v\'edi c
\'b8c y\'aau c\'c7u c\'f1a t\'b5i li\'d6u n\'b5y.
\par }
\par {\b 2.3 Nhi\'d6t \'ae\'e9 ti\'aau chu\'c8n 
\par }
\par Nhi\'d6t \'ae\'e9 ti\'aau chu\'c8n l\'b5 nhi\'d6t \'ae\'e9 m\'b5 t\'b9i \'ae\'e3 pipet s\'cf x\'b6 ra m\'e9t th\'d3 t\'ddch n\'ad\'edc t\'ad\'acng \'f8ng v\'edi dung t\'ddch danh \'ae\'denh c\'f1a n\'e3. Nhi\'d6t \'ae\'e9 n\'b5y \'ae\'ad\'eec l\'cay b\'bb
ng 20 {\super 0}C.
\par {\b\fs28 3 V\'cbt li\'d6u
\par }{\b\i 
\par }Pipet ph\'b6i \'ae\'ad\'eec l\'b5m b\'bbng thu\'fb tinh s\'b9ch, trong su\'e8t, \'ae\'ad\'eec gia c\'abng t\'e8t v\'b5 c\'e3 c\'b8c t\'ddnh ch\'cat v\'d2 nhi\'d6t \'ae\'e9 v\'b5 ho\'b8 h\'e4c th\'ddch h\'eep. Thu\'fb tinh kh\'abng \'ae\'ad\'eec c\'e3 c
\'b8c khuy\'d5t t\'cbt l\'b5m \'b6nh h\'ad\'ebng \'ae\'d5n vi\'d6c quan s\'b8t ho\'c6c s\'f6 d\'f4ng pipet, \'ae\'c6c bi\'d6t t\'b9i v\'efng l\'a9n c\'cbn c\'f1a thang \'aeo \'ae\'b7 \'ae\'ad\'eec chia \'ae\'e9.
\par 
\par {\b\fs28 4 K\'d5t c\'cau 
\par }{\f16 
\par }{\b\f16 4.1}{\f16  }Pipet ph\'b6i c\'e3 k\'d5t c\'cau \'ae\'f1 b\'d2n v\'f7ng \'ae\'d3 ch\'deu \'ae\'f9ng \'ae\'ad\'eec vi\'d6c s\'f6 d\'f4ng b\'d7nh th\'ad\'eang.
\par {\b\i 
\par }{\b 4.2} Th\'b5nh pipet kh\'abng \'ae\'ad\'eec c\'e3 b\'cat c\'f8 s\'f9 thay \'ae\'e6i \'ae\'b8ng k\'d3 n\'b5o v\'d2 \'ae\'e9 d\'b5y.
\par {\b 
\par 4.3} M\'d0p tr\'aan ph\'b6i vu\'abng g\'e3c v\'edi tr\'f4c c\'f1a pipet v\'b5 ph\'b6i kh\'abng c\'e3 b\'cat c\'f8 khuy\'d5t t\'cbt n\'b5o c\'e3 th\'d3 \'b6nh h\'ad\'ebng \'ae\'d5n v\'de tr\'dd \'ae\'f3ng c\'f1a m\'c6t cong khi \'aei\'d2u khi\'d3n b\'bb
ng tay. 
\par 
\par M\'d0p tr\'aan ph\'b6i h\'aci v\'b8t ra ph\'dda ngo\'b5i, \'ae\'ad\'eec m\'b5i nh\'bdn ho\'c6c h\'ac l\'f6a nh\'d1.
\par 
\par {\b 4.4} \'a7\'c7u d\'ad\'edi c\'f1a pipet \'ae\'ad\'eec k\'d5t th\'f3c t\'b9i \'ae\'c7u h\'f3t c\'e3 d\'b9ng c\'abn d\'c7n \'ae\'d2u v\'b5 kh\'abng \'ae\'ad\'eec c\'e3 b\'cat k\'fa ch\'e7 th\'bet \'ae\'e9t ng\'e9t n\'b5o t\'b9i l\'e7. 
\par 
\par \'a7\'c7u m\'f3t c\'c7n \'ae\'ad\'eec v\'aa tr\'dfn \'ae\'d2u, vu\'abng g\'e3c v\'edi tr\'f4c pipet v\'b5 h\'aci v\'b8t ra ph\'dda ngo\'b5i. 
\par 
\par C\'e3 th\'d3 l\'b5m b\'e3ng b\'bbng c\'b8ch h\'ac l\'f6a nh\'e1 \'ae\'d3 \'ae\'b9t \'ae\'ad\'eec y\'aau c\'c7u n\'aau tr\'aan. 
\par 
\par {\b 4.5} \'a7\'c7u m\'f3t ph\'b6i c\'e3 k\'d5t c\'cau v\'f7ng ch\'bec \'ae\'d3 b\'b6o \'ae\'b6m d\'dfng ch\'b6y \'e6n \'ae\'denh theo y\'aau c\'c7u n\'aau trong m\'f4c 6.
\par {\b\i 
\par }{\b 4.6} Kh\'bec \'ae\'e9
\par 
\par Pipet c\'e3 th\'d3 \'ae\'ad\'eec kh\'bec \'ae\'e9 v\'edi m\'e9t v\'b9ch d\'cau \'f8ng v\'edi dung t\'ddch danh \'ae\'denh (g\'e4i l\'b5 pip\'d0t m\'e9t m\'f8c) ho\'c6c c\'e3 th\'d3 \'ae\'ad\'eec ghi kh\'bec thang \'aeo v\'edi c\'b8c v\'b9ch d\'cau (g\'e4
i l\'b5 pip\'d0t k\'ce \'ae\'e9).
\par 
\par \pard \qj\sb100\sa60\nowidctlpar {\b\fs28 5 H\'d7nh d\'b8ng v\'b5 k\'ddch th\'ad\'edc
\par }{\b 5.1} Pipet ph\'b6i c\'e3 h\'d7nh d\'b8ng t\'e6ng qu\'b8t nh\'ad m\'ab t\'b6 tr\'aan h\'d7nh C1 a), b), c) \'ae\'e8i v\'edi pip\'d0t m\'e9t m\'f8c v\'b5 h\'d7nh C2 \'ae\'e8i v\'edi pipet k\'ce \'ae\'e9.
\par 
\par 
