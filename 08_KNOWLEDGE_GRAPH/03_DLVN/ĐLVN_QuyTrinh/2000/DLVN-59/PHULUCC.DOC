\brdrs\brdrw15 \cellx9498 \pard \nowidctlpar\intbl \'a7\'e9 d\'b5y th\'b5nh pipet\cell \pard \sl360\slmult1\nowidctlpar\intbl Min      2\cell \pard \qc\sl360\slmult1\nowidctlpar\intbl 1.5\cell 1\cell 1\cell 1\cell \pard \intbl \row \pard \qj\nowidctlpar {
\b\fs28 
\par 6 Th\'eai gian ch\'b6y
\par 
\par }{\b 6.1} Th\'eai gian ch\'b6y c\'f1apipet c\'c7n ph\'b6i n\'bbm trong kho\'b6ng t\'f5 20 gi\'a9y \'ae\'d5n 40 gi\'a9y \'ae\'e8i v\'edi pipet c\'e3 dung t\'ddch danh \'ae\'denh t\'f5 (1 {{\field{\*\fldinst SYMBOL 184 \\f "Symbol" \\s 13}{\fldrslt
\f1\fs26}}} 25) cm{\super 3} v\'b5 t\'f5 30 gi\'a9y \'ae\'d5n 70 gi\'a9y \'ae\'e8i v\'edi pipet c\'e3 dung t\'ddch danh \'ae\'denh  t\'f5 (50 {{\field{\*\fldinst SYMBOL 184 \\f "Symbol" \\s 13}{\fldrslt\f1\fs26}}} 200) cm{\super 3}.
\par 
\par {\b 6.2} Th\'eai gian ch\'b6y ph\'b6i \'ae\'ad\'eec ghi kh\'bec tr\'aan pipet.
\par 
\par Th\'eai gian ch\'b6y \'ae\'ad\'eec x\'b8c \'ae\'denh khi ki\'d3m \'ae\'denh v\'b5 ghi kh\'bec tr\'aan pipet ph\'b6i n\'bbm trong gi\'edi h\'b9n quy \'ae\'denh trong m\'f4c 6.1 v\'b5 kh\'abng \'ae\'ad\'eec sai l\'d6ch nhau qu\'b8 4 gi\'a9y.
\par {\b\fs28 
\par 7 Thang \'aeo
\par }\pard\plain \s20\qj\nowidctlpar \f15\fs28 {\b\fs26 
\par 7.1}{\i\fs26  }{\fs26 Thang \'aeo c\'c7n ph\'b6i \'ae\'d2u, c\'b8c v\'b9ch d\'cau ph\'b6i r\'e2 n\'d0t, c\'e3 \'ae\'e9 d\'b5y b\'bbng nhau v\'b5 kh\'abng v\'ad\'eet qu\'b8 0,3 mm.
\par }\pard\plain \qj\nowidctlpar \f15\fs26 {\b 
\par 7.2 }C\'b8c v\'b9ch d\'cau ph\'b6i \'eb g\'e3c b\'aan ph\'b6i c\'f1a tr\'f4c d\'e4c c\'f1a ph\'c7n kh\'bec \'ae\'e9 tr\'aan pipet.
\par {\b 
\par 7.3} Thang \'aeo kh\'abng \'ae\'ad\'eec k\'d0o d\'b5i t\'edi \'ae\'c7u m\'f3t. V\'b9ch d\'cau c\'e3 \'ae\'b8nh s\'e8 d\'ad\'edi c\'efng ph\'b6i \'eb v\'de tr\'dd ph\'ef h\'eep v\'edi y\'aau c\'c7u trong c\'b8c b\'b6ng C2 v\'b5 C3.
\par 
\par Thang \'aeo c\'e3 th\'d3 k\'d5t th\'f3c t\'b9i v\'b9ch \'ae\'b8nh s\'e8 n\'b5y ho\'c6c c\'e3 th\'d3 \'ae\'ad\'eec k\'d0o d\'b5i th\'aam  3 v\'b9ch v\'edi {\expnd0\expndtw4 \'aei\'d2u ki\'d6n c\'b8c v\'b9ch kh\'abng n\'bbm v\'b5o ph\'c7n \'ae\'c7u m\'f3
t (xem v\'dd d\'f4 \'ae\'e8i v\'edi pipet lo\'b9i 2 cm}{\expnd0\expndtw4\super 3}{\expnd0\expndtw4  v\'b5}  10 cm{\super 3}).
\par {\b 
\par 7.4} Gi\'b8 tr\'de \'ae\'e9 chia
\par 
\par Gi\'b8 tr\'de \'ae\'e9 chia thang \'aeo \'ae\'ad\'eec quy \'ae\'denh trong b\'b6ng C3.
\par \pard \qc\nowidctlpar {\b\i 
\par }\pard \qr\nowidctlpar {\b\i B\'b6ng C3
\par }\pard \qc\nowidctlpar {\b\fs28 Gi\'b8 tr\'de \'ae\'e9 chia, cm}{\b\fs28\super 3}{\b\f16 
