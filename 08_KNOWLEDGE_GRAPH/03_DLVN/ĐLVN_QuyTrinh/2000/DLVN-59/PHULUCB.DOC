\li2413\sb60\sa60\nowidctlpar\intbl {\fs26 {\field{\*\fldinst SYMBOL 177 \\f "Symbol" \\s 13}{\fldrslt\f1\fs26}}}{\fs26  0,05\cell }\pard \intbl {\fs26 \row }\trowd \trgaph108\trbrdrt\brdrs\brdrw15 \trbrdrl\brdrs\brdrw15 \trbrdrb\brdrs\brdrw15 \trbrdrr
\brdrs\brdrw15 \trbrdrh\brdrs\brdrw15 \trbrdrv\brdrs\brdrw15 \clbrdrl\brdrs\brdrw15 \clbrdrb\brdrs\brdrw15 \clbrdrr\brdrs\brdrw15 \cellx4678\clbrdrl\brdrs\brdrw15 \clbrdrb\brdrs\brdrw15 \clbrdrr\brdrs\brdrw15 \cellx9498 \pard 
\li1735\sb60\sa60\nowidctlpar\intbl {\fs26 100\cell }\pard \li2413\sb60\sa60\nowidctlpar\intbl {\fs26 {\field{\*\fldinst SYMBOL 177 \\f "Symbol" \\s 13}{\fldrslt\f1\fs26}}}{\fs26  0,1\cell }\pard \intbl {\fs26 \row }\pard \qj\nowidctlpar {\b\i\fs26 

\par 
\par 
\par }{\b\fs26 7.2}{\b\i\fs26  }{\fs26  Sai s\'e8 cho ph\'d0p l\'edn nh\'cat c\'f1a dung t\'ddch \'f8ng v\'edi b\'cat k\'fa v\'b9ch d\'cau n\'b5o tr\'aan thang \'aeo \'ae\'ad\'eec quy \'ae\'denh} {\fs26 b\'bbng v\'edi sai s\'e8 l\'edn nh\'cat cho ph\'d0p c\'f1
a dung t\'ddch danh \'ae\'denh c\'f1a buret.
\par 
\par Sai s\'e8 cho ph\'d0p l\'edn nh\'cat c\'f1a dung t\'ddch c\'f1a kho\'b6ng gi\'f7a hai v\'b9ch d\'cau b\'cat k\'fa tr\'aan thang \'aeo c\'f2ng \'ae\'ad\'eec quy \'ae\'denh} {\fs26 b\'bbng v\'edi sai s\'e8 cho ph\'d0p l\'edn nh\'cat c\'f1a dung t\'dd
ch danh \'ae\'denh c\'f1a buret.
\par 
\par }{\b\fs28 8  Ghi nh\'b7n
\par }{\b\fs26 
\par 8.1}{\fs26  Nh\'f7ng n\'e9i dung sau ph\'b6i \'ae\'ad\'eec ghi t\'b9i ph\'c7n kh\'abng \'ae\'ad\'eec chia \'ae\'e9 c\'f1a buret :
\par }\pard \qj\fi720\nowidctlpar {\fs26 a) M\'e9t ho\'c6c nhi\'d2u ch\'f7 c\'b8i bi\'d3u th\'de buret chu\'c8n;
\par b) }{\f16\fs26 D}{\fs26 ung t\'ddch danh \'ae\'denh b\'bbng ch\'f7 s\'e8 }{\f16\fs26 \'b6}{\fs26  r\'cbp k\'ccm theo k\'fd hi\'d6u cm}{\fs26\super 3}{\fs26  (ho\'c6c mL);
\par c) D\'cau hi\'d6u quy \'ad\'edc "Ex 20 }{\fs26\super 0}{\fs26 C" \'ae\'d3 bi\'d3u th\'de r\'bbng buret \'ae\'ad\'eec hi\'d6u chu\'c8n b\'bbng ph\'ad\'acng ph\'b8p \'ae\'e6 ra t\'b9i nhi\'d6t \'ae\'e9 ti\'aau chu\'c8n l\'b5 20 }{\fs26\super 0}{\fs26 C;

\par d) Th\'eai gian ch\'b6y t\'ddnh theo gi\'a9y;
\par e) T\'aan ho\'c6c k\'fd hi\'d6u c\'f1a c\'ac s\'eb s\'b6n xu\'cat;
\par f) S\'e8 ch\'d5 t\'b9o c\'f1a buret \'ae\'ad\'eec ghi tr\'aan th\'a9n v\'b5 tay v\'c6n kho\'b8 van x\'b6.
\par 
\par }\pard \qj\nowidctlpar {\b\fs26 8.2}{\fs26  T\'cat c\'b6 c\'b8c k\'fd, nh\'b7n hi\'d6u tr\'aan ph\'b6i r\'e2 n\'d0t, d\'d4 \'ae\'e4c v\'b5 kh\'abng t\'c8y xo\'b8 \'ae\'ad\'eec trong \'aei\'d2u ki\'d6n s\'f6 d\'f4ng b\'d7nh th\'ad\'eang c\'f1a buret.

\par }{\b\fs26 
\par }{\b\fs28 9 Bao g\'e3i
\par }{\b\i\fs26 
\par }{\b\fs26 9.1}{\fs26  Buret c\'e3 th\'d3 \'ae\'ad\'eec \'ae\'f9ng trong h\'e9p k\'ddn l\'b5m b\'bbng v\'cbt li\'d6u th\'ddch h\'eep, n\'d5u c\'c7n  l\'e3t nhung, da, nh\'f9a m\'d2m ho\'c6c v\'cbt li\'d6u th\'ddch h\'eep kh\'b8c.
\par 
\par }{\b\fs26 9.2}{\fs26  }{\f16\fs26 c}{\fs26 \'b8c buret ph\'b6i \'ae\'ad\'eec \'ae\'f9ng trong h\'e9p \'ae\'d3 tr\'b8nh b\'cat m\'e4i s\'f9 x\'aa d\'dech, r\'aci l\'b5m h\'ad h\'e1ng.
\par 
\par }{\b\fs28 10 Ghi nh\'b7n h\'e9p \'ae\'f9ng 
\par }{\b\fs26 
\par 10.1}{\fs26  H\'e9p \'ae\'f9ngburet chu\'c8n ph\'b6i c\'e3 bi\'d3n nh\'b7n hi\'d6u bao g\'e5m c\'b8c th\'abng tin sau:
\par \tab a) D\'cau nh\'cbn d\'b9ng qu\'e8c gia;
\par }\pard \qj\fi720\nowidctlpar {\fs26 b) T\'aan ho\'c6c k\'fd hi\'d6u c\'f1a c\'ac s\'eb s\'b6n xu\'cat;
\par c) S\'e8 nh\'cbn d\'b9ng;
\par d) Ph\'b9m vi \'aeo c\'f1a c\'b8c buret;
\par }\pard \qj\nowidctlpar {\b\fs26 
\par 10.2 }{\fs26 C\'e3 th\'d3 s\'f6 d\'f4ng c\'b8c k\'fd nh\'b7n hi\'d6u kh\'b8c kh\'abng tr\'b8i v\'edi quy \'ae\'denh c\'f1a Nh\'b5 n\'ad\'edc.
\par }\pard \qc\nowidctlpar {\b\i\fs26 
\par }}