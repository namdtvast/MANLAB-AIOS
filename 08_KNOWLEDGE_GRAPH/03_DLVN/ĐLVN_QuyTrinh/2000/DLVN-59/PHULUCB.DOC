\clbrdrl\brdrs\brdrw15 \clbrdrb\brdrs\brdrw15 \clbrdrr\brdrs\brdrw15 \cellx4678\clbrdrl\brdrs\brdrw15 \clbrdrb\brdrs\brdrw15 \clbrdrr\brdrs\brdrw15 \cellx9498 \pard \qc\nowidctlpar\intbl {\fs26 100\cell 3\cell }\pard \intbl {\fs26 \row }\pard 
\qj\nowidctlpar {\b\i\fs26 
\par }{\b\fs26 6.5}{\fs26  \'a7\'d3 d\'d4 ph\'a9n bi\'d6t, chi\'d2u d\'b5i c\'f1a c\'b8c v\'b9ch d\'cau ph\'b6i kh\'b8c nhau, c\'f4 th\'d3 nh\'ad sau :
\par }{\b\i\fs26 
\par }{\fs26 6.5.1}{\b\i\fs26  }{\fs26 V\'b9ch d\'b5i ph\'b6i k\'d0o d\'b5i to\'b5n b\'e9 ho\'c6c kho\'b6ng 9/10 chu vi c\'f1a buret v\'b5 li\'d2n n\'d0t. N\'d5u c\'e3 s\'f9 ng\'bet qu\'b7ng n\'b5o \'ae\'e3 tr\'aan v\'b9ch n\'b5y th\'d7 n\'e3 ph\'b6i n\'bbm tr
\'aan \'ae\'ad\'eang sinh b\'aan c\'b9nh khi nh\'d7n v\'b5o buret t\'f5 ph\'dda tr\'ad\'edc.
\par }{\b\i\fs26 
\par }{\fs26 6.5.2}{\b\i\fs26  }{\fs26 Chi\'d2u d\'b5i c\'f1a v\'b9ch trung b\'d7nh ph\'b6i b\'bbng kho\'b6ng 2/3 chu vi c\'f1a buret.
\par }{\b\i\fs26 
\par }{\fs26 6.5.3}{\b\i\fs26  }{\fs26 Chi\'d2u d\'b5i c\'f1a v\'b9ch ng\'ben ph\'b6i b\'bbng ho\'c6c l\'edn h\'acn 1/2 chu vi c\'f1a buret.
\par 
\par 6.5.4}{\i\fs26  }{\fs26 Ph\'c7n k\'d0o d\'b5i sang hai ph\'dda v\'b9ch trung b\'d7nh ph\'b6i l\'b5 \'ae\'e8i x\'f8ng t\'ad\'acng \'f8ng v\'edi c\'b8c \'ae\'c7u m\'f3t c\'f1a v\'b9ch ng\'ben.
\par }\pard \nowidctlpar {\b\i\fs26 
\par }{\b\fs26 6.6}{\b\i\fs26  }{\fs26 Vi\'d6c b\'e8 tr\'dd c\'b8c v\'b9ch c\'e3 \'ae\'e9 d\'b5i kh\'b8c nhau ph\'b6i tu\'a9n th\'f1 theo c\'b8c y\'aau c\'c7u d\'ad\'edi \'ae\'a9y:
\par }\pard \qj\nowidctlpar {\b\i\fs26 
\par }{\fs26 6.6.1}{\b\i\fs26  }{\fs26  Buret c\'e3 dung t\'ddch \'ae\'denh danh l\'b5 10 cm}{\fs26\super 3  }{\fs26 v\'b5 25 cm}{\fs26\super 3 }{\fs26 :
\par \tab a) V\'b9ch \ldblquote 0\rdblquote  v\'b5 c\'f8 c\'b8ch 10 v\'b9ch ph\'b6i l\'b5 v\'b9ch d\'b5i;
\par \tab b) Ph\'b6i c\'e3 4 v\'b9ch trung b\'d7nh c\'b8ch \'ae\'d2u n\'bbm gi\'f7a 2 v\'b9ch d\'b5i li\'d2n k\'d2 nhau;
\par 
\par \tab c) Ph\'b6i c\'e3 1 v\'b9ch ng\'ben n\'bbm gi\'f7a 2 v\'b9ch trung b\'d7nh li\'d2n k\'d2 nhau v\'b5 gi\'f7a v\'b9ch trung b\'d7nh v\'b5 v\'b9ch d\'b5i li\'d2n k\'d2 nhau.
\par }{\b\i\fs26 
\par }{\fs26 6.6.2}{\b\i\fs26  }{\fs26 Buret c\'e3 dung t\'ddch \'ae\'denh danh 50 cm}{\fs26\super 3}{\fs26  :
\par }\pard \qj\fi720\nowidctlpar {\fs26 a)  V\'b9ch \ldblquote 0\rdblquote  v\'b5 c\'b8ch 10 v\'b9ch ph\'b6i l\'b5 v\'b9ch d\'b5i;
\par b)  Ph\'b6i c\'e3 1 v\'b9ch trung b\'d7nh n\'bbm gi\'f7a hai v\'b9ch d\'b5i li\'d2n k\'d2 nhau;
\par c)  Ph\'b6i c\'e3 4 v\'b9ch ng\'ben n\'bbm  gi\'f7a v\'b9ch d\'b5i v\'b5 v\'b9ch trung b\'d7nh li\'d2n k\'d2 nhau.
\par }\pard \qj\nowidctlpar {\b\i\fs26 
\par }{\fs26 6.6.3}{\b\i\fs26  }{\fs26 Buret c\'e3 dung t\'ddch \'ae\'denh danh 100 cm}{\fs26\super 3}{\fs26  :
\par }\pard \qj\li720\nowidctlpar {\fs26 a) V\'b9ch \ldblquote 0\rdblquote  v\'b5 c\'b8ch 5 v\'b9ch ph\'b6i l\'b5 v\'b9ch d\'b5i;
\par }\pard \qj\fi720\nowidctlpar {\fs26 b) Ph\'b6i c\'e3 4 v\'b9ch ng\'ben c\'b8ch \'ae\'d2u n\'bbm gi\'f7a 2 v\'b9ch d\'b5i li\'d2n k\'d2 nhau.
\par }\pard \qj\nowidctlpar {\b\fs26 
\par 6.7}{\fs26  Khi nh\'d7n v\'b5o buret t\'f5 ph\'dda tr\'ad\'edc t\'b9i v\'de tr\'dd s\'f6 d\'f4ng b\'d7nh th\'ad\'eang th\'d7 :
\par }\pard \qj\fi720\nowidctlpar {\fs26 - Tay v\'c6n kho\'b8 van x\'b6 ph\'b6i \'eb ph\'dda b\'aan ph\'b6i c\'f1a ng\'ad\'eai v\'cbn h\'b5nh (h\'d7nh B1);
\par }\pard\plain \s17\qj\fi720\nowidctlpar \f15\fs26 - Tr\'ad\'eang h\'eep buret c\'e3 ki\'d3u nh\'ad m\'ab t\'b6 trong h\'d7nh 2 v\'edi ph\'c7n cong b\'aan d\'ad\'edi h\'ad\'edng v\'d2 ph\'dda ng\'ad\'eai v\'cbn h\'b5nh, \'aei\'d3m b\'bet \'ae\'c7u c\'f1a m
\'e7i v\'b9ch ng\'ben ph\'b6i n\'bbm tr\'aan m\'e9t \'ae\'ad\'eang th\'bcng \'ae\'f8ng t\'ad\'ebng t\'ad\'eeng, b\'bet \'ae\'c7u t\'f5 gi\'f7a  m\'c6t ph\'dda tr\'ad\'edc c\'f1a buret v\'b5 k\'d0o d\'b5i v\'d2 ph\'dda b\'aan tr\'b8i.
\par \pard\plain \qj\nowidctlpar \f15 {\b\fs26 
\par 6.8}{\fs26  C\'b8c v\'b9ch \'ae\'ad\'eec \'ae\'b8nh s\'e8 t\'f5 tr\'aan xu\'e8ng, b\'bet \'ae\'c7u t\'f5 s\'e8 \ldblquote 0\rdblquote  t\'b9i c\'b8c kho\'b6ng kh\'bec \'ae\'e9 nh\'ad trong b\'b6ng 2.
\par }{\b\fs26 
\par 6.9}{\fs26  C\'b8c ch\'f7 s\'e8 ph\'b6i \'ae\'ad\'eec ghi kh\'bec ngay tr\'aan nh\'f7ng v\'b9ch d\'b5i t\'ad\'acng \'f8ng v\'b5 \'eb ph\'dda b\'aan ph\'b6i c\'f1a c\'b8c v\'b9ch ng\'ben h\'acn li\'d2n k\'d2.
\par }{\b\fs26 
\par 6.10 }{\fs26 C\'b8c v\'b9ch d\'cau v\'b5 ch\'f7 s\'e8 ph\'b6i r\'e2 n\'d0t, d\'d4 \'ae\'e4c v\'b5 kh\'abng t\'c8y xo\'b8 \'ae\'ad\'eec.
\par }{\b\fs26 
\par }{\b\fs28 7 Sai s\'e8 cho ph\'d0p l\'edn nh\'cat 
\par }{\b\i\fs26 
\par }{\b\fs26 7.1}{\fs26  Sai s\'e8 l\'edn nh\'cat cho ph\'d0p c\'f1a dung t\'ddch danh \'ae\'denh c\'f1a buret khi ki\'d3m \'ae\'denh ban \'ae\'c7u v\'b5 \'ae\'denh k\'fa \'ae\'ad\'eec cho trong b\'b6ng B5.
\par 
\par }\pard \qr\nowidctlpar {\b\i\fs26 B\'b6ng B5                                                                                                                }{\fs26 
\par }\pard \qj\nowidctlpar {\fs26 
\par }\trowd \trgaph108\trbrdrt\brdrs\brdrw15 \trbrdrl\brdrs\brdrw15 \trbrdrb\brdrs\brdrw15 \trbrdrr\brdrs\brdrw15 \trbrdrh\brdrs\brdrw15 \trbrdrv\brdrs\brdrw15 \clbrdrt\brdrs\brdrw15 \clbrdrl\brdrs\brdrw15 \clbrdrr\brdrs\brdrw15 \cellx4678\clbrdrt
