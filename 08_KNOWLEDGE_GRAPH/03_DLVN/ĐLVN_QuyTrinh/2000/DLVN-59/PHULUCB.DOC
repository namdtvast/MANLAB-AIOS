{\pntxtb (}{\pntxta )}}{\*\pnseclvl9\pnlcrm\pnstart1\pnindent720\pnhang{\pntxtb (}{\pntxta )}}\pard\plain \qr\nowidctlpar \f15 {\b\i\f49\fs28 Ph\'f4 l\'f4c B
\par }\pard \qc\nowidctlpar {\b\f16\fs28 
\par }{\b\f25\fs28 buret chu\'c8n - y\'aau c\'c7u k\'fc thu\'cbt v\'b5 \'aeo l\'ad\'eang
\par }\pard \qj\nowidctlpar {\b\fs26 
\par 
\par }{\b\fs28 1 \'a7\'denh ngh\'dca}{\fs28 
\par }{\b\i\fs26 
\par }{\b\fs26 1.1 Dung t\'ddch 
\par }{\fs26 
\par Dung t\'ddch \'f8ng v\'edi m\'e9t v\'b9ch d\'cau b\'cat k\'fa tr\'aan thang \'aeo l\'b5 th\'d3 t\'ddch c\'f1a n\'ad\'edc \'eb nhi\'d6t \'ae\'e9 ti\'aau chu\'c8n \'ae\'ad\'eec x\'b6 ra t\'f5 v\'b9ch d\'cau \ldblquote O\rdblquote  t\'edi v\'b9ch d\'cau \'ae
\'e3 c\'f1a buret. D\'dfng ch\'b6y ph\'b6i l\'b5 li\'aan t\'f4c cho \'ae\'d5n khi m\'c6t cong c\'f1a ch\'cat l\'e1ng \'ae\'b9t t\'edi v\'b9ch d\'cau n\'b5y tr\'aan thang \'aeo. Kh\'abng \'ae\'ad\'eec \'ae\'d3 ch\'cat l\'e1ng c\'dfn \'ae\'e4ng l\'b9i tr
\'aan th\'b5nh buret tr\'ad\'edc khi d\'f5ng h\'bcn ph\'d0p \'aeo. 
\par 
\par }{\i\fs26\ul Ghi ch\'f3:}{\i\fs26  M\'c6t cong c\'f1a n\'ad\'edc trong buret \'ae\'ad\'eec \'aei\'d2u ch\'d8nh sao cho m\'c6t ph\'bbng theo ph\'ad\'acng n\'bbm ngang \'aei qua m\'d0p tr\'aan c\'f1a v\'b9ch d\'cau ti\'d5p tuy\'d5n v\'edi \'aei\'d3m th\'ca
p nh\'cat c\'f1a m\'c6t cong khi quan s\'b8t trong m\'c6t ph\'bcng n\'b5y. 
\par }{\b\i\fs26 
\par }{\b\fs26 1.2 Dung t\'ddch danh \'ae\'denh
\par }{\fs26        
\par }\pard\plain \s17\qj\nowidctlpar \f15\fs26 Dung t\'ddch danh \'ae\'denh l\'b5 gi\'b8 tr\'de b\'bbng s\'e8 l\'edn nh\'cat tr\'aan thang \'aeo c\'f1a th\'d3 t\'ddch \'ae\'ad\'eec bi\'d3u th\'de tr\'aan buret.
\par \pard\plain \qj\nowidctlpar \f15 {\b\i\fs26 
\par }{\b\fs26 1.3 Th\'eai gian ch\'b6y 
\par }{\fs26 
\par L\'b5 th\'eai gian c\'c7n thi\'d5t \'ae\'d3 m\'c6t cong c\'f1a n\'ad\'edc h\'b9 xu\'e8ng m\'e9t c\'b8ch t\'f9 do t\'f5 v\'b9ch d\'cau \ldblquote 0\rdblquote  t\'edi v\'b9ch chia \'ae\'e9 th\'cap nh\'cat trong \'aei\'d2u ki\'d6n van x\'b6 \'ae\'ad\'eec m
\'eb ho\'b5n to\'b5n v\'b5 d\'dfng ch\'b6y l\'b5 li\'aan t\'f4c.
\par }{\b\fs26 
\par }{\b\fs28 2 Dung t\'ddch danh \'ae\'denh 
\par }{\b\i\fs26 
\par }{\b\fs26 2.1 \'a7\'acn v\'de 
\par }{\fs26 
\par \'a7\'acn v\'de c\'f1a dung t\'ddch l\'b5  centimet kh\'e8i (cm}{\fs26\super 3}{\fs26 ).
\par }\pard\plain \s17\qj\nowidctlpar \f15\fs26 
\par C\'e3 th\'d3 s\'f6 d\'f4ng \'ae\'acn v\'de mililit  (mL) thay cho centimet kh\'e8i.
\par \pard\plain \qj\nowidctlpar \f15 {\b\i\fs26 
\par }{\b\fs26 2.2 Gi\'b8 tr\'de  
\par }{\fs26 
\par Dung t\'ddch danh \'ae\'denh c\'f1a buret ph\'b6i c\'e3 m\'e9t trong c\'b8c gi\'b8 tr\'de sau : 10 cm}{\fs26\super 3}{\fs26 ; 25 cm}{\fs26\super 3}{\fs26 ; 50 cm}{\fs26\super 3}{\fs26  ho\'c6c  100 cm}{\fs26\super 3}{\fs26 .
\par 
\par Khi s\'f6 d\'f4ng v\'edi nh\'f7ng m\'f4c \'ae\'ddch \'ae\'c6c bi\'d6t, cho ph\'d0p buret c\'e3 dung t\'ddch danh \'ae\'denh kh\'b8c (v\'dd d\'f4: 5 cm}{\fs26\super 3}{\fs26  ho\'c6c 20 cm}{\fs26\super 3}{\fs26 ) v\'edi \'aei\'d2u ki\'d6n ch\'f3ng ph\'ef h
\'eep v\'edi c\'b8c y\'aau kh\'b8c n\'aau trong t\'b5i li\'d6u n\'b5y.
\par }{\b\fs26 2.3 Nhi\'d6t \'ae\'e9 ti\'aau chu\'c8n 
\par }{\fs26 
\par Nhi\'d6t \'ae\'e9 ti\'aau chu\'c8n l\'b5 nhi\'d6t \'ae\'e9 m\'b5 t\'b9i \'ae\'e3 buret s\'cf x\'b6 ra m\'e9t th\'d3 t\'ddch ch\'cat l\'e1ng t\'ad\'acng \'f8ng v\'edi dung t\'ddch danh \'ae\'denh c\'f1a n\'e3. Nhi\'d6t \'ae\'e9 n\'b5y \'ae\'ad\'eec l\'ca
y b\'bbng 20 }{\fs26\super 0}{\fs26 C.
\par }{\b\fs26 
\par }{\b\fs28 3 V\'cbt li\'d6u
\par }{\b\i\fs26 
\par }{\b\fs26 3.1}{\fs26  }{\f16\fs26 b}{\fs26 uret ph\'b6i \'ae\'ad\'eec l\'b5m b\'bbng thu\'fb tinh s\'b9ch, trong su\'e8t, \'ae\'ad\'eec gia c\'abng t\'e8t v\'b5 c\'e3 c\'b8c t\'ddnh ch\'cat v\'d2 nhi\'d6t \'ae\'e9 v\'b5 ho\'b8 h\'e4c th\'ddch h\'eep. Thu
\'fb tinh kh\'abng \'ae\'ad\'eec c\'e3 c\'b8c khuy\'d5t t\'cbt l\'b5m \'b6nh h\'ad\'ebng \'ae\'d5n vi\'d6c quan s\'b8t ho\'c6c s\'f6 d\'f4ng buret, \'ae\'c6c bi\'d6t t\'b9i v\'efng l\'a9n c\'cbn c\'f1a thang \'aeo \'ae\'b7 \'ae\'ad\'eec chia \'ae\'e9.

\par 
\par }{\b\fs26 3.2}{\b\i\fs26  }{\fs26 Kho\'b8 c\'f1a van x\'b6 c\'e3 th\'d3 \'ae\'ad\'eec l\'b5m b\'bbng thu\'fb tinh ho\'c6c v\'cbt li\'d6u th\'ddch h\'eep kh\'b8c.
\par }{\b\fs26 
\par }{\b\fs28 4 K\'d5t c\'cau, h\'d7nh d\'b9ng v\'b5 k\'ddch th\'ad\'edc. 
\par }{\b\i\f16\fs26 
\par }{\b\f16\fs26 4.1}{\f16\fs26  B}{\fs26 uret ph\'b6i c\'e3 k\'d5t c\'cau \'ae\'f1 b\'d2n v\'f7ng \'ae\'d3 ch\'deu \'ae\'f9ng \'ae\'ad\'eec vi\'d6c s\'f6 d\'f4ng b\'d7nh th\'ad\'eang.
\par }{\b\i\fs26 
\par }{\b\fs26 4.2}{\fs26  Th\'b5nh buret kh\'abng \'ae\'ad\'eec c\'e3 b\'cat c\'f8 s\'f9 thay \'ae\'e6i \'ae\'b8ng k\'d3 n\'b5o v\'d2 \'ae\'e9 d\'b5y.
\par }{\b\i\fs26 
\par }{\b\fs26 4.3 }{\fs26 Buret ph\'b6i c\'e3 d\'b9ng h\'d7nh tr\'f4. M\'d0p tr\'aan c\'efng ph\'b6i nh\'bdn v\'b5 vu\'abng g\'e3c v\'edi tr\'f4c c\'f1a buret.
\par  
\par }\pard \qj\sb100\sa60\nowidctlpar {\fs26 H\'d7nh d\'b8ng t\'e6ng qu\'b8t c\'f1a buret \'ae\'ad\'eec m\'ab t\'b6 tr\'aan c\'b8c h\'d7nh B1 v\'b5 B2.
\par 
\par }\pard \qj\nowidctlpar {\b\i\fs26 
\par 
\par 
\par 
\par 
\par 
\par 
\par 
\par 
\par 
\par 
\par 
\par 
\par 
\par 
\par 
\par 
\par 
\par                      H\'d7nh B1                                                                    H\'d7nh B2                                
\par }{\b\fs26 4.4}{\fs26  Ph\'c7n d\'ad\'edi c\'f1a buret k\'d5t th\'f3c t\'b9i van x\'b6 v\'b5 v\'dfi x\'b6 v\'b5 l\'b5 hai b\'e9 ph\'cbn c\'cau th\'b5nh c\'f1a buret.
\par }{\b\i\fs26 
\par }{\b\fs26 4.5 }{\fs26 Van x\'b6 ph\'b6i c\'e3 d\'b9ng tr\'dfn \'ae\'d3 \'ae\'b6m b\'b6o \'ae\'e9 k\'ddn c\'f1a buret v\'b5 d\'d4 \'ae\'e3ng m\'eb.
\par       
\par Ph\'c7n tr\'dfn t\'e8t nh\'cat l\'b5 c\'e3 \'ae\'e9 c\'abn v\'edi t\'fb l\'d6 1/10.
\par 
\par N\'d5u c\'c7n  c\'e3 th\'d3 s\'f6 d\'f4ng thi\'d5t b\'de th\'ddch h\'eep \'ae\'d3 gi\'f7 kho\'b8 c\'f1avan x\'b6.
\par }{\b\i\fs26 
\par }{\b\fs26 4.6 }{\fs26 \'a7\'ad\'eang k\'ddnh l\'e7 c\'f1a kho\'b8 van x\'b6 kho\'b6ng 2 mm. K\'ddch th\'ad\'edc c\'f1a kho\'b8 van x\'b6 ph\'b6i ph\'ef h\'eep v\'edi c\'b8c quy \'ae\'denh c\'f1a Nh\'b5 n\'ad\'edc.
\par }{\b\i\fs26 
\par }\pard\plain \s17\qj\nowidctlpar \f15\fs26 \'a7\'e8i v\'edi c\'b8c buret c\'e3 \'e8ng n\'b9p k\'ccm theo \'e8ng kh\'bec \'ae\'e9, c\'b8c \'e8ng \'ae\'ad\'eec \'ae\'e3ng b\'bbng kho\'b8 van x\'b6 2 l\'e7 c\'e3 \'ae\'ad\'eang k\'ddnh kho\'b6ng 2 mm (h\'d7
nh B3). D\'b9ng buret n\'b5y c\'e3 th\'d3 \'ae\'ad\'eec s\'f6 d\'f4ng nh\'ad buret chu\'c8n v\'edi \'aei\'d2u ki\'d6n ch\'f3ng ph\'b6i \'ae\'b8p \'f8ng c\'b8c y\'aau c\'c7u c\'f1a t\'b5i li\'d6u n\'b5y v\'b5 \'ae\'b6m b\'b6o y\'aau c\'c7u v\'d2 \'ae\'e9 k
\'ddn c\'f1a \'e8ng n\'b9p.
\par 
\par 
\par 
\par 
\par 
\par 
\par 
\par 
\par 
\par 
\par 
\par 
\par 
\par 
\par 
\par 
\par 
\par 
\par 
\par 
\par 
\par 
\par 
\par \pard\plain \s9\qc\keepn\nowidctlpar \b\i\f15\fs26 H\'d7nh B3
\par \pard\plain \qj\nowidctlpar \f15 {\b\i\fs26 
\par 
\par }{\b\fs26 4.7 }{\fs26 \'a7\'c7u v\'dfi x\'b6 ph\'b6i c\'abn d\'c7n \'ae\'d2u, kh\'abng c\'e3 ch\'e7 th\'bet l\'b9i \'ae\'e9t ng\'e9t. 
\par }\pard\plain \s18\qj\nowidctlpar \f15\fs28 {\fs26 
\par \'a7\'c7u v\'dfi x\'b6 t\'e8t nh\'cat l\'b5 ph\'b6i \'ae\'ad\'eec v\'aa tr\'dfn, nh\'bdn, vu\'abng g\'e3c v\'edi tr\'f4c buret v\'b5 h\'aci v\'b8t ra ph\'dda ngo\'b5i.
\par }\pard\plain \qj\nowidctlpar \f15 {\fs26 
\par C\'e3 th\'d3 l\'b5m b\'e3ng b\'bbng c\'b8ch h\'ac l\'f6a nh\'e1 \'ae\'d3 \'ae\'b9t \'ae\'ad\'eec y\'aau c\'c7u n\'aau tr\'aan. 
\par 
\par }{\b\fs26 4.8}{\fs26  \'a7\'c7u v\'dfi x\'b6 \'ae\'ad\'eec l\'b5m b\'bbng \'e8ng mao qu\'b6n c\'e3 th\'b5nh d\'b5y.
\par }\pard\plain \s6\qj\keepn\nowidctlpar \f15\fs28 {\fs26         
\par Ch\'e7 n\'e8i v\'edi van x\'b6 kh\'abng \'ae\'ad\'eec c\'e3 l\'e7 c\'e3 kh\'b6 n\'a8ng  t\'b9o b\'e4t kh\'dd.
\par }\pard\plain \qj\nowidctlpar \f15 {\b\i\fs26 
\par }{\b\fs26 4.9 }{\fs26 \'a7\'c7u v\'dfi x\'b6 l\'b5 m\'e9t b\'e9 ph\'cbn c\'cau th\'b5nh c\'f1a buret \'ae\'ad\'eec n\'e8i v\'edi th\'a9n van x\'b6 ho\'c6c l\'b5 m\'e9t ph\'c7n c\'f1a kho\'b8 van x\'b6 (h\'d7nh B1 v\'b5 B2).
\par }{\b\i\fs26 
\par }{\b\fs26 4.10 }{\fs26 K\'ddch th\'ad\'edc c\'f1a buret \'ae\'ad\'eec cho trong b}{\i\fs26 \'b6ng B1}{\b\i\fs26 .}{\fs26 
\par }\pard \qc\nowidctlpar {\b\fs26 
\par }\pard \qr\nowidctlpar {\b\i\fs26 B\'b6ng B1
\par }\pard \qc\nowidctlpar {\b\fs28 C\'b8c k\'ddch th\'ad\'edc
