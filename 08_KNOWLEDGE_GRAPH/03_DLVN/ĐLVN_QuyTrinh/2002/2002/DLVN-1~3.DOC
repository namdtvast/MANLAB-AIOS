\par }\pard \qj \fi720\li0\ri0\widctlpar\faauto\adjustright\rin0\lin0\itap0 {\fs26 
\par }\pard \qj \li0\ri0\widctlpar\faauto\adjustright\rin0\lin0\itap0 {\fs26 Khi ti\'d5n h\'b5nh hi\'d6u chu\'c8n ph\'b6i b\'b6o \'ae\'b6m c\'b8c \'aei\'d2u ki\'d6n hi\'d6u chu\'c8n theo \'ae\'f3ng thuy\'d5t minh k\'fc thu\'cbt c\'f1a c\'b8c b\'e9 suy gi\'b6m 
\'ae\'e5ng tr\'f4c c\'f4 th\'d3 y\'aau c\'c7u. N\'d5u trong thuy\'d5t minh k\'fc thu\'cbt kh\'abng n\'aau th\'d7 ph\'b6i tu\'a9n theo TCVN 1966 - 77 "Kh\'dd h\'cbu chu\'c8n d\'efng trong \'aeo l\'ad\'eang v\'b5 th\'f6 nghi\'d6m".}{
\fs26\lang1033\langfe1033\langnp1033 
\par }\pard \ql \li0\ri0\widctlpar\faauto\adjustright\rin0\lin0\itap0 {\fs26\lang1033\langfe1033\langnp1033 
\par }{\b\lang1033\langfe1033\langnp1033 5}{\b  Ti\'d5n h\'b5nh hi\'d6u chu\'c8n}{\b\lang1033\langfe1033\langnp1033 
\par }\pard \qj \fi720\li0\ri0\widctlpar\faauto\adjustright\rin0\lin0\itap0 {\fs26 
\par }\pard \qj \li0\ri0\widctlpar\faauto\adjustright\rin0\lin0\itap0 {\b\fs26 5.1  }{\fs26 Ki\'d3m tra b\'aan ngo\'b5i
\par 
\par C\'b8c b\'e9 suy gi\'b6m \'ae\'e5ng tr\'f4c d\'b6i t\'c7n s\'e8 t\'f5 100 kHz \'ae\'d5n18 GHz \'ae\'ada \'ae\'d5n hi\'d6u chu\'c8n ph\'b6i kh\'abng b\'de m\'d0o ,v\'ec. C\'b8c ch\'f7, k\'fd hi\'d6u, m\'b7 hi\'d6u, kh\'bec v\'b9ch \'ae\'e9 chia ph\'b6i r
\'e2 r\'b5ng. C\'b8c \'ae\'c7u gh\'d0p n\'e8i \'ae\'e5ng tr\'f4c ph\'b6i s\'b9ch s\'cf, kh\'abng b\'de m\'d0o, b\'d1p. C\'b8c ph\'f4 ki\'d6n, c\'b8p n\'e8i ph\'b6i \'ae\'c7y \'ae\'f1.
\par }{\b\fs26 
\par 5.2}{\fs26   Ki\'d3m tra k\'fc thu\'cbt
\par 
\par C\'b8c b\'e9 suy gi\'b6m}{\b\fs26  }{\fs26 kh\'abng c\'e3 h\'e1ng h\'e3c v\'d2 c\'ac kh\'dd v\'b5 \'aei\'d6n, c\'b8c n\'f3m \'aei\'d2u ch\'d8nh ph\'b6i d\'dech chuy\'d3n d\'d4 d\'b5ng, \'ae\'b6o m\'b9ch ph\'b6i chuy\'d3n \'ae\'e6i ch\'ddnh x\'b8c, gi\'b8
 tr\'de \'ae\'e9 suy gi\'b6m ph\'b6i thi\'d5t l\'cbp \'ae\'ad\'eec tr\'aan to\'b5n thang \'aeo. C\'b8c ph\'f4 ki\'d6n, c\'b8p n\'e8i ph\'b6i gh\'d0p n\'e8i b\'d7nh th\'ad\'acng.
\par 
\par N\'d5u c\'b8c b\'e9 suy gi\'b6m \'ae\'ada \'ae\'d5n hi\'d6u chu\'c8n kh\'abng b\'b6o \'ae\'b6m c\'b8c \'aei\'d2u ki\'d6n n\'aau tr\'aan th\'d7 kh\'abng nh\'cbn v\'b5o \'ae\'d3}{\fs26\lang1033\langfe1033\langnp1033  }{\fs26 hi\'d6u chu\'c8n.
\par }\pard \qr \li0\ri0\widctlpar\faauto\adjustright\rin0\lin0\itap0 {\b\f29\lang1033\langfe1033\langnp1033 \'a7LVN 103 : 2002}{\b\fs26 
