\par H\'d7nh 1. S\'ac \'ae\'e5 \'ae\'d3 x\'b8c \'ae\'denh h\'d6 s\'e8 s\'e3ng \'ae\'f8ng theo \'aei\'d6n \'b8p
\par }\pard \qj \fi720\li0\ri0\widctlpar\faauto\adjustright\rin0\lin0\itap0 {\fs26 
\par }\pard \qj \li0\ri0\widctlpar\faauto\adjustright\rin0\lin0\itap0 {\fs26 Khi hi\'d6u chu\'c8n h\'d6 s\'e8 s\'e3ng \'ae\'f8ng \'aei\'d6n \'b8p \'eb \'ae\'c7u v\'b5o th\'d7 \'ae\'ad\'eang d\'a9y \'aeo n\'e8i tr\'f9c ti\'d5p ho\'c6c qua chuy\'d3n \'ae\'e6i 
\'ae\'e5ng tr\'f4c kh\'abng v\'dfng \'ae\'d6m v\'edi \'ae\'c7u v\'b5o b\'e9 suy gi\'b6m c\'c7n hi\'d6u chu\'c8n. \'a7\'c7u ra c\'f1a n\'e3 n\'e8i tr\'f9c ti\'d5p t\'edi t\'b6i m\'c9u. Khi x\'b8c \'ae\'denh h\'d6 s\'e8 s\'e3ng \'ae\'f8ng theo \'aei\'d6n 
\'b8p \'ae\'c7u ra t}{\fs26\lang1033\langfe1033\langnp1033 h}{\fs26 \'d7 vi\'d6c n\'e8i b\'e9 suy gi\'b6m v\'edi \'ae\'ad\'eang d\'a9y \'aeo v\'b5 t\'b6i m\'c9u ho\'b5n to\'b5n ng\'ad\'eec l\'b9i.
\par 
\par B\'e9 suy gi\'b6m ph\'a9n c\'b8ch ph\'b6i c\'e3 gi\'b8 tr\'de \'ae\'e9 suy gi\'b6m n\'bbm trong kho\'b6ng (10 }{\fs26 {\field{\*\fldinst SYMBOL 184 \\f "Symbol" \\s 13}{\fldrslt\f3\fs26}}}{\fs26  20) dB v\'b5 c\'e3 h\'d6 s\'e8 s\'e3ng \'ae\'f8ng \'aei\'d6
n \'b8p kh\'abng l\'edn h\'acn 1,2.
\par 
\par C\'b8c \'aei\'d3m t\'c7n s\'e8 \'ae\'d3 hi\'d6u chu\'c8n h\'d6 s\'e8 s\'e3ng \'ae\'f8ng theo \'aei\'d6n \'b8p \'ae\'ad\'eec ch\'d8 ra trong l\'fd l\'dech ho\'c6c thuy\'d5t minh k\'fc thu\'cbt c\'f1a c\'b8c b\'e9 suy gi\'b6m c\'c7n hi\'d6u chu\'c8n. Ph\'d0
p hi\'d6u chu\'c8n \'eb m\'e7i t\'c7n s\'e8 \'ae\'ad\'eec l\'c6p l\'b9i \'ddt nh\'cat 3 l\'c7n.
\par 
\par \'a7\'e8i v\'edi c\'b8c b\'e9 suy gi\'b6m \'ae\'e5ng tr\'f4c nh\'c8y n\'cac ho\'c6c bi\'d5n \'ae\'e6i \'ae\'d2u vi\'d6c hi\'d6u chu\'c8n h\'d6 s\'e8 s\'e3ng \'ae\'f8ng theo \'aei\'d6n \'b8p \'eb \'ae\'c7u v\'b5o v\'b5 \'ae\'c7u ra \'ae\'ad\'eec \'aeo \'eb
 \'ddt nh\'cat 3 gi\'b8 tr\'de \'ae\'e9 suy gi\'b6m trong s\'e8 \'ae\'e3 c\'e3 gi\'b8 tr\'de \'ae\'e9 suy gi\'b6m l\'edn nh\'cat v\'b5 b\'d0 nh\'cat.
\par 
\par Gi\'b8 tr\'de h\'d6 s\'e8 s\'e3ng \'ae\'f8ng \'aei\'d6n theo \'b8p \'eb \'ae\'c7u v\'b5o v\'b5 \'ae\'c7u ra trong b\'cat k\'fa l\'c7n \'aeo n\'b5o kh\'abng \'ae\'ad\'eec v\'ad\'eet qu\'b8 gi\'b8 tr\'de cho ph\'d0p. Ghi k\'d5t qu\'b6 hi\'d6u chu\'c8n v\'b5
o bi\'aan b\'b6n hi\'d6u chu\'c8n (ph\'f4 l\'f4c 2).
\par 
\par }{\b\fs26 5.4 }{\fs26 X\'b8c \'ae\'denh \'ae\'e9 suy gi\'b6m ban \'ae\'c7u.}{\b\fs26 
\par }{\fs26 
\par S\'ac \'ae\'e5 kh\'e8i \'ae\'d3 hi\'d6u chu\'c8n b\'e9 suy gi\'b6m ban \'ae\'c7u n\'e8i theo h\'d7nh 2 v\'b5 3.
\par }\pard \qj \fi720\li0\ri0\widctlpar\faauto\adjustright\rin0\lin0\itap0 {\fs26 
