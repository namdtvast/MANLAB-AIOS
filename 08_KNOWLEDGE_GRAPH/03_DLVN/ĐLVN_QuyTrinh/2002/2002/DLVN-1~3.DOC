\par }\pard \qj \li0\ri0\widctlpar\faauto\adjustright\rin0\lin0\itap0 {\b\fs26 
\par 3.1}{\fs26  Ph\'ad\'acng ti\'d6n d\'efng \'ae\'d3 hi\'d6u chu\'c8n c\'b8c b\'e9 suy gi\'b6m \'ae\'e5ng tr\'f4c d\'b6i t\'c7n s\'e8 t\'f5 100 kHz \'ae\'d5n   18 GHz ph\'b6i c\'e3 sai s\'e8 kh\'abng \'ae\'ad\'eec l\'edn h\'acn 1/3 sai s\'e8 c\'ac }{
\fs26\lang1033\langfe1033\langnp1033 b}{\fs26 \'b6n cho ph\'d0p l\'edn nh\'cat c\'f1a b\'e9 suy gi\'b6m c}{\fs26\lang1033\langfe1033\langnp1033 \'c7n}{\fs26  hi\'d6u chu\'c8n.
\par }{\b\f29\lang1033\langfe1033\langnp1033 \'a7LVN 103 : 2002
\par }{\fs26\lang1033\langfe1033\langnp1033 
\par 
\par }{\b\fs26\lang1033\langfe1033\langnp1033 3}{\b\fs26 .2}{\fs26  Ph\'ad\'acng ti\'d6n d\'efng \'ae\'d3 hi\'d6u chu\'c8n c\'b8c b\'e9 suy gi\'b6m \'ae\'e5ng tr\'f4c d\'b6i t\'c7n s\'e8 t\'f5 100 MHz \'ae\'d5n 18 GHz g\'e5m c\'e3: thi\'d5t b\'de \'ae\'d3}{
\fs26\lang1033\langfe1033\langnp1033  }{\fs26 hi\'d6u chu\'c8n suy gi\'b6m}{\fs26\lang1033\langfe1033\langnp1033 , }{\fs26 m\'b8y t\'b9o s\'e3ng c\'e3 d\'b6i t\'c7n s\'e8 t\'ad\'acng \'f8ng v\'edi d\'b6i t\'c7n s\'e8 c\'f1a b\'e9 suy gi\'b6m c\'c7n hi\'d6
u chu\'c8n, \'ae\'ad\'eang d\'a9y \'aeo ho\'c6c m\'b8y \'aeo tr\'eb kh\'b8ng to\'b5n ph\'c7n, t\'b6i m\'c9u, c\'b8c b\'e9 c}{\fs26\lang1033\langfe1033\langnp1033 h}{\fs26 \'d8 th\'de c\'e9ng h\'ad\'ebng c\'f1a \'ae\'ad\'eang d\'a9y \'aeo, c\'b8c b\'e9
 suy gi\'b6m ph\'a9n c\'b8ch, c\'b8c chuy\'d3n \'ae\'e6i \'ae\'e5ng tr\'f4c thi\'d5t b\'de \'ae\'d3 ph\'e8i h\'eep tr\'eb kh\'b8ng v\'b5 c\'b8p n\'e8i. C\'b8c ph\'ad\'acng ti\'d6n hi\'d6u chu\'c8n k\'d3 tr\'aan \'ae\'ad\'eec ch\'e4n tu\'fa thu\'e9c v\'b5
o \'ae\'e9 ch\'ddnh x\'b8c, d\'b6i t\'c7n s\'e8 v\'b5 \'ae\'e9 suy gi\'b6m c\'f1a c\'b8c b\'e9 suy gi\'b6m \'ae\'e5ng tr\'f4c c\'c7n hi\'d6u chu\'c8n.
\par }\pard \qj \fi720\li0\ri0\widctlpar\faauto\adjustright\rin0\lin0\itap0 {\fs26\lang1033\langfe1033\langnp1033 
\par }\pard \qj \li0\ri0\widctlpar\faauto\adjustright\rin0\lin0\itap0 {\b\fs26\lang1033\langfe1033\langnp1033 3}{\b\fs26 .3}{\fs26  Ph\'d0p hi\'d6u chu\'c8n h\'d6 s\'e8 s\'e3ng \'ae\'f8ng tr\'aan \'aei\'d6n \'b8p \'eb \'ae\'c7u v\'b5o }{
\fs26\lang1033\langfe1033\langnp1033 v}{\fs26 \'b5 \'ae\'c7u ra c\'f1a c\'b8c b\'e9 suy gi\'b6m \'ae\'ad\'eec th\'f9c hi\'d6n b\'bbng \'ae\'ad\'eang d\'a9y \'aeo ho\'c6c m\'b8y \'aeo tr\'eb kh\'b8n}{\fs26\lang1033\langfe1033\langnp1033 g}{\fs26  to\'b5
n ph\'c7n c\'e3 sai s\'e8 khi \'aeo h\'d6 s\'e8 s\'e3ng \'ae\'f8ng b\'bbng 2,0 kh\'abng l\'edn h\'acn }{\fs26\ul +}{\fs26  7%.
\par }{\fs26\lang1033\langfe1033\langnp1033 
\par }{\b\fs26\lang1033\langfe1033\langnp1033 3}{\b\fs26 .4}{\fs26  \'a7\'d3 hi\'d6u chu\'c8n gi\'b8 tr\'de \'ae\'e9 suy }{\fs26\lang1033\langfe1033\langnp1033 g}{\fs26 i\'b6m ph\'b6i s\'f6 d\'f4ng thi\'d5t b\'de chuy\'aan d\'f4ng \'ae\'d3 hi\'d6u chu\'c8
n suy gi\'b6m (sau \'ae\'a9y g\'e4i t\'bet l\'b5 thi\'d5t b\'de \'aeo m\'c9u). V\'d7 v\'cby c\'b8c m\'b8y t\'b9o s\'e3ng ph\'b6i c\'e3 ch\'d5 \'ae\'e9 l\'b5m vi\'d6c \'eb \'aei\'d2u ch\'d5 xung ngo\'b5i. T\'ddn hi\'d6u xung \'ae\'d3 \'aei\'d2u ch\'d5 m
\'b8y t\'b9o s\'e3ng l\'cay t\'f5 thi\'d5t b\'de \'ae\'d3}{\fs26\lang1033\langfe1033\langnp1033  }{\fs26 hi\'d6u chu\'c8n suy gi\'b6m.
\par 
\par }{\b\fs26 3.5}{\fs26  Khi hi\'d6u chu\'c8n c\'b8c b\'e9 suy gi\'b6m c\'e3 \'ae\'c7u gh\'d0p n\'e8i \'ae\'e5ng tr\'f4c kh\'b8c v\'edi \'eb thi\'d5t b\'de \'aeo m\'c9u, c\'b8c b\'e9 suy gi\'b6m ph\'b6i \'b8p d\'f4ng  c\'b8c chuy\'d3n \'ae\'e6i \'ae\'e5ng tr
\'f4c c\'e3 gi\'b8 tr\'de h\'d6 s\'e8 s\'e3ng \'ae\'f8ng theo \'aei\'d6n \'b8p kh\'abng l\'edn h\'acn 1,2. N\'d5u sai s\'e8 v\'ad\'eet qu\'b8 1/2 gi\'edi h\'b9n sai s\'e8 cho ph\'d0p th\'d7 ph\'b6i d\'efng chuy\'d3n \'ae\'e6i \'ae\'e5ng tr\'f4c c\'e3 h
\'d6 s\'e8 s\'e3ng \'ae\'f8ng theo \'aei\'d6n \'b8p nh\'e1 h\'acn.
\par }{\i\fs26 
\par }{\i\fs26\ul Ghi ch\'f3}{\i\fs26 :V\'dd d\'f4 ch\'e4n c\'b8c ph\'ad\'acng ti\'d6n hi\'d6u chu\'c8n n\'aau \'eb ph\'f4 l\'f4c 3.
\par }\pard \qj \fi720\li0\ri0\widctlpar\faauto\adjustright\rin0\lin0\itap0 {\fs26 
