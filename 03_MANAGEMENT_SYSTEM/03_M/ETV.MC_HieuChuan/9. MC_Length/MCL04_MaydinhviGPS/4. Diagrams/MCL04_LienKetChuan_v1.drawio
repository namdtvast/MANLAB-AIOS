<mxfile host="app.diagrams.net" agent="ManLab-DrawIO-Skill" version="24.0.0">
  <diagram id="mcl04-lienketchuan" name="MCL.04 - So do lien ket chuan do luong">
    <mxGraphModel dx="1400" dy="1800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="950" pageHeight="1400" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title" value="ETV.MCL 04 — PHƯƠNG TIỆN ĐO ĐỊNH VỊ VỆ TINH (GNSS/GPS) CẦM TAY&#10;SƠ ĐỒ LIÊN KẾT CHUẨN ĐO LƯỜNG (Metrological Traceability Chain)" style="text;html=1;align=center;verticalAlign=middle;fontSize=15;fontStyle=1;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="950" height="60" as="geometry" />
        </mxCell>

        <!-- Level 1: SI / Global GNSS system (out of lab control) -->
        <mxCell id="n1" value="ĐƠN VỊ ĐO LƯỜNG QUỐC TẾ (SI) &amp; HỆ THỐNG VỆ TINH DẪN ĐƯỜNG TOÀN CẦU&#10;GPS / GLONASS / Galileo / BeiDou — Control Segment; hệ quy chiếu WGS-84" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="175" y="90" width="600" height="70" as="geometry" />
        </mxCell>

        <mxCell id="e1" value="Tín hiệu định vị vệ tinh, hệ quy chiếu WGS-84" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;fontSize=11;" edge="1" parent="1" source="n1" target="n2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Level 2: National standard -->
        <mxCell id="n2" value="CHUẨN ĐO LƯỜNG QUỐC GIA&#10;Mạng lưới điểm tọa độ quốc gia VN-2000 / Hệ thống trạm CORS quốc gia&#10;(Viện Đo lường Việt Nam - VMI; Cục Đo đạc, Bản đồ và TTĐL Việt Nam)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="175" y="240" width="600" height="80" as="geometry" />
        </mxCell>

        <mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.2;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="n2" target="n3a">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e3" value="Hiệu chuẩn định kỳ tại phòng hiệu chuẩn được công nhận&#10;(cấp GCN hiệu chuẩn còn hiệu lực)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;fontSize=11;" edge="1" parent="1" source="n2" target="n3b">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.8;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="n2" target="n3c">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Level 3: Working standards of the lab -->
        <mxCell id="n3a" value="Bộ thu GNSS RTK cấp trắc địa&#10;(Leica GS18 / Trimble R10 / CHCNAV i93 hoặc tương đương)&#10;GCN hiệu chuẩn còn hiệu lực" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="55" y="410" width="270" height="100" as="geometry" />
        </mxCell>
        <mxCell id="n3b" value="Máy toàn đạc / máy thủy chuẩn&#10;(kiểm tra, xác lập điểm chuẩn — khi áp dụng)&#10;GCN hiệu chuẩn còn hiệu lực" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="340" y="410" width="270" height="100" as="geometry" />
        </mxCell>
        <mxCell id="n3c" value="Nhiệt ẩm kế, áp kế&#10;(theo dõi điều kiện môi trường đo)&#10;GCN hiệu chuẩn còn hiệu lực" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="625" y="410" width="270" height="100" as="geometry" />
        </mxCell>

        <mxCell id="e5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.5;exitY=1;entryX=0.2;entryY=0;" edge="1" parent="1" source="n3a" target="n4">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e6" value="Đo đạc, xác lập tọa độ chuẩn&#10;(u_ref = U_ref / k, theo GCN)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;fontSize=11;" edge="1" parent="1" source="n3b" target="n4">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e7" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.5;exitY=1;entryX=0.8;entryY=0;" edge="1" parent="1" source="n3c" target="n4">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Level 4: Coordinate reference point (lab reference standard) -->
        <mxCell id="n4" value="ĐIỂM CHUẨN TỌA ĐỘ (CHUẨN MẪU CỦA PTN)&#10;E₀, N₀, h₀ theo VN-2000/WGS-84 — tối thiểu 03 điểm chuẩn&#10;Hồ sơ xác lập điểm chuẩn: ETV.MCL.F04.03 (Phụ lục 03)&#10;Yêu cầu: u(điểm chuẩn) ≤ 1/3 MPE của phương tiện đo" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="175" y="580" width="600" height="100" as="geometry" />
        </mxCell>

        <mxCell id="e8" value="So sánh trực tiếp tại hiện trường&#10;(≥ 10 lần đo/điểm chuẩn; chờ ≥ 30 giây giữa các lần đo — Mục 7.3.2)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;fontSize=11;" edge="1" parent="1" source="n4" target="n5">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Level 5: Unit Under Test (UUT) -->
        <mxCell id="n5" value="PHƯƠNG TIỆN ĐO CẦN HIỆU CHUẨN (UUT)&#10;Máy định vị GPS/GNSS cầm tay của khách hàng&#10;(Garmin GPSMap 65s/66s, eTrex 32x, Trimble Juno, Bad Elf Flex,...)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="175" y="760" width="600" height="80" as="geometry" />
        </mxCell>

        <mxCell id="e9" value="Tính sai số ΔE, ΔN, Δh, eH; xác định ĐKĐBĐ&#10;(JCGM 100:2008 - GUM; TCVN 9595-3:2013)&#10;Quy tắc quyết định: ILAC-G8:09/2019 (Mục 7.3.3 - 7.3.5)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;fontSize=11;" edge="1" parent="1" source="n5" target="n6b">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e10" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.3;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="n5" target="n6a">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e11" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.7;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="n5" target="n6c">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Level 6: Output records / certificate -->
        <mxCell id="n6title" value="KẾT QUẢ &amp; HỒ SƠ HIỆU CHUẨN" style="text;html=1;align=center;fontStyle=1;fontSize=12;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="175" y="950" width="600" height="25" as="geometry" />
        </mxCell>
        <mxCell id="n6a" value="Biên bản hiệu chuẩn&#10;(ETV.MCL.F04.01)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="55" y="985" width="270" height="70" as="geometry" />
        </mxCell>
        <mxCell id="n6b" value="Bảng tính sai số &amp; ĐKĐBĐ&#10;(ETV.MCL.F04.02)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="340" y="985" width="270" height="70" as="geometry" />
        </mxCell>
        <mxCell id="n6c" value="Giấy chứng nhận hiệu chuẩn&#10;(ETV.MCL.F04.04) — dán tem hiệu chuẩn" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="625" y="985" width="270" height="70" as="geometry" />
        </mxCell>

        <!-- Feedback: recalibration cycle -->
        <mxCell id="e12" value="Chu kỳ hiệu chuẩn: 12 tháng (Mục 8)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;dashed=1;strokeColor=#d79b00;fontColor=#d79b00;exitX=1;exitY=0.5;entryX=1;entryY=0.5;" edge="1" parent="1" source="n6c" target="n5">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="925" y="1020" />
              <mxPoint x="925" y="800" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Legend -->
        <mxCell id="legend" value="Chú giải màu sắc" style="text;html=1;align=left;fontStyle=1;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="20" y="1090" width="300" height="30" as="geometry" />
        </mxCell>
        <mxCell id="leg1" value="Chuẩn/hệ thống ngoài phạm vi&#10;kiểm soát trực tiếp của PTN" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="20" y="1125" width="215" height="40" as="geometry" />
        </mxCell>
        <mxCell id="leg2" value="Chuẩn đo lường có liên kết chuẩn&#10;(GCN hiệu chuẩn còn hiệu lực)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="255" y="1125" width="215" height="40" as="geometry" />
        </mxCell>
        <mxCell id="leg3" value="Đối tượng đang được hiệu chuẩn&#10;(UUT)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="490" y="1125" width="215" height="40" as="geometry" />
        </mxCell>
        <mxCell id="leg4" value="Kết quả/hồ sơ đầu ra&#10;đã được chấp nhận" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="725" y="1125" width="200" height="40" as="geometry" />
        </mxCell>

        <mxCell id="legnote" value="Ghi chú: Liên kết chuẩn đo lường (LKC) là tính chất của kết quả đo cho phép liên hệ tới mốc quy chiếu qua một chuỗi hiệu chuẩn không gián đoạn, mỗi bước đóng góp vào độ không đảm bảo đo (VIM; ETV.QM Mục 6.5). Chuẩn công tác và điểm chuẩn tọa độ được duy trì liên kết chuẩn thông qua hiệu chuẩn định kỳ độc lập, kiểm soát theo Thủ tục ETV.MP 05 (Quản lý thiết bị, chuẩn đo lường)." style="text;html=1;align=left;fontSize=10;fontColor=#666666;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="20" y="1180" width="905" height="55" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
